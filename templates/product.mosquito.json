    "custom_liquid_p4J6rj": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elora-how{background:linear-gradient(180deg,#fff 0%,#f4faf6 100%);padding:76px 20px;direction:rtl;font-family:'Assistant','Heebo',sans-serif}\n.elora-how *{box-sizing:border-box}\n.elora-how__head{text-align:center;max-width:720px;margin:0 auto 54px}\n.elora-how__eyebrow{color:#2e9e5b;font-weight:800;font-size:15px;letter-spacing:1px;margin-bottom:14px}\n.elora-how__head h2{font-size:clamp(28px,5vw,44px);font-weight:800;color:#173d29;margin:0 0 14px;line-height:1.25}\n.elora-how__head p{font-size:clamp(16px,2.2vw,19px);color:#5a7767;line-height:1.7;margin:0}\n.elora-how__steps{max-width:900px;margin:0 auto;display:flex;flex-direction:column;gap:22px}\n.elora-how__step{display:flex;align-items:center;gap:26px;background:#fff;border:1px solid #e2f0e7;border-radius:24px;padding:28px 30px;box-shadow:0 10px 34px rgba(23,61,41,.06);opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}\n.elora-how__step.in{opacity:1;transform:none}\n.elora-how__step:nth-child(2){transition-delay:.1s}\n.elora-how__step:nth-child(3){transition-delay:.2s}\n.elora-how__step:nth-child(4){transition-delay:.3s}\n.elora-how__num{flex:0 0 62px;width:62px;height:62px;border-radius:50%;background:linear-gradient(135deg,#39b06a,#2e7d52);color:#fff;font-size:26px;font-weight:800;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 20px rgba(46,125,82,.3)}\n.elora-how__txt h3{font-size:clamp(19px,2.6vw,23px);font-weight:800;color:#173d29;margin:0 0 6px}\n.elora-how__txt p{font-size:clamp(15px,2vw,17px);color:#57756a;line-height:1.65;margin:0}\n.elora-how__txt .k{color:#2e9e5b;font-weight:800}\n.elora-how__cta{text-align:center;margin-top:48px}\n.elora-how__cta a{display:inline-block;background:#173d29;color:#fff;font-weight:800;font-size:18px;padding:16px 44px;border-radius:100px;text-decoration:none;box-shadow:0 12px 30px rgba(23,61,41,.22);transition:transform .2s}\n.elora-how__cta a:hover{transform:translateY(-3px)}\n@media(max-width:600px){.elora-how__step{gap:16px;padding:22px 18px;flex-direction:row}.elora-how__num{flex:0 0 50px;width:50px;height:50px;font-size:21px}}\n</style>\n<section class=\"elora-how\">\n  <div class=\"elora-how__head\">\n    <div class=\"elora-how__eyebrow\">הפתרון של אלורה</div>\n    <h2>אז הנה — איך זה עובד</h2>\n    <p>מדבקה שנדבקת על הבגד ולא על העור, ויוצרת בועת הגנה טבעית שמסתירה את הילד מהיתושים — בלי לגעת בו.</p>\n  </div>\n  <div class=\"elora-how__steps\">\n    <div class=\"elora-how__step js-how\">\n      <div class=\"elora-how__num\">1</div>\n      <div class=\"elora-how__txt\"><h3>מדביקים על הבגד — לא על הילד</h3><p>עור הילד לא בא במגע עם שום דבר. פשוט מדביקים את המדבקה על החולצה או המכנס ויוצאים.</p></div>\n    </div>\n    <div class=\"elora-how__step js-how\">\n      <div class=\"elora-how__num\">2</div>\n      <div class=\"elora-how__txt\"><h3>ציטרונלה טבעית בלבד</h3><p>סרט דבק בדרגה רפואית, <span class=\"k\">מתאים מגיל 0</span>. בלי כימיקלים ובלי חומרים שאתם לא מכירים.</p></div>\n    </div>\n    <div class=\"elora-how__step js-how\">\n      <div class=\"elora-how__num\">3</div>\n      <div class=\"elora-how__txt\"><h3>בועת הגנה שמסתירה את הילד</h3><p>יתושים מנווטים לפי ריח. הציטרונלה על הבגד יוצרת בועת הגנה <span class=\"k\">שמסתירה את הילד מהם — בלי לגעת בו</span>.</p></div>\n    </div>\n    <div class=\"elora-how__step js-how\">\n      <div class=\"elora-how__num\">4</div>\n      <div class=\"elora-how__txt\"><h3>כמות ותזמון פשוטים</h3><p>גיל 0–2: מדבקה אחת על הגב · גיל 3–5: 2 מדבקות · גיל 6+: עד 4 מדבקות. <span class=\"k\">מחליפים כל 8 שעות.</span></p></div>\n    </div>\n  </div>\n  <div class=\"elora-how__cta\"><a href=\"#buy\">התחילו להגן בצורה חכמה »</a></div>\n</section>\n<script>\n(function(){\n  var els=document.querySelectorAll('.js-how');\n  if('IntersectionObserver' in window){\n    var io=new IntersectionObserver(function(e){e.forEach(function(x){if(x.isIntersecting){x.target.classList.add('in');io.unobserve(x.target);}});},{threshold:.2});\n    els.forEach(function(el){io.observe(el);});\n  }else{els.forEach(function(el){el.classList.add('in');});}\n})();\n</script>",
