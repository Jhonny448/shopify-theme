    "custom_liquid_Nw98kb": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  ELORA – סקשן וידאו קרוסלה (RTL) + רקע גן/טבע לילדים\n  ------------------------------------------------------------\n  איך מוסיפים סרטונים:\n  1. העלו את הסרטונים ל: הגדרות ← קבצים (Settings → Files)\n  2. העתיקו את שם הקובץ המדויק (למשל: video1.mp4)\n  3. הדביקו את שמות הקבצים ברשימה שלמטה, מופרדים בפסיק.\n     אפשר גם להדביק קישור מלא (URL) לסרטון חיצוני.\n  * הסרטונים רצים לבד בלופ, מושתקים (חובה להפעלה אוטומטית).\n  ============================================================\n{%- endcomment -%}\n\n{%- comment -%} ←←← ערכו רק את השורה הזו: שמות קבצי הווידאו ←←← {%- endcomment -%}\n{%- assign video_files = \"video1.mp4, video2.mp4, video3.mp4\" -%}\n\n{%- comment -%} אופציונלי: תמונות פתיחה (poster) לכל סרטון, באותו סדר {%- endcomment -%}\n{%- assign poster_files = \"\" -%}\n\n{%- assign video_list = video_files | split: \",\" -%}\n{%- assign poster_list = poster_files | split: \",\" -%}\n\n<section class=\"elora-vc\" dir=\"rtl\" aria-label=\"גלריית סרטונים\">\n\n  {%- comment -%} ===== רקע גן/טבע (CSS + SVG, בלי תמונות) ===== {%- endcomment -%}\n  <div class=\"elora-vc__bg\" aria-hidden=\"true\">\n<span class=\"elora-vc__edge elora-vc__edge--top\"></span>\n    <span class=\"elora-vc__edge elora-vc__edge--bottom\"></span>\n    <span class=\"elora-vc__sun\"></span>\n    <span class=\"elora-vc__cloud elora-vc__cloud--1\"></span>\n    <span class=\"elora-vc__cloud elora-vc__cloud--2\"></span>\n    <span class=\"elora-vc__cloud elora-vc__cloud--3\"></span>\n\n    {%- comment -%} פרפרים מרחפים {%- endcomment -%}\n    <span class=\"elora-vc__flutter elora-vc__flutter--1\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 12c-2-5-9-6-9-1 0 4 6 5 9 1zm0 0c2-5 9-6 9-1 0 4-6 5-9 1z\" fill=\"#ffb3c7\"/><path d=\"M12 12c-1.6 3-7 4.5-8 1m8-1c1.6 3 7 4.5 8 1\" stroke=\"#ff8fb0\" stroke-width=\"1\" fill=\"none\"/></svg>\n    </span>\n    <span class=\"elora-vc__flutter elora-vc__flutter--2\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M12 12c-2-5-9-6-9-1 0 4 6 5 9 1zm0 0c2-5 9-6 9-1 0 4-6 5-9 1z\" fill=\"#ffe08a\"/></svg>\n    </span>\n\n    {%- comment -%} דשא בתחתית {%- endcomment -%}\n    <svg class=\"elora-vc__grass\" viewBox=\"0 0 1440 160\" preserveAspectRatio=\"none\">\n      <path d=\"M0,90 C120,50 240,120 360,80 C480,40 600,110 720,80 C840,50 960,120 1080,80 C1200,45 1320,110 1440,80 L1440,160 L0,160 Z\" fill=\"#8fd66b\"/>\n      <path d=\"M0,120 C160,90 320,140 480,110 C640,85 800,140 960,110 C1120,85 1280,140 1440,110 L1440,160 L0,160 Z\" fill=\"#6cc24a\"/>\n    </svg>\n  </div>\n\n  <div class=\"elora-vc__inner\">\n\n    <h2 class=\"elora-vc__title\">\n      הדרך הכי יעילה להגן על הילד שלך מיתושים…\n      <br>\n      היא לא לשים <span class=\"elora-vc__hl\">שום דבר על העור שלו</span>.\n    </h2>\n\n    <div class=\"elora-vc__carousel\" id=\"eloraCarousel\">\n      <div class=\"elora-vc__track\" id=\"eloraTrack\">\n        {%- for file in video_list -%}\n          {%- assign vsrc = file | strip -%}\n          {%- unless vsrc contains \"http\" -%}\n            {%- assign vsrc = vsrc | file_url -%}\n          {%- endunless -%}\n\n          {%- assign psrc = \"\" -%}\n          {%- if poster_list.size > forloop.index0 -%}\n            {%- assign praw = poster_list[forloop.index0] | strip -%}\n            {%- if praw != \"\" -%}\n              {%- if praw contains \"http\" -%}\n                {%- assign psrc = praw -%}\n              {%- else -%}\n                {%- assign psrc = praw | file_url -%}\n              {%- endif -%}\n            {%- endif -%}\n          {%- endif -%}\n\n          <div class=\"elora-vc__slide\" data-index=\"{{ forloop.index0 }}\">\n            <div class=\"elora-vc__video-wrap\">\n              <video\n                class=\"elora-vc__video\"\n                {% if psrc != \"\" %}poster=\"{{ psrc }}\"{% endif %}\n                playsinline\n                muted\n                loop\n                autoplay\n                preload=\"metadata\">\n                <source src=\"{{ vsrc }}\" type=\"video/mp4\">\n              </video>\n            </div>\n          </div>\n        {%- endfor -%}\n      </div>\n\n      {%- comment -%} חצים – מותאמים ל-RTL {%- endcomment -%}\n      <button class=\"elora-vc__arrow elora-vc__arrow--prev\" id=\"eloraPrev\" type=\"button\" aria-label=\"הקודם\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 18l6-6-6-6\"/></svg>\n      </button>\n      <button class=\"elora-vc__arrow elora-vc__arrow--next\" id=\"eloraNext\" type=\"button\" aria-label=\"הבא\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M15 18l-6-6 6-6\"/></svg>\n      </button>\n    </div>\n\n    <div class=\"elora-vc__dots\" id=\"eloraDots\"></div>\n  </div>\n</section>\n\n<style>\n  .elora-vc {\n    --vc-accent: #2f5fd6;\n    --vc-text: #14181f;\n    --vc-radius: 20px;\n    position: relative;\n    font-family: inherit;\n    padding: 40px 0 44px;\n    color: var(--vc-text);\n    overflow: hidden;\n    isolation: isolate;\n  }\n  .elora-vc *,\n  .elora-vc *::before,\n  .elora-vc *::after { box-sizing: border-box; }\n\n  /* ===== רקע גן/טבע ===== */\n  .elora-vc__bg {\n    position: absolute;\n    inset: 0;\n    z-index: -1;\n    background: linear-gradient(180deg, #cdeeff 0%, #e6f7ff 42%, #f3fbef 100%);\n    pointer-events: none;\n  }\n/* ===== שוליים מסולסלים (פאזל) למעלה ולמטה ===== */\n  .elora-vc__edge {\n    position: absolute;\n    left: 0;\n    width: 100%;\n    height: 22px;\n    z-index: 2;\n    background: #ffffff; /* צבע הרקע של הדף — שנו אם הרקע שלכם לא לבן */\n    pointer-events: none;\n  }\n  .elora-vc__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n  .elora-vc__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n  .elora-vc__sun {\n    position: absolute;\n    top: 26px; left: 8%;\n    width: 70px; height: 70px;\n    border-radius: 50%;\n    background: radial-gradient(circle, #fff3b0 0%, #ffe066 60%, rgba(255,224,102,0) 72%);\n    box-shadow: 0 0 40px rgba(255, 214, 82, .55);\n    animation: elora-sun 6s ease-in-out infinite;\n  }\n  @keyframes elora-sun { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }\n\n  .elora-vc__cloud {\n    position: absolute;\n    background: #ffffff;\n    border-radius: 50px;\n    opacity: .9;\n    filter: drop-shadow(0 6px 10px rgba(120,160,190,.18));\n  }\n  .elora-vc__cloud::before,\n  .elora-vc__cloud::after {\n    content: \"\";\n    position: absolute;\n    background: #ffffff;\n    border-radius: 50%;\n  }\n  .elora-vc__cloud--1 { top: 40px; width: 90px; height: 26px; animation: elora-drift-a 26s linear infinite; }\n  .elora-vc__cloud--1::before { width: 40px; height: 40px; top: -18px; left: 14px; }\n  .elora-vc__cloud--1::after  { width: 30px; height: 30px; top: -12px; left: 46px; }\n  .elora-vc__cloud--2 { top: 96px; width: 70px; height: 20px; opacity: .8; animation: elora-drift-b 34s linear infinite; }\n  .elora-vc__cloud--2::before { width: 30px; height: 30px; top: -14px; left: 10px; }\n  .elora-vc__cloud--2::after  { width: 24px; height: 24px; top: -9px; left: 36px; }\n  .elora-vc__cloud--3 { top: 20px; width: 60px; height: 18px; opacity: .75; animation: elora-drift-a 40s linear infinite; }\n  .elora-vc__cloud--3::before { width: 26px; height: 26px; top: -12px; left: 10px; }\n  .elora-vc__cloud--3::after  { width: 20px; height: 20px; top: -7px; left: 32px; }\n\n  @keyframes elora-drift-a { from{right:-140px} to{right:110%} }\n  @keyframes elora-drift-b { from{right:110%} to{right:-140px} }\n\n  .elora-vc__flutter { position: absolute; width: 26px; height: 26px; }\n  .elora-vc__flutter svg { width: 100%; height: 100%; display: block; transform-origin: center; animation: elora-wing .35s ease-in-out infinite alternate; }\n  .elora-vc__flutter--1 { top: 130px; right: 14%; animation: elora-fly-1 18s ease-in-out infinite; }\n  .elora-vc__flutter--2 { top: 170px; left: 16%; width: 20px; height: 20px; animation: elora-fly-2 22s ease-in-out infinite; }\n  @keyframes elora-wing { from{transform:scaleX(.7)} to{transform:scaleX(1)} }\n  @keyframes elora-fly-1 { 0%{transform:translate(0,0)} 25%{transform:translate(-40px,-24px)} 50%{transform:translate(-90px,10px)} 75%{transform:translate(-30px,30px)} 100%{transform:translate(0,0)} }\n  @keyframes elora-fly-2 { 0%{transform:translate(0,0)} 33%{transform:translate(50px,-20px)} 66%{transform:translate(20px,26px)} 100%{transform:translate(0,0)} }\n\n  .elora-vc__grass {\n    position: absolute;\n    bottom: 0; left: 0;\n    width: 100%; height: 120px;\n    display: block;\n  }\n  @media (max-width: 600px) {\n    .elora-vc__grass { height: 80px; }\n    .elora-vc__sun { width: 54px; height: 54px; top: 18px; }\n  }\n\n  /* ===== תוכן ===== */\n  .elora-vc__inner {\n    position: relative;\n    z-index: 1;\n    max-width: 760px;\n    margin: 0 auto;\n    padding: 0 16px;\n  }\n\n  .elora-vc__title {\n    position: relative;\n    text-align: center;\n    font-size: clamp(21px, 5.2vw, 32px);\n    line-height: 1.4;\n    font-weight: 800;\n    margin: 0 auto 30px;\n    max-width: 640px;\n    letter-spacing: -0.2px;\n    /* לוח קריאות עדין מאחורי הטקסט – שהרקע לעולם לא יסתיר אותו */\n    background: rgba(255, 255, 255, .72);\n    -webkit-backdrop-filter: blur(3px);\n    backdrop-filter: blur(3px);\n    padding: 18px 22px;\n    border-radius: 18px;\n    box-shadow: 0 6px 22px rgba(60, 90, 120, .10);\n  }\n  .elora-vc__hl {\n    position: relative;\n    white-space: nowrap;\n    padding-bottom: 2px;\n  }\n  .elora-vc__hl::after {\n    content: \"\";\n    position: absolute;\n    right: 0;\n    left: 0;\n    bottom: -6px;\n    height: 7px;\n    background:\n      linear-gradient(var(--vc-accent), var(--vc-accent)) top/100% 2.5px no-repeat,\n      linear-gradient(var(--vc-accent), var(--vc-accent)) bottom/100% 2.5px no-repeat;\n    border-radius: 2px;\n    opacity: .95;\n  }\n\n  /* Carousel */\n  .elora-vc__carousel {\n    position: relative;\n    border-radius: var(--vc-radius);\n  }\n  .elora-vc__track {\n    display: flex;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    scroll-behavior: smooth;\n    gap: 0;\n    border-radius: var(--vc-radius);\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n  .elora-vc__track::-webkit-scrollbar { display: none; }\n\n  .elora-vc__slide {\n    flex: 0 0 100%;\n    scroll-snap-align: center;\n    padding: 0 4px;\n  }\n\n  .elora-vc__video-wrap {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 9 / 16;\n    max-height: 620px;\n    margin: 0 auto;\n    background: #0d0f14;\n    border-radius: var(--vc-radius);\n    overflow: hidden;\n    box-shadow: 0 18px 46px rgba(15, 24, 48, .18);\n    border: 4px solid rgba(255,255,255,.85);\n  }\n  @media (min-width: 768px) {\n    .elora-vc__video-wrap { aspect-ratio: 16 / 10; max-height: 460px; }\n  }\n\n  .elora-vc__video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  /* Arrows */\n  .elora-vc__arrow {\n    position: absolute;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 46px;\n    height: 46px;\n    border: none;\n    border-radius: 50%;\n    background: rgba(255, 255, 255, .96);\n    color: var(--vc-text);\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 6px 18px rgba(15, 24, 48, .2);\n    z-index: 3;\n    transition: transform .16s ease, background .16s ease;\n  }\n  .elora-vc__arrow:hover { transform: translateY(-50%) scale(1.08); background: #fff; }\n  .elora-vc__arrow svg { width: 22px; height: 22px; }\n  /* ב-RTL: \"הבא\" בצד שמאל, \"הקודם\" בצד ימין */\n  .elora-vc__arrow--next { left: 10px; }\n  .elora-vc__arrow--prev { right: 10px; }\n\n  @media (max-width: 500px) {\n    .elora-vc__arrow { width: 40px; height: 40px; }\n    .elora-vc__arrow--next { left: 6px; }\n    .elora-vc__arrow--prev { right: 6px; }\n  }\n\n  /* Dots */\n  .elora-vc__dots {\n    display: flex;\n    justify-content: center;\n    gap: 8px;\n    margin-top: 18px;\n  }\n  .elora-vc__dot {\n    width: 9px;\n    height: 9px;\n    border-radius: 50%;\n    border: none;\n    padding: 0;\n    background: rgba(255,255,255,.85);\n    box-shadow: 0 1px 3px rgba(60,90,120,.3);\n    cursor: pointer;\n    transition: transform .18s ease, background .18s ease;\n  }\n  .elora-vc__dot.is-active {\n    background: var(--vc-accent);\n    transform: scale(1.35);\n  }\n\n  @media (prefers-reduced-motion: reduce) {\n    .elora-vc__sun, .elora-vc__cloud, .elora-vc__flutter, .elora-vc__flutter svg { animation: none; }\n  }\n</style>\n\n<script>\n  (function () {\n    var carousel = document.getElementById('eloraCarousel');\n    if (!carousel) return;\n\n    var track  = document.getElementById('eloraTrack');\n    var slides = Array.prototype.slice.call(track.querySelectorAll('.elora-vc__slide'));\n    var prev   = document.getElementById('eloraPrev');\n    var next   = document.getElementById('eloraNext');\n    var dotsEl = document.getElementById('eloraDots');\n    if (!slides.length) return;\n\n    var current = 0;\n    var AUTO_MS = 5000;\n    var autoTimer = null;\n\n    /* Build dots */\n    slides.forEach(function (s, i) {\n      var d = document.createElement('button');\n      d.type = 'button';\n      d.className = 'elora-vc__dot' + (i === 0 ? ' is-active' : '');\n      d.setAttribute('aria-label', 'סרטון ' + (i + 1));\n      d.addEventListener('click', function () { goTo(i, true); });\n      dotsEl.appendChild(d);\n    });\n    var dots = Array.prototype.slice.call(dotsEl.children);\n\n    function updateDots() {\n      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === current); });\n    }\n\n    function goTo(index, userAction) {\n      current = (index + slides.length) % slides.length;\n      var slide = slides[current];\n      track.scrollTo({ left: slide.offsetLeft - track.offsetLeft, behavior: 'smooth' });\n      updateDots();\n      if (userAction) restartAuto();\n    }\n\n    /* RTL: הבא = הבא ברשימה, הקודם = הקודם ברשימה */\n    next.addEventListener('click', function () { goTo(current + 1, true); });\n    prev.addEventListener('click', function () { goTo(current - 1, true); });\n\n    /* Sync current index while user swipes */\n    var scrollDebounce;\n    track.addEventListener('scroll', function () {\n      clearTimeout(scrollDebounce);\n      scrollDebounce = setTimeout(function () {\n        var best = 0, bestDist = Infinity;\n        var mid = track.scrollLeft + track.offsetWidth / 2;\n        slides.forEach(function (s, i) {\n          var c = s.offsetLeft + s.offsetWidth / 2;\n          var dist = Math.abs(c - mid);\n          if (dist < bestDist) { bestDist = dist; best = i; }\n        });\n        if (best !== current) { current = best; updateDots(); }\n      }, 90);\n    });\n\n    /* Auto-advance every 5s */\n    function startAuto() {\n      stopAuto();\n      autoTimer = setInterval(function () { goTo(current + 1, false); }, AUTO_MS);\n    }\n    function stopAuto() { if (autoTimer) { clearInterval(autoTimer); autoTimer = null; } }\n    function restartAuto() { startAuto(); }\n\n    carousel.addEventListener('mouseenter', stopAuto);\n    carousel.addEventListener('mouseleave', startAuto);\n    document.addEventListener('visibilitychange', function () {\n      if (document.hidden) stopAuto(); else startAuto();\n    });\n\n    /* ודא שכל הסרטונים רצים לבד, מושתקים */\n    slides.forEach(function (slide) {\n      var video = slide.querySelector('.elora-vc__video');\n      if (!video) return;\n      video.muted = true;\n      var tryPlay = function () { var p = video.play(); if (p && p.catch) p.catch(function(){}); };\n      if (video.readyState >= 2) tryPlay();\n      else video.addEventListener('loadeddata', tryPlay, { once: true });\n    });\n\n    startAuto();\n  })();\n</script>",
