      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  ELORA – סקשן טיעון (reframe) — בא אחרי סקשן הווידאו\n  ------------------------------------------------------------\n  חשוב לחיבור ה\"פאזל\":\n  • בהגדרות הבלוק הזה: Padding → Top = 0\n  • בהגדרות הבלוק הקודם (הווידאו): Padding → Bottom = 0\n    כך השוליים המסולסלים נפגשים ומשתלבים.\n  ============================================================\n{%- endcomment -%}\n\n<section class=\"elora-arg\" dir=\"rtl\">\n\n  {%- comment -%} שוליים מסולסלים – מוסטים בחצי צעד כדי להשתלב בסקשן הקודם {%- endcomment -%}\n  <span class=\"elora-arg__edge elora-arg__edge--top\" aria-hidden=\"true\"></span>\n\n  <div class=\"elora-arg__inner\">\n\n    <p class=\"elora-arg__p\" data-reveal>\n      כן, זה נשמע קצת מוזר  כי זה נוגד את מה <span class=\"elora-arg__b\">שאנחנו מכירים</span>.\n    </p>\n\n    <p class=\"elora-arg__p\" data-reveal>\n      אבל רוב ההורים לא יודעים שיש פתרון שעובד\n      <span class=\"elora-arg__mark\">בלי למרוח או לרסס כלום</span>\n      על <span class=\"elora-arg__b\">העור של הילד</span>.\n    </p>\n\n    <p class=\"elora-arg__p\" data-reveal>\n      אומרים שהתרסיסים האלה בטוחים. אולי זה נכון.\n    </p>\n\n    <p class=\"elora-arg__headline\" data-reveal>\n      אבל כשמדובר <strong>בילד שלך</strong> \n      למה בכלל לקחת סיכון, אם יש פתרון שעובד בלי לשים\n      <span class=\"elora-arg__hl\">שום דבר על העור שלו</span>?\n    </p>\n\n  </div>\n\n  <span class=\"elora-arg__edge elora-arg__edge--bottom\" aria-hidden=\"true\"></span>\n</section>\n\n<style>\n  .elora-arg {\n    --arg-accent: #2f5fd6;\n    --arg-text: #1c2430;\n    --arg-bg: #fffff;          /* ירוק עדין ורך */\n    --arg-edge: #ffffff;        /* צבע הרקע של הדף / הסקשן הקודם */\n    position: relative;\n    font-family: inherit;\n    color: var(--arg-text);\n    background: var(--arg-bg);\n    padding: 54px 0 58px;\n    overflow: hidden;\n    isolation: isolate;\n  }\n  .elora-arg *,\n  .elora-arg *::before,\n  .elora-arg *::after { box-sizing: border-box; }\n\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .elora-arg__edge {\n    position: absolute;\n    left: 0;\n    width: 100%;\n    height: 22px;\n    z-index: 2;\n    background: var(--arg-edge);\n    pointer-events: none;\n  }\n  /* למעלה: מוסט ב-22px כדי להשתלב בשוליים התחתונים של סקשן הווידאו */\n  .elora-arg__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  /* למטה: אותה שפה מסולסלת להמשכיות עם מה שיבוא אחרי */\n  .elora-arg__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n\n  /* ===== תוכן ===== */\n  .elora-arg__inner {\n    position: relative;\n    z-index: 1;\n    max-width: 620px;\n    margin: 0 auto;\n    padding: 0 22px;\n    text-align: center;\n  }\n\n  .elora-arg__p {\n    font-size: clamp(18px, 4.4vw, 23px);\n    line-height: 1.75;\n    font-weight: 500;\n    margin: 0 0 18px;\n    color: #33404f;\n  }\n  .elora-arg__p:last-of-type { margin-bottom: 24px; }\n\n  /* הדגשה פשוטה (בולד) */\n  .elora-arg__b { font-weight: 800; color: inherit; }\n\n  /* הדגשת מרקר רכה */\n  .elora-arg__mark {\n    font-weight: 800;\n    color: var(--arg-accent);\n    background: linear-gradient(180deg, transparent 62%, rgba(47, 95, 214, .16) 62%);\n    padding: 0 3px;\n    border-radius: 3px;\n    white-space: nowrap;\n  }\n\n  /* ===== כותרת שאלת הסיכון (במקום הבועה) ===== */\n  .elora-arg__headline {\n    margin: 26px auto 0;\n    max-width: 560px;\n    font-size: clamp(21px, 5.2vw, 28px);\n    line-height: 1.5;\n    font-weight: 800;\n    color: var(--arg-text);\n  }\n  .elora-arg__headline strong { color: var(--arg-accent); }\n\n  /* קריאה חוזרת לכותרת של הסקשן הקודם – שני פסים */\n  .elora-arg__hl {\n    position: relative;\n    white-space: nowrap;\n    padding-bottom: 2px;\n  }\n  .elora-arg__hl::after {\n    content: \"\";\n    position: absolute;\n    right: 0; left: 0; bottom: -5px;\n    height: 7px;\n    background:\n      linear-gradient(var(--arg-accent), var(--arg-accent)) top/100% 2.5px no-repeat,\n      linear-gradient(var(--arg-accent), var(--arg-accent)) bottom/100% 2.5px no-repeat;\n    border-radius: 2px;\n    opacity: .95;\n  }\n\n  /* ===== אנימציית הופעה מדורגת ===== */\n  [data-reveal] {\n    opacity: 0;\n    transform: translateY(18px);\n    transition: opacity .6s ease, transform .6s ease;\n  }\n  [data-reveal].is-visible {\n    opacity: 1;\n    transform: none;\n  }\n  @media (prefers-reduced-motion: reduce) {\n    [data-reveal] { opacity: 1; transform: none; transition: none; }\n  }\n</style>\n\n<script>\n  (function () {\n    var section = document.currentScript && document.currentScript.previousElementSibling;\n    var root = document.querySelector('.elora-arg');\n    if (!root) return;\n    var items = Array.prototype.slice.call(root.querySelectorAll('[data-reveal]'));\n    if (!items.length) return;\n\n    if (!('IntersectionObserver' in window)) {\n      items.forEach(function (el) { el.classList.add('is-visible'); });\n      return;\n    }\n\n    var io = new IntersectionObserver(function (entries) {\n      entries.forEach(function (entry) {\n        if (entry.isIntersecting) {\n          var el = entry.target;\n          var i = items.indexOf(el);\n          el.style.transitionDelay = (i * 140) + 'ms';\n          el.classList.add('is-visible');\n          io.unobserve(el);\n        }\n      });\n    }, { threshold: 0.2 });\n\n    items.forEach(function (el) { io.observe(el); });\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 16,
        "padding_bottom": 24
      }
    },
    "custom_liquid_FaJwnt": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  ELORA – \"איך זה עובד\" — חלל קסום לילדים (Sticky + Hyperspace)\n  ------------------------------------------------------------\n  • שדה כוכבים חי + ניצוצות פסטל, קפיצת היילספייס בין שלבים.\n  • רקטה חמודה חולפת, כוכב לכת פסטלי מרחף — vibe ילדותי.\n  • יתושים מצוירים עם כנפיים מתנפנפות; בשלב 3 נהדפים מהמגן.\n  • לחיבור הפאזל: Padding → Top = 0 בבלוק הזה,\n    Padding → Bottom = 0 בבלוק שמעליו.\n  • כיוונונים מהירים:\n      – מהירות גלילה:  height של .elora-how__scroller (300vh,\n        גדול יותר = איטי יותר)\n      – גובה הפאנל:    --panel-h\n  ★ התמונות = ממלא־מקום זמני. החליפו את הקישורים כאן למטה:\n  ============================================================\n{%- endcomment -%}\n\n{%- comment -%} ←←← תמונות (זמניות) — החליפו כאן ←←← {%- endcomment -%}\n{%- assign img_problem  = \"https://loremflickr.com/700/440/mosquito,baby?lock=11\" -%}\n{%- assign img_failed   = \"https://loremflickr.com/700/440/child,cream?lock=22\" -%}\n{%- assign img_solution = \"https://loremflickr.com/700/440/child,summer?lock=41\" -%}\n\n{%- comment -%} יתוש מצויר (בשימוש חוזר) {%- endcomment -%}\n{%- capture mosq_svg -%}\n<svg viewBox=\"0 0 72 56\" fill=\"none\">\n  <g class=\"elora-how__wing elora-how__wing--b\"><ellipse cx=\"38\" cy=\"14\" rx=\"11\" ry=\"5.5\" fill=\"rgba(255,255,255,.5)\" stroke=\"rgba(255,255,255,.85)\" stroke-width=\"1.6\" transform=\"rotate(-4 38 14)\"/></g>\n  <g class=\"elora-how__wing elora-how__wing--a\"><ellipse cx=\"25\" cy=\"15\" rx=\"13\" ry=\"6.5\" fill=\"rgba(255,255,255,.62)\" stroke=\"rgba(255,255,255,.9)\" stroke-width=\"1.6\" transform=\"rotate(-14 25 15)\"/></g>\n  <ellipse cx=\"30\" cy=\"33\" rx=\"14\" ry=\"9.5\" fill=\"#ff9d9d\" stroke=\"#ff6b6b\" stroke-width=\"2.4\"/>\n  <path d=\"M22 27.5c1.5 3.5 1.5 7.5 0 11M29 25.8c1.6 4.4 1.6 9.6 0 14\" stroke=\"#ff6b6b\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <circle cx=\"49\" cy=\"25\" r=\"7.5\" fill=\"#ff9d9d\" stroke=\"#ff6b6b\" stroke-width=\"2.4\"/>\n  <circle cx=\"51.4\" cy=\"23.6\" r=\"2.5\" fill=\"#3b1f2b\"/>\n  <circle cx=\"52.3\" cy=\"22.7\" r=\".9\" fill=\"#fff\"/>\n  <path d=\"M55.5 29l11 6\" stroke=\"#ff6b6b\" stroke-width=\"2.6\" stroke-linecap=\"round\"/>\n  <path d=\"M20 41l-4 6M28 43l-2 7M36 42l2 6\" stroke=\"#ff6b6b\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n</svg>\n{%- endcapture -%}\n\n<section class=\"elora-how\" dir=\"rtl\">\n\n  <span class=\"elora-how__edge elora-how__edge--top\" aria-hidden=\"true\"></span>\n\n  <div class=\"elora-how__scroller\">\n    <div class=\"elora-how__sticky\">\n\n      <canvas class=\"elora-how__stars\" aria-hidden=\"true\"></canvas>\n\n      <div class=\"elora-how__bg\" aria-hidden=\"true\">\n        <div class=\"elora-how__bg-layer\" data-layer=\"0\"></div>\n        <div class=\"elora-how__bg-layer\" data-layer=\"1\"></div>\n        <div class=\"elora-how__bg-layer\" data-layer=\"2\"></div>\n      </div>\n\n      {%- comment -%} קישוטי חלל ילדותיים {%- endcomment -%}\n      <div class=\"elora-how__deco\" aria-hidden=\"true\">\n        <span class=\"elora-how__planet\">\n          <svg viewBox=\"0 0 80 60\" fill=\"none\">\n            <circle cx=\"40\" cy=\"30\" r=\"17\" fill=\"#ffd9a8\" stroke=\"#ffb864\" stroke-width=\"2.5\"/>\n            <path d=\"M27 26c3-2.5 8-4 13-4s10 1.5 13 4\" stroke=\"#ffb864\" stroke-width=\"2\" stroke-linecap=\"round\" opacity=\".55\"/>\n            <circle cx=\"34\" cy=\"28\" r=\"2\" fill=\"#3b2b1f\"/>\n            <circle cx=\"46\" cy=\"28\" r=\"2\" fill=\"#3b2b1f\"/>\n            <path d=\"M35 35c1.6 1.8 3.4 2.6 5 2.6s3.4-.8 5-2.6\" stroke=\"#3b2b1f\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n            <ellipse cx=\"40\" cy=\"33\" rx=\"30\" ry=\"8\" stroke=\"#b9a4ff\" stroke-width=\"3\" fill=\"none\" transform=\"rotate(-14 40 33)\"/>\n          </svg>\n        </span>\n        <span class=\"elora-how__rocket\">\n          <svg viewBox=\"0 0 60 60\" fill=\"none\">\n            <path d=\"M30 6c7 6 10 14 10 22l-10 8-10-8c0-8 3-16 10-22z\" fill=\"#eef3ff\" stroke=\"#9db7e8\" stroke-width=\"2.4\"/>\n            <circle cx=\"30\" cy=\"22\" r=\"5\" fill=\"#a5c8ff\" stroke=\"#5f8ad1\" stroke-width=\"2\"/>\n            <path d=\"M20 30l-7 9 9-2M40 30l7 9-9-2\" fill=\"#ffb0b0\" stroke=\"#ff7b7b\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n            <g class=\"elora-how__flame\">\n              <path d=\"M30 38c3 4 3 8 0 13-3-5-3-9 0-13z\" fill=\"#ffd166\" stroke=\"#ff9f43\" stroke-width=\"1.8\"/>\n            </g>\n          </svg>\n        </span>\n      </div>\n\n      <div class=\"elora-how__dots\" aria-hidden=\"true\">\n        <span class=\"elora-how__dot is-active\"></span>\n        <span class=\"elora-how__dot\"></span>\n        <span class=\"elora-how__dot\"></span>\n      </div>\n\n      <div class=\"elora-how__content\">\n        <div class=\"elora-how__kicker\"><i></i>אז הנה איך זה עובד</div>\n\n        <div class=\"elora-how__stages\">\n\n          {%- comment -%} ===== שלב 1 – הבעיה ===== {%- endcomment -%}\n          <article class=\"elora-how__stage\" data-stage=\"0\">\n            <span class=\"elora-how__tag elora-how__tag--red\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 8v5M12 16h.01\"/></svg>\n              הבעיה\n            </span>\n\n            <div class=\"elora-how__media elora-how__media--holo\">\n              <img src=\"{{ img_problem }}\" alt=\"ילד עם עקיצות יתושים\" loading=\"eager\">\n              <span class=\"elora-how__mosq elora-how__mosq--1\">{{ mosq_svg }}</span>\n              <span class=\"elora-how__mosq elora-how__mosq--2\">{{ mosq_svg }}</span>\n              <span class=\"elora-how__mosq elora-how__mosq--3\">{{ mosq_svg }}</span>\n            </div>\n\n            <p class=\"elora-how__text\">\n              כל קיץ אותו סיפור.\n              יתושים, עקיצות, ילד שמגרד —<br>\n              ואתם מחפשים פתרון <b>שסוף סוף יעבוד</b>.\n            </p>\n          </article>\n\n          {%- comment -%} ===== שלב 2 – מה שניסיתם ===== {%- endcomment -%}\n          <article class=\"elora-how__stage\" data-stage=\"1\">\n            <span class=\"elora-how__tag elora-how__tag--gray\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 12a8 8 0 1 1-3-6.2\"/><path d=\"M20 4v4h-4\"/></svg>\n              מה שכבר ניסיתם\n            </span>\n\n            <div class=\"elora-how__fails\">\n              <figure class=\"elora-how__fail\">\n                <div class=\"elora-how__fail-ic\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M8 9h8l-1 9.2a2 2 0 0 1-2 1.8h-2a2 2 0 0 1-2-1.8L8 9z\"/><path d=\"M9.5 9V6.5A2.5 2.5 0 0 1 12 4a2.5 2.5 0 0 1 2.5 2.5V9\"/><path d=\"M10 13h4\"/></svg>\n                  <span class=\"elora-how__fail-x\" aria-hidden=\"true\">✕</span>\n                </div>\n                <figcaption>קרם</figcaption>\n              </figure>\n\n              <figure class=\"elora-how__fail\">\n                <div class=\"elora-how__fail-ic\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"8\" y=\"9\" width=\"8\" height=\"11\" rx=\"2\"/><path d=\"M10 9V6h3\"/><path d=\"M13 6l3.5-1.5M13 4h3.5M13 8l3.5 1.5\"/></svg>\n                  <span class=\"elora-how__fail-x\" aria-hidden=\"true\">✕</span>\n                </div>\n                <figcaption>תרסיס</figcaption>\n              </figure>\n\n              <figure class=\"elora-how__fail\">\n                <div class=\"elora-how__fail-ic\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3s5.5 6 5.5 10a5.5 5.5 0 0 1-11 0C6.5 9 12 3 12 3z\"/></svg>\n                  <span class=\"elora-how__fail-x\" aria-hidden=\"true\">✕</span>\n                </div>\n                <figcaption>משהו על העור</figcaption>\n              </figure>\n            </div>\n\n            <p class=\"elora-how__text elora-how__text--sm\">\n              ועדיין הילד חזר הביתה עם עקיצות. שמתם עליו משהו שלא הייתם בטוחים לגביו,\n              <b>ובסוף גם זה לא עזר</b>.\n            </p>\n\n            <div class=\"elora-how__media elora-how__media--failed\">\n              <img src=\"{{ img_failed }}\" alt=\"מריחת קרם על ילד\" loading=\"lazy\">\n            </div>\n          </article>\n\n          {%- comment -%} ===== שלב 3 – הפתרון ===== {%- endcomment -%}\n          <article class=\"elora-how__stage\" data-stage=\"2\">\n            <span class=\"elora-how__tag elora-how__tag--green\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12l5 5L20 6\"/></svg>\n              הפתרון\n            </span>\n\n            <div class=\"elora-how__media elora-how__media--shield\">\n              <img src=\"{{ img_solution }}\" alt=\"ילד מוגן מיתושים בחוץ\" loading=\"lazy\">\n              <span class=\"elora-how__shield-badge\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3l7 3v5c0 4.4-3 8.2-7 9.5C8 19.2 5 15.4 5 11V6l7-3z\"/><path d=\"M9 12l2 2 4-4.5\"/></svg>\n              </span>\n              <span class=\"elora-how__deflect elora-how__deflect--r\" aria-hidden=\"true\">{{ mosq_svg }}<b></b></span>\n              <span class=\"elora-how__deflect elora-how__deflect--l\" aria-hidden=\"true\">{{ mosq_svg }}<b></b></span>\n            </div>\n\n            <p class=\"elora-how__lead\">יש פתרון אחר.</p>\n            <p class=\"elora-how__text--solution\">\n              מדבקה שמדביקים <b>על הבגד</b> — <span class=\"elora-how__no\">לא על העור</span>.\n            </p>\n\n            <div class=\"elora-how__hours\">\n              <span class=\"elora-how__hours-clock\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 48 48\" fill=\"none\">\n                  <circle cx=\"24\" cy=\"24\" r=\"21\" stroke=\"rgba(111,232,154,.28)\" stroke-width=\"2\"/>\n                  <g stroke=\"rgba(111,232,154,.75)\" stroke-width=\"2.4\" stroke-linecap=\"round\">\n                    <path d=\"M24 3v4M45 24h-4M24 45v-4M3 24h4M38.8 9.2l-2.8 2.8M38.8 38.8l-2.8-2.8M9.2 38.8l2.8-2.8M9.2 9.2l2.8 2.8\"/>\n                  </g>\n                  <g class=\"elora-how__sweep\" stroke=\"#6fe89a\" stroke-width=\"2.6\" stroke-linecap=\"round\">\n                    <path d=\"M24 24V10\"/>\n                  </g>\n                  <circle cx=\"24\" cy=\"24\" r=\"2.6\" fill=\"#6fe89a\"/>\n                </svg>\n              </span>\n              <span class=\"elora-how__hours-txt\">\n                <span class=\"elora-how__hours-num\">עד 8 שעות</span>\n                <span class=\"elora-how__hours-sub\">הגנה רציפה מיתושים</span>\n              </span>\n            </div>\n          </article>\n\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <span class=\"elora-how__edge elora-how__edge--bottom\" aria-hidden=\"true\"></span>\n</section>\n\n<style>\n  .elora-how {\n    --how-blue: #7fb0ff;\n    --how-green: #6fe89a;\n    --how-red: #ff7b7b;\n    --how-text: #e9eefb;\n    --how-edge: #ffffff;              /* צבע הרקע של הדף מעל/מתחת */\n    --panel-h: min(100svh, 680px);    /* ← גובה הפאנל */\n    position: relative;\n    font-family: inherit;\n    color: var(--how-text);\n    background: #060a16;              /* חלל רך */\n    isolation: isolate;\n  }\n  .elora-how *,\n  .elora-how *::before,\n  .elora-how *::after { box-sizing: border-box; }\n\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .elora-how__edge {\n    position: absolute; left: 0; width: 100%; height: 22px; z-index: 6;\n    background: var(--how-edge); pointer-events: none;\n  }\n  .elora-how__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  .elora-how__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n\n  /* ===== מבנה גלילה ===== */\n  .elora-how__scroller { height: 300vh; }   /* ← מהירות: גדול יותר = איטי יותר */\n  .elora-how__sticky {\n    position: -webkit-sticky; position: sticky;\n    top: 0;\n    top: max(0px, calc((100svh - var(--panel-h)) / 2));\n    height: 100vh;\n    height: var(--panel-h);\n    overflow: hidden;\n    display: flex; align-items: center; justify-content: center;\n  }\n\n  .elora-how__stars { position: absolute; inset: 0; z-index: 0; display: block; }\n\n  .elora-how__bg { position: absolute; inset: 0; z-index: 1; pointer-events: none; }\n  .elora-how__bg-layer { position: absolute; inset: 0; opacity: 0; transition: opacity 200ms linear; will-change: opacity; }\n  .elora-how__bg-layer[data-layer=\"0\"] { opacity: 1; background: radial-gradient(115% 85% at 50% 36%, rgba(84, 130, 240, .28) 0%, rgba(84, 130, 240, 0) 70%); }\n  .elora-how__bg-layer[data-layer=\"1\"] { background: radial-gradient(115% 85% at 50% 36%, rgba(240, 110, 130, .2) 0%, rgba(240, 110, 130, 0) 70%); }\n  .elora-how__bg-layer[data-layer=\"2\"] { background: radial-gradient(115% 85% at 50% 36%, rgba(80, 225, 140, .24) 0%, rgba(80, 225, 140, 0) 72%); }\n\n  /* ===== קישוטים ילדותיים ===== */\n  .elora-how__deco { position: absolute; inset: 0; z-index: 1; pointer-events: none; }\n  .elora-how__planet {\n    position: absolute; top: 7%; right: 6%;\n    width: clamp(64px, 12vw, 96px);\n    animation: elora-bob 6s ease-in-out infinite;\n    filter: drop-shadow(0 0 14px rgba(255, 216, 168, .3));\n  }\n  .elora-how__planet svg { width: 100%; height: auto; display: block; }\n  @keyframes elora-bob { 0%,100%{transform:translateY(0) rotate(-4deg)} 50%{transform:translateY(-12px) rotate(4deg)} }\n\n  .elora-how__rocket {\n    position: absolute; bottom: -70px; left: -70px;\n    width: clamp(44px, 9vw, 62px);\n    opacity: 0;\n    animation: elora-rocket 15s ease-in-out infinite;\n    animation-delay: 2s;\n    filter: drop-shadow(0 0 12px rgba(165, 200, 255, .35));\n  }\n  .elora-how__rocket svg { width: 100%; height: auto; display: block; transform: rotate(38deg); }\n  .elora-how__flame { transform-box: fill-box; transform-origin: top center; animation: elora-flame .22s ease-in-out infinite alternate; }\n  @keyframes elora-flame { from { transform: scaleY(.75); } to { transform: scaleY(1.15); } }\n  @keyframes elora-rocket {\n    0%   { transform: translate(0, 0); opacity: 0; }\n    4%   { opacity: 1; }\n    30%  { transform: translate(calc(100vw + 140px), calc(-1 * var(--panel-h) - 140px)); opacity: 1; }\n    31%, 100% { transform: translate(0, 0); opacity: 0; }\n  }\n\n  .elora-how__content {\n    position: relative; z-index: 2; width: 100%; max-width: 680px;\n    margin: 0 auto; padding: 24px;\n    display: flex; flex-direction: column; align-items: center;\n    gap: clamp(12px, 2.2vh, 20px);\n  }\n\n  /* Kicker */\n  .elora-how__kicker {\n    display: inline-flex; align-items: center; gap: 9px;\n    padding: 7px 17px; border-radius: 999px;\n    background: rgba(16, 26, 52, .66);\n    border: 1px solid rgba(127, 176, 255, .4);\n    box-shadow: 0 0 18px rgba(127, 176, 255, .18);\n    color: #dce8ff;\n    font-size: clamp(12px, 3.2vw, 15px); font-weight: 700; letter-spacing: .05em; white-space: nowrap;\n  }\n  .elora-how__kicker i {\n    width: 7px; height: 7px; border-radius: 50%;\n    background: var(--how-blue);\n    box-shadow: 0 0 8px var(--how-blue);\n    animation: elora-blink 1.6s ease-in-out infinite;\n  }\n  @keyframes elora-blink { 0%,100%{opacity:1} 50%{opacity:.25} }\n\n  .elora-how__dots {\n    position: absolute; left: 16px; top: 50%; transform: translateY(-50%); z-index: 4;\n    display: flex; flex-direction: column; gap: 11px;\n  }\n  .elora-how__dot {\n    width: 9px; height: 9px; border-radius: 50%;\n    background: rgba(255, 255, 255, .22);\n    transition: background .3s ease, transform .3s ease, box-shadow .3s ease;\n  }\n  .elora-how__dot.is-active { background: var(--how-blue); box-shadow: 0 0 10px var(--how-blue); transform: scale(1.5); }\n\n  .elora-how__stages { display: grid; width: 100%; }\n  .elora-how__stage {\n    grid-column: 1; grid-row: 1;\n    display: flex; flex-direction: column; align-items: center; text-align: center;\n    gap: clamp(11px, 2vh, 17px);\n    opacity: 0; will-change: opacity, transform;\n  }\n\n  /* תגיות שלב */\n  .elora-how__tag {\n    display: inline-flex; align-items: center; gap: 7px;\n    padding: 6px 15px; border-radius: 999px;\n    font-size: clamp(12px, 3.2vw, 14px); font-weight: 800; letter-spacing: .04em;\n    background: rgba(255, 255, 255, .05);\n    animation: elora-wobble 5s ease-in-out infinite;\n  }\n  @keyframes elora-wobble { 0%,100%{transform:rotate(0)} 25%{transform:rotate(1.6deg)} 75%{transform:rotate(-1.6deg)} }\n  .elora-how__tag svg { width: 15px; height: 15px; }\n  .elora-how__tag--red   { color: var(--how-red);   border: 1px solid rgba(255, 123, 123, .45); box-shadow: 0 0 14px rgba(255, 123, 123, .2); }\n  .elora-how__tag--gray  { color: #b6c2da;          border: 1px solid rgba(182, 194, 218, .4);  box-shadow: 0 0 14px rgba(182, 194, 218, .14); }\n  .elora-how__tag--green { color: var(--how-green); border: 1px solid rgba(111, 232, 154, .45); box-shadow: 0 0 14px rgba(111, 232, 154, .2); }\n\n  /* ===== מדיה ===== */\n  .elora-how__media { position: relative; width: 100%; max-width: min(430px, 84vw); }\n  .elora-how__media img {\n    width: 100%; aspect-ratio: 16 / 10; object-fit: cover;\n    max-height: 32vh;\n    border-radius: 20px; display: block;\n  }\n  .elora-how__media--holo img {\n    border: 2px solid rgba(127, 176, 255, .55);\n    box-shadow: 0 0 30px rgba(127, 176, 255, .22), 0 18px 44px rgba(0, 0, 0, .5);\n  }\n  .elora-how__media--failed { max-width: min(390px, 80vw); }\n  .elora-how__media--failed img {\n    max-height: 24vh;\n    border: 2px solid rgba(255, 123, 123, .4);\n    box-shadow: 0 0 24px rgba(255, 123, 123, .16), 0 16px 38px rgba(0, 0, 0, .5);\n    filter: saturate(.8);\n  }\n\n  /* יתושים — כנפיים מתנפנפות */\n  .elora-how__wing { transform-box: fill-box; transform-origin: bottom center; }\n  .elora-how__wing--a { animation: elora-flap .16s ease-in-out infinite alternate; }\n  .elora-how__wing--b { animation: elora-flap .16s ease-in-out infinite alternate-reverse; }\n  @keyframes elora-flap { from { transform: rotate(-4deg) scaleY(1); } to { transform: rotate(10deg) scaleY(.62); } }\n\n  .elora-how__mosq { position: absolute; width: 52px; pointer-events: none; filter: drop-shadow(0 3px 8px rgba(0,0,0,.45)); }\n  .elora-how__mosq svg { width: 100%; height: auto; display: block; }\n  .elora-how__mosq--1 { top: -26px; right: -10px; animation: elora-fly1 7s ease-in-out infinite; }\n  .elora-how__mosq--2 { bottom: -18px; left: -14px; width: 42px; animation: elora-fly2 9s ease-in-out infinite; transform: scaleX(-1); }\n  .elora-how__mosq--2 svg { transform: scaleX(-1); }\n  .elora-how__mosq--3 { top: 30%; left: -30px; width: 34px; animation: elora-fly3 8s ease-in-out infinite; }\n  @keyframes elora-fly1 { 0%,100%{transform:translate(0,0) rotate(-6deg)} 30%{transform:translate(-28px,16px) rotate(6deg)} 65%{transform:translate(-10px,-12px) rotate(-3deg)} }\n  @keyframes elora-fly2 { 0%,100%{transform:translate(0,0) rotate(8deg)} 40%{transform:translate(22px,-18px) rotate(-5deg)} 75%{transform:translate(6px,10px) rotate(3deg)} }\n  @keyframes elora-fly3 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(14px,-20px) rotate(10deg)} }\n\n  /* ===== כיפת מגן (שלב 3) ===== */\n  .elora-how__media--shield img {\n    border: 2.5px solid rgba(111, 232, 154, .75);\n    box-shadow: 0 0 34px rgba(111, 232, 154, .3), 0 18px 44px rgba(0, 0, 0, .5);\n  }\n  .elora-how__media--shield::before,\n  .elora-how__media--shield::after {\n    content: \"\"; position: absolute; inset: 0;\n    border-radius: 20px;\n    border: 1.6px solid rgba(111, 232, 154, .55);\n    pointer-events: none;\n    animation: elora-ring 2.6s ease-out infinite;\n  }\n  .elora-how__media--shield::after { animation-delay: 1.3s; }\n  @keyframes elora-ring { 0% { transform: scale(1); opacity: .8; } 100% { transform: scale(1.14); opacity: 0; } }\n\n  .elora-how__shield-badge {\n    position: absolute; bottom: -16px; left: 50%; transform: translateX(-50%);\n    width: 46px; height: 46px; border-radius: 50%;\n    background: #0a1a10; color: var(--how-green);\n    border: 2px solid rgba(111, 232, 154, .8);\n    box-shadow: 0 0 18px rgba(111, 232, 154, .5);\n    display: flex; align-items: center; justify-content: center;\n    z-index: 2;\n    animation: elora-badge 3s ease-in-out infinite;\n  }\n  @keyframes elora-badge { 0%,100%{transform:translateX(-50%) scale(1)} 50%{transform:translateX(-50%) scale(1.1)} }\n  .elora-how__shield-badge svg { width: 24px; height: 24px; }\n\n  /* יתושים נהדפים מהמגן */\n  .elora-how__deflect { position: absolute; width: 46px; pointer-events: none; filter: drop-shadow(0 3px 8px rgba(0,0,0,.45)); }\n  .elora-how__deflect svg { width: 100%; height: auto; display: block; }\n  .elora-how__deflect b {\n    position: absolute; top: 50%; width: 16px; height: 16px; border-radius: 50%;\n    border: 2.5px solid rgba(111, 232, 154, .95);\n    box-shadow: 0 0 10px rgba(111, 232, 154, .8);\n    opacity: 0; pointer-events: none;\n  }\n  .elora-how__deflect--r { top: 14%; right: -46px; animation: elora-def-r 3.6s ease-in-out infinite; }\n  .elora-how__deflect--r svg { transform: scaleX(-1); }\n  .elora-how__deflect--r b { right: auto; left: -10px; animation: elora-spark 3.6s ease-out infinite; }\n  .elora-how__deflect--l { bottom: 20%; left: -40px; width: 38px; animation: elora-def-l 4.4s ease-in-out infinite; animation-delay: .8s; }\n  .elora-how__deflect--l b { left: auto; right: -10px; animation: elora-spark 4.4s ease-out infinite; animation-delay: .8s; }\n  @keyframes elora-def-r {\n    0%, 100% { transform: translate(0, 0) rotate(-10deg); }\n    42%      { transform: translate(-20px, 8px) rotate(-4deg); }\n    50%      { transform: translate(-24px, 10px) rotate(0deg); }\n    58%      { transform: translate(2px, -6px) rotate(24deg); }\n    70%      { transform: translate(8px, -10px) rotate(-12deg); }\n  }\n  @keyframes elora-def-l {\n    0%, 100% { transform: translate(0, 0) rotate(8deg); }\n    42%      { transform: translate(18px, -6px) rotate(3deg); }\n    50%      { transform: translate(22px, -8px) rotate(0deg); }\n    58%      { transform: translate(-2px, 6px) rotate(-22deg); }\n    70%      { transform: translate(-8px, 10px) rotate(10deg); }\n  }\n  @keyframes elora-spark {\n    0%, 46% { opacity: 0; transform: scale(.4); }\n    52%     { opacity: 1; transform: scale(1); }\n    66%, 100% { opacity: 0; transform: scale(1.6); }\n  }\n\n  /* ===== טקסטים ===== */\n  .elora-how__text {\n    margin: 0; max-width: 560px;\n    font-size: clamp(19px, 4.6vw, 26px); line-height: 1.5; font-weight: 500; color: var(--how-text);\n  }\n  .elora-how__text b { color: var(--how-blue); font-weight: 800; text-shadow: 0 0 16px rgba(127, 176, 255, .45); }\n  .elora-how__text--sm { margin: 0; max-width: 520px; font-size: clamp(15px, 3.8vw, 19px); line-height: 1.55; font-weight: 500; color: #c6d1e6; }\n  .elora-how__text--sm b { color: var(--how-red); font-weight: 800; text-shadow: 0 0 14px rgba(255, 123, 123, .4); }\n\n  .elora-how__lead {\n    margin: 0; font-size: clamp(24px, 6vw, 34px); font-weight: 900; line-height: 1.15;\n    color: #fff; text-shadow: 0 0 24px rgba(111, 232, 154, .3);\n  }\n  .elora-how__text--solution {\n    margin: 0; max-width: 520px;\n    font-size: clamp(17px, 4.3vw, 24px); line-height: 1.5; font-weight: 600; color: var(--how-text);\n  }\n  .elora-how__text--solution b { color: var(--how-green); font-weight: 900; text-shadow: 0 0 16px rgba(111, 232, 154, .5); }\n  .elora-how__no {\n    font-weight: 900; color: var(--how-blue);\n    text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 3px;\n    text-shadow: 0 0 16px rgba(127, 176, 255, .45);\n  }\n\n  /* ===== שלב 2 — כרטיסי כישלון (גדולים יותר) ===== */\n  .elora-how__fails { display: flex; gap: clamp(14px, 4vw, 26px); justify-content: center; }\n  .elora-how__fail { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 10px; }\n  .elora-how__fail:nth-child(1) { animation: elora-bob-s 4.6s ease-in-out infinite; }\n  .elora-how__fail:nth-child(2) { animation: elora-bob-s 4.6s ease-in-out infinite; animation-delay: .7s; }\n  .elora-how__fail:nth-child(3) { animation: elora-bob-s 4.6s ease-in-out infinite; animation-delay: 1.4s; }\n  @keyframes elora-bob-s { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-7px)} }\n  .elora-how__fail-ic {\n    position: relative;\n    width: clamp(92px, 26vw, 122px); height: clamp(92px, 26vw, 122px);\n    border-radius: 26px;\n    background: rgba(255, 255, 255, .065);\n    border: 1.6px solid rgba(255, 255, 255, .18);\n    box-shadow: 0 0 22px rgba(255, 123, 123, .12), 0 12px 26px rgba(0, 0, 0, .45);\n    display: flex; align-items: center; justify-content: center; color: #c3cfe4;\n  }\n  .elora-how__fail-ic svg { width: 50%; height: 50%; }\n  .elora-how__fail-x {\n    position: absolute; top: -11px; left: -11px;\n    width: 36px; height: 36px; border-radius: 50%;\n    background: #ff4d4d; color: #fff;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 19px; font-weight: 900; line-height: 1;\n    box-shadow: 0 0 16px rgba(255, 77, 77, .8); border: 2.5px solid #2a0a0a;\n  }\n  .elora-how__fail figcaption {\n    font-size: clamp(14px, 3.7vw, 17px); font-weight: 700; color: #9aa8c0;\n    text-decoration: line-through; text-decoration-color: rgba(255, 100, 100, .8);\n  }\n\n  /* ===== שעון משימה ===== */\n  .elora-how__hours {\n    display: inline-flex; align-items: center; gap: 14px; margin-top: 2px;\n    padding: 12px 22px; border-radius: 18px;\n    background: rgba(8, 20, 14, .6);\n    -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);\n    border: 1px solid rgba(111, 232, 154, .4);\n    box-shadow: 0 0 26px rgba(111, 232, 154, .18);\n  }\n  .elora-how__hours-clock { width: clamp(42px, 11vw, 54px); height: clamp(42px, 11vw, 54px); flex: none; }\n  .elora-how__hours-clock svg { width: 100%; height: 100%; display: block; }\n  .elora-how__sweep { transform-origin: 24px 24px; animation: elora-sweep 8s linear infinite; }\n  @keyframes elora-sweep { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }\n  .elora-how__hours-txt { display: flex; flex-direction: column; align-items: flex-start; }\n  .elora-how__hours-num {\n    font-size: clamp(28px, 7.6vw, 44px); font-weight: 900; line-height: 1.05;\n    color: var(--how-green); letter-spacing: -0.02em;\n    text-shadow: 0 0 20px rgba(111, 232, 154, .55);\n  }\n  .elora-how__hours-sub { font-size: clamp(12px, 3.2vw, 15px); font-weight: 700; color: #9fd4ae; }\n\n  /* מסכים נמוכים */\n  @media (max-height: 660px) {\n    .elora-how__media img { max-height: 26vh; }\n    .elora-how__media--failed img { max-height: 20vh; }\n    .elora-how__content { gap: 9px; padding: 18px 24px; }\n    .elora-how__stage { gap: 9px; }\n    .elora-how__fail-ic { width: clamp(78px, 22vw, 100px); height: clamp(78px, 22vw, 100px); }\n  }\n\n  /* ===== Fallback — ללא JS / תנועה מופחתת ===== */\n  .elora-how:not(.is-enhanced) .elora-how__scroller { height: auto; }\n  .elora-how:not(.is-enhanced) .elora-how__sticky { position: static; height: auto; overflow: visible; padding: 48px 0; }\n  .elora-how:not(.is-enhanced) .elora-how__stars { display: none; }\n  .elora-how:not(.is-enhanced) .elora-how__bg-layer[data-layer=\"0\"] { opacity: 1; }\n  .elora-how:not(.is-enhanced) .elora-how__dots { display: none; }\n  .elora-how:not(.is-enhanced) .elora-how__rocket { display: none; }\n  .elora-how:not(.is-enhanced) .elora-how__stages { display: block; }\n  .elora-how:not(.is-enhanced) .elora-how__stage { opacity: 1; margin-bottom: 46px; }\n  .elora-how:not(.is-enhanced) .elora-how__stage:last-child { margin-bottom: 0; }\n  .elora-how:not(.is-enhanced) .elora-how__media img { max-height: none; }\n  @media (prefers-reduced-motion: reduce) {\n    .elora-how__mosq, .elora-how__deflect, .elora-how__deflect b,\n    .elora-how__wing, .elora-how__sweep, .elora-how__kicker i,\n    .elora-how__planet, .elora-how__rocket, .elora-how__flame,\n    .elora-how__tag, .elora-how__fail, .elora-how__shield-badge,\n    .elora-how__media--shield::before, .elora-how__media--shield::after { animation: none; }\n  }\n</style>\n\n<script>\n  (function () {\n    var sections = document.querySelectorAll('.elora-how');\n    Array.prototype.forEach.call(sections, initHow);\n\n    function initHow(section) {\n      if (section.dataset.eloraInit) return;\n      section.dataset.eloraInit = '1';\n\n      var scroller = section.querySelector('.elora-how__scroller');\n      var sticky   = section.querySelector('.elora-how__sticky');\n      var canvas   = section.querySelector('.elora-how__stars');\n      var stages = [].slice.call(section.querySelectorAll('.elora-how__stage'));\n      var layers = [].slice.call(section.querySelectorAll('.elora-how__bg-layer'));\n      var dots   = [].slice.call(section.querySelectorAll('.elora-how__dot'));\n      var N = stages.length;\n      if (!N || !scroller || !sticky) return;\n\n      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n      if (reduce) return;\n\n      section.classList.add('is-enhanced');\n\n      function clamp(v, a, b) { return Math.min(b, Math.max(a, v)); }\n\n      var warpTarget = 0;\n      var ticking = false;\n\n      function update() {\n        ticking = false;\n        var rect = scroller.getBoundingClientRect();\n        var stickyH = sticky.offsetHeight;\n        var topOff = parseFloat(window.getComputedStyle(sticky).top) || 0;\n        var dist = scroller.offsetHeight - stickyH;\n        if (dist <= 0) dist = 1;\n        var p = clamp((topOff - rect.top) / dist, 0, 1);\n        var scaled = p * N;\n\n        for (var i = 0; i < N; i++) {\n          var center = i + 0.5;\n          var d = Math.abs(scaled - center);\n\n          var o = clamp(1 - d / 0.5, 0, 1);\n          if (i === 0 && scaled < center) o = 1;\n          if (i === N - 1 && scaled > center) o = 1;\n          var ty = (scaled - center) * -30;\n          stages[i].style.opacity = o;\n          stages[i].style.transform = 'translateY(' + ty + 'px) scale(' + (0.96 + 0.04 * o) + ')';\n          stages[i].style.pointerEvents = o > 0.5 ? 'auto' : 'none';\n          stages[i].style.zIndex = o > 0.5 ? 2 : 1;\n\n          var lo = clamp(1 - d / 0.95, 0, 1);\n          if (i === 0 && scaled < center) lo = 1;\n          if (i === N - 1 && scaled > center) lo = 1;\n          layers[i].style.opacity = lo;\n        }\n\n        var w = 0;\n        for (var b = 1; b < N; b++) {\n          var dd = scaled - b;\n          w = Math.max(w, Math.exp(-(dd * dd) / 0.022));\n        }\n        warpTarget = (p <= 0 || p >= 1) ? 0 : w;\n\n        var active = clamp(Math.floor(scaled), 0, N - 1);\n        for (var k = 0; k < dots.length; k++) dots[k].classList.toggle('is-active', k === active);\n      }\n\n      function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }\n      window.addEventListener('scroll', onScroll, { passive: true });\n      window.addEventListener('resize', function () { onScroll(); sizeCanvas(); });\n      update();\n\n      /* ===== שדה כוכבים + ניצוצות פסטל + היילספייס ===== */\n      if (!canvas || !canvas.getContext) return;\n      var ctx = canvas.getContext('2d');\n      var stars = [], W = 0, H = 0, cx = 0, cy = 0, maxR = 1;\n      var warp = 0, running = false, inView = false;\n      var palette = ['215,228,255', '255,224,160', '255,190,220', '180,240,200'];\n\n      function sizeCanvas() {\n        var dpr = Math.min(window.devicePixelRatio || 1, 2);\n        W = sticky.clientWidth; H = sticky.clientHeight;\n        canvas.width = W * dpr; canvas.height = H * dpr;\n        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n        cx = W / 2; cy = H / 2;\n        maxR = Math.sqrt(cx * cx + cy * cy);\n        var count = clamp(Math.round(W * H / 8500), 60, 170);\n        stars = [];\n        for (var i = 0; i < count; i++) stars.push(newStar(true));\n      }\n\n      function newStar(anywhere) {\n        var sparkle = Math.random() < 0.16;\n        return {\n          a: Math.random() * Math.PI * 2,\n          r: anywhere ? Math.random() : 0.04 + Math.random() * 0.12,\n          sp: 0.0004 + Math.random() * 0.0012,\n          sz: sparkle ? 1.1 + Math.random() * 1.3 : 0.5 + Math.random() * 1.5,\n          tw: Math.random() * Math.PI * 2,\n          c: sparkle ? palette[1 + Math.floor(Math.random() * 3)] : palette[0],\n          k: sparkle\n        };\n      }\n\n      function frame() {\n        if (!running) return;\n        warp += (warpTarget - warp) * 0.09;\n        ctx.clearRect(0, 0, W, H);\n\n        for (var i = 0; i < stars.length; i++) {\n          var s = stars[i];\n          var speed = s.sp * (1 + warp * 30);\n          s.r += speed;\n          s.tw += 0.045;\n          if (s.r > 1.05) { stars[i] = newStar(false); continue; }\n\n          var x = cx + Math.cos(s.a) * s.r * maxR;\n          var y = cy + Math.sin(s.a) * s.r * maxR;\n          var alpha = (0.3 + 0.7 * Math.abs(Math.sin(s.tw))) * Math.min(1, s.r * 5 + 0.15);\n\n          if (warp > 0.06) {\n            var r0 = Math.max(0.01, s.r - speed * 9 - warp * 0.055 * s.r);\n            var x0 = cx + Math.cos(s.a) * r0 * maxR;\n            var y0 = cy + Math.sin(s.a) * r0 * maxR;\n            ctx.strokeStyle = 'rgba(' + s.c + ',' + (alpha * (0.5 + warp * 0.5)) + ')';\n            ctx.lineWidth = s.sz;\n            ctx.beginPath(); ctx.moveTo(x0, y0); ctx.lineTo(x, y); ctx.stroke();\n          } else if (s.k) {\n            /* ניצוץ פסטל בצורת + */\n            var L = s.sz * 3.2;\n            ctx.strokeStyle = 'rgba(' + s.c + ',' + alpha + ')';\n            ctx.lineWidth = 1.2;\n            ctx.beginPath();\n            ctx.moveTo(x - L, y); ctx.lineTo(x + L, y);\n            ctx.moveTo(x, y - L); ctx.lineTo(x, y + L);\n            ctx.stroke();\n          } else {\n            ctx.fillStyle = 'rgba(' + s.c + ',' + alpha + ')';\n            ctx.beginPath(); ctx.arc(x, y, s.sz, 0, 6.2832); ctx.fill();\n          }\n        }\n        requestAnimationFrame(frame);\n      }\n\n      function setRunning(v) {\n        v = v && inView && !document.hidden;\n        if (v === running) return;\n        running = v;\n        if (running) requestAnimationFrame(frame);\n      }\n\n      sizeCanvas();\n\n      if ('IntersectionObserver' in window) {\n        var io = new IntersectionObserver(function (entries) {\n          inView = entries[0].isIntersecting;\n          setRunning(true);\n        }, { rootMargin: '120px' });\n        io.observe(section);\n      } else {\n        inView = true; setRunning(true);\n      }\n      document.addEventListener('visibilitychange', function () { setRunning(true); });\n    }\n  })();\n</script>",
