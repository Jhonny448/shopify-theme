      }
    },
    "custom_liquid_b69CaY": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-cmp{background:#fff;padding:76px 20px;direction:rtl;font-family:'Assistant','Heebo',sans-serif}\n.elx-cmp *{box-sizing:border-box}\n.elx-cmp__head{text-align:center;max-width:700px;margin:0 auto 46px}\n.elx-cmp__head h2{font-size:clamp(28px,5vw,42px);font-weight:800;color:#122a6b;margin:0 0 12px;line-height:1.25}\n.elx-cmp__head p{font-size:clamp(16px,2.2vw,18px);color:#5a6b96;margin:0}\n.elx-cmp__grid{max-width:820px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:20px}\n.elx-cmp__col{border-radius:24px;padding:30px 26px}\n.elx-cmp__col.old{background:#f6f7fb;border:1px solid #e6e2e2}\n.elx-cmp__col.new{background:linear-gradient(160deg,#2a5fe0,#1f4fc9);color:#fff;box-shadow:0 18px 44px rgba(31,79,201,.32);position:relative}\n.elx-cmp__tag{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:#ffd23f;color:#122a6b;font-weight:800;font-size:13px;padding:5px 16px;border-radius:100px;white-space:nowrap}\n.elx-cmp__col h3{font-size:20px;font-weight:800;margin:0 0 20px;text-align:center}\n.elx-cmp__col.old h3{color:#9aa0b0}\n.elx-cmp__col.new h3{color:#fff}\n.elx-cmp__li{display:flex;align-items:flex-start;gap:11px;font-size:15px;line-height:1.5;margin-bottom:15px}\n.elx-cmp__col.old .elx-cmp__li{color:#7a808f}\n.elx-cmp__col.new .elx-cmp__li{color:#e8eeff}\n.elx-cmp__ic{flex:0 0 22px;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;margin-top:1px}\n.old .elx-cmp__ic{background:#eceef4;color:#a3a9b8}\n.new .elx-cmp__ic{background:rgba(255,255,255,.2);color:#fff}\n@media(max-width:640px){.elx-cmp__grid{grid-template-columns:1fr;gap:26px}}\n</style>\n<section class=\"elx-cmp\">\n  <div class=\"elx-cmp__head\">\n    <h2>למה הורים עוברים לאלורה</h2>\n    <p>ההבדל בין להגן על הילד, לבין להגן על העור שלו.</p>\n  </div>\n  <div class=\"elx-cmp__grid\">\n    <div class=\"elx-cmp__col old\">\n      <h3>קרמים ותרסיסים רגילים</h3>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✕</div><div>נמרחים ישירות על עור הילד</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✕</div><div>מכילים כימיקלים שקשה לזהות</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✕</div><div>מתפוגגים מהר וצריך למרוח שוב</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✕</div><div>ריח חזק ותחושה דביקה על העור</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✕</div><div>לא תמיד מתאימים לתינוקות</div></div>\n    </div>\n    <div class=\"elx-cmp__col new\">\n      <div class=\"elx-cmp__tag\">★ הבחירה של ההורים</div>\n      <h3>מדבקות אלורה</h3>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✓</div><div>נדבקות על הבגד, לא נוגעות בעור</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✓</div><div>ציטרונלה טבעית 100%, ללא כימיקלים</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✓</div><div>הגנה יציבה עד 8 שעות רצופות</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✓</div><div>בלי מגע דביק, בלי ריח חריף</div></div>\n      <div class=\"elx-cmp__li\"><div class=\"elx-cmp__ic\">✓</div><div>מתאימות מגיל 0, גם לתינוקות</div></div>\n    </div>\n  </div>\n</section>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_iLDwta": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-rev{position:relative;background:linear-gradient(180deg,#1f4fc9 0%,#1740a8 100%);padding:78px 20px 90px;direction:rtl;font-family:'Assistant','Heebo',sans-serif;overflow:hidden}\n.elx-rev *{box-sizing:border-box}\n.elx-rev__head{position:relative;z-index:2;text-align:center;max-width:680px;margin:0 auto 44px}\n.elx-rev__stars{color:#ffd23f;font-size:26px;letter-spacing:2px;margin-bottom:12px}\n.elx-rev__head h2{font-size:clamp(26px,4.6vw,42px);font-weight:800;color:#fff;margin:0 0 10px;line-height:1.3}\n.elx-rev__head p{font-size:clamp(15px,2.2vw,18px);color:#cfdcff;margin:0}\n.elx-rev__grid{position:relative;z-index:2;max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:18px}\n.elx-rev__card{background:#fff;border-radius:22px;padding:26px 24px;box-shadow:0 18px 44px rgba(10,30,90,.28);display:flex;flex-direction:column;transition:transform .3s}\n.elx-rev__card:hover{transform:translateY(-8px)}\n.elx-rev__s{color:#f4b400;font-size:16px;letter-spacing:1px;margin-bottom:12px}\n.elx-rev__q{font-size:16px;line-height:1.65;color:#1c2b52;margin:0 0 18px;flex:1;font-weight:500}\n.elx-rev__who{display:flex;align-items:center;gap:12px}\n.elx-rev__av{width:46px;height:46px;border-radius:50%;background:linear-gradient(135deg,#4f7cff,#1f4fc9);color:#fff;font-weight:800;display:flex;align-items:center;justify-content:center;font-size:18px}\n.elx-rev__nm{font-weight:800;color:#122a6b;font-size:15px;line-height:1.2}\n.elx-rev__nm small{display:block;color:#7385b5;font-weight:600;font-size:12px;margin-top:2px}\n.elx-rev__badge{position:relative;z-index:2;text-align:center;margin-top:36px}\n.elx-rev__badge span{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.25);color:#fff;font-weight:700;font-size:14px;padding:10px 20px;border-radius:100px}\n.elx-rev__bub{position:absolute;border-radius:50%;background:rgba(255,255,255,.06);z-index:1}\n.elx-rev__bub.b1{width:180px;height:180px;top:-40px;right:-40px}\n.elx-rev__bub.b2{width:120px;height:120px;bottom:20px;left:-30px}\n@media(max-width:820px){.elx-rev__grid{grid-template-columns:1fr}}\n</style>\n<section class=\"elx-rev\">\n  <span class=\"elx-rev__bub b1\"></span>\n  <span class=\"elx-rev__bub b2\"></span>\n  <div class=\"elx-rev__head\">\n    <div class=\"elx-rev__stars\">★★★★★</div>\n    <h2>אלפי הורים כבר עברו למדבקות שלנו</h2>\n    <p>הקיץ הזה כבר נראה אחרת בבית שלהם. הנה מה שהם מספרים.</p>\n  </div>\n  <div class=\"elx-rev__grid\">\n    <div class=\"elx-rev__card\">\n      <div class=\"elx-rev__s\">★★★★★</div>\n      <p class=\"elx-rev__q\">\"סוף סוף משהו שאני מרגישה בנוח לשים על התינוקת. מדביקה על הבגד בבוקר ולא חושבת על זה יותר. חזרנו מהפארק בלי אף עקיצה.\"</p>\n      <div class=\"elx-rev__who\"><div class=\"elx-rev__av\">ש</div><div class=\"elx-rev__nm\">שירה כהן<small>אמא לרוני, בת 8 חודשים</small></div></div>\n    </div>\n    <div class=\"elx-rev__card\">\n      <div class=\"elx-rev__s\">★★★★★</div>\n      <p class=\"elx-rev__q\">\"ניסינו הכל, קרמים, תרסיסים, נרות. זה הדבר היחיד שבאמת עבד. הילדים אפילו אוהבים לבחור איזו דמות להדביק. פשוט גאוני.\"</p>\n      <div class=\"elx-rev__who\"><div class=\"elx-rev__av\">י</div><div class=\"elx-rev__nm\">יעל לוי<small>אמא ל־3</small></div></div>\n    </div>\n    <div class=\"elx-rev__card\">\n      <div class=\"elx-rev__s\">★★★★★</div>\n      <p class=\"elx-rev__q\">\"מה שמכר אותי זה שאין מגע עם העור. בלי ריח כימי, בלי דביקות. מדביק בבוקר לפני הגן ויודע שהוא מוגן כל היום. ממליץ בחום.\"</p>\n      <div class=\"elx-rev__who\"><div class=\"elx-rev__av\">א</div><div class=\"elx-rev__nm\">אורי מזרחי<small>אבא לתאומים</small></div></div>\n    </div>\n  </div>\n  <div class=\"elx-rev__badge\"><span>💙 מדורג 4.9 מתוך 5 על ידי הורים בכל הארץ</span></div>\n</section>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_Cp64PX": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-faq{background:#f4f7ff;padding:74px 20px;direction:rtl;font-family:'Assistant','Heebo',sans-serif}\n.elx-faq *{box-sizing:border-box}\n.elx-faq__head{text-align:center;max-width:640px;margin:0 auto 40px}\n.elx-faq__head h2{font-size:clamp(28px,5vw,42px);font-weight:800;color:#122a6b;margin:0 0 10px}\n.elx-faq__head p{font-size:clamp(15px,2.2vw,18px);color:#5a6b96;margin:0}\n.elx-faq__list{max-width:720px;margin:0 auto}\n.elx-faq__item{border:1px solid #d9e2ff;border-radius:16px;margin-bottom:14px;overflow:hidden;background:#fff;transition:box-shadow .25s}\n.elx-faq__item[open]{box-shadow:0 12px 30px rgba(31,79,201,.12)}\n.elx-faq__q{list-style:none;cursor:pointer;padding:20px 24px;font-size:clamp(16px,2.4vw,19px);font-weight:800;color:#122a6b;display:flex;justify-content:space-between;align-items:center;gap:16px}\n.elx-faq__q::-webkit-details-marker{display:none}\n.elx-faq__q .plus{flex:0 0 26px;width:26px;height:26px;border-radius:50%;background:#e4ebff;color:#1f4fc9;font-size:18px;display:flex;align-items:center;justify-content:center;transition:transform .25s,background .25s,color .25s}\n.elx-faq__item[open] .plus{transform:rotate(45deg);background:#1f4fc9;color:#fff}\n.elx-faq__a{padding:0 24px 22px;color:#4a5b86;font-size:clamp(15px,2vw,17px);line-height:1.7}\n</style>\n<section class=\"elx-faq\">\n  <div class=\"elx-faq__head\">\n    <h2>שאלות שהורים שואלים</h2>\n    <p>כל מה שרציתם לדעת לפני שאתם מגנים על הילד בצורה חכמה.</p>\n  </div>\n  <div class=\"elx-faq__list\">\n    <details class=\"elx-faq__item\" open>\n      <summary class=\"elx-faq__q\">האם זה בטוח לתינוקות?<span class=\"plus\">+</span></summary>\n      <div class=\"elx-faq__a\">כן. המדבקות מבוססות על ציטרונלה טבעית בלבד עם סרט דבק בדרגה רפואית, ומתאימות מגיל 0. הן נדבקות על הבגד ולא נוגעות בעור של הילד כלל.</div>\n    </details>\n    <details class=\"elx-faq__item\">\n      <summary class=\"elx-faq__q\">כמה זמן ההגנה מחזיקה?<span class=\"plus\">+</span></summary>\n      <div class=\"elx-faq__a\">כל מדבקה מגנה עד 8 שעות רצופות. פשוט מדביקים בבוקר לפני היציאה, ומחליפים לאחר 8 שעות במידת הצורך.</div>\n    </details>\n    <details class=\"elx-faq__item\">\n      <summary class=\"elx-faq__q\">כמה מדבקות צריך לשים?<span class=\"plus\">+</span></summary>\n      <div class=\"elx-faq__a\">תלוי בגיל: גיל 0 עד 2 מדבקה אחת על הגב. גיל 3 עד 5 שתי מדבקות. גיל 6 ומעלה עד 4 מדבקות. מפזרים על הבגדים לכיסוי מיטבי.</div>\n    </details>\n    <details class=\"elx-faq__item\">\n      <summary class=\"elx-faq__q\">איך זה עובד בכלל בלי לגעת בעור?<span class=\"plus\">+</span></summary>\n      <div class=\"elx-faq__a\">יתושים מנווטים לפי ריח. הציטרונלה שעל הבגד יוצרת בועת הגנה ריחנית שמסתירה את הילד מהיתושים, כך שהם פשוט לא מזהים אותו, בלי שום מגע עם העור.</div>\n    </details>\n    <details class=\"elx-faq__item\">\n      <summary class=\"elx-faq__q\">האם המדבקה משאירה סימנים על הבגד?<span class=\"plus\">+</span></summary>\n      <div class=\"elx-faq__a\">לא. המדבקות מתקלפות בקלות ולא משאירות שאריות דבק על הבגד. הן עמידות לאורך היום אך פשוטות להסרה בסוף.</div>\n    </details>\n  </div>\n</section>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_wyCemC": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-cta{position:relative;overflow:hidden;background:linear-gradient(150deg,#2a5fe0 0%,#122a6b 100%);padding:80px 20px;direction:rtl;font-family:'Assistant','Heebo',sans-serif;text-align:center}\n.elx-cta *{box-sizing:border-box}\n.elx-cta__in{position:relative;z-index:2;max-width:720px;margin:0 auto}\n.elx-cta h2{font-size:clamp(28px,5.5vw,46px);font-weight:800;color:#ffffff;margin:0 0 16px;line-height:1.25}\n.elx-cta p{font-size:clamp(16px,2.4vw,20px);color:#d5e0ff;line-height:1.65;margin:0}\n.elx-cta__badges{display:flex;flex-wrap:wrap;justify-content:center;gap:14px;margin-top:40px}\n.elx-cta__badge{display:flex;flex-direction:column;align-items:center;gap:6px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.18);border-radius:18px;padding:20px 14px;flex:1 1 130px;max-width:170px}\n.elx-cta__badge .bi{font-size:30px}\n.elx-cta__badge strong{font-size:15px;font-weight:800;color:#ffffff}\n.elx-cta__badge span{font-size:12.5px;color:#c3d1f7}\n.elx-cta__bub{position:absolute;border-radius:50%;background:rgba(255,255,255,0.07);z-index:1}\n.elx-cta__bub.b1{width:220px;height:220px;top:-60px;left:-50px}\n.elx-cta__bub.b2{width:160px;height:160px;bottom:-50px;right:-40px}\n</style>\n<section class=\"elx-cta\">\n  <span class=\"elx-cta__bub b1\"></span>\n  <span class=\"elx-cta__bub b2\"></span>\n  <div class=\"elx-cta__in\">\n    <h2>הקיץ הזה, הילד שלך מוגן. בלי לשים עליו כלום.</h2>\n    <p>הצטרפו לאלפי ההורים שכבר גילו את הדרך החכמה, הטבעית והבטוחה להגן על הילדים מיתושים.</p>\n    <div class=\"elx-cta__badges\">\n      <div class=\"elx-cta__badge\"><div class=\"bi\">🌿</div><strong>100% טבעי</strong><span>ציטרונלה בלבד</span></div>\n      <div class=\"elx-cta__badge\"><div class=\"bi\">👶</div><strong>מגיל 0</strong><span>גם לתינוקות</span></div>\n      <div class=\"elx-cta__badge\"><div class=\"bi\">⏱️</div><strong>עד 8 שעות</strong><span>הגנה רצופה</span></div>\n      <div class=\"elx-cta__badge\"><div class=\"bi\"