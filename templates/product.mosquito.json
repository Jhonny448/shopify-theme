    "custom_liquid_PCrBgL": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-prob{position:relative;background:#122a6b;color:#e7edff;padding:100px 20px 130px;direction:rtl;font-family:'Assistant','Heebo',sans-serif;text-align:center;overflow:hidden}\n.elx-prob *{box-sizing:border-box}\n.elx-prob__top{position:absolute;top:-1px;left:0;width:100%;line-height:0;z-index:2}\n.elx-prob__in{position:relative;z-index:3;max-width:900px;margin:0 auto}\n.elx-prob .eyebrow{color:#8fb0ff;font-weight:800;font-size:17px;letter-spacing:.5px;margin:0 0 14px}\n.elx-prob h2{font-size:40px;line-height:1.25;font-weight:900;color:#fff;margin:0 0 24px}\n.elx-prob .lead{font-size:20px;line-height:1.7;color:#c5d3ff;max-width:680px;margin:0 auto 18px}\n.elx-prob .strong{font-size:22px;font-weight:800;color:#fff;max-width:720px;margin:0 auto 46px}\n.elx-prob .strong b{color:#ffd23f}\n.elx-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;max-width:900px;margin:0 auto}\n.elx-cardp{background:rgba(255,255,255,.06);border:1px solid rgba(143,176,255,.25);border-radius:22px;padding:34px 22px 28px;text-align:center;opacity:0;transform:translateY(30px);transition:opacity .6s ease,transform .6s ease}\n.elx-cardp.in{opacity:1;transform:none}\n.elx-cardp:nth-child(2){transition-delay:.15s}\n.elx-cardp:nth-child(3){transition-delay:.3s}\n.elx-cardp .ic{width:74px;height:74px;margin:0 auto 18px;animation:elxBob 3.5s ease-in-out infinite}\n.elx-cardp:nth-child(2) .ic{animation-delay:.5s}\n.elx-cardp:nth-child(3) .ic{animation-delay:1s}\n@keyframes elxBob{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}\n.elx-cardp h3{font-size:20px;font-weight:800;color:#fff;margin:0 0 8px}\n.elx-cardp p{font-size:15px;line-height:1.55;color:#b9c8f5;margin:0}\n.elx-star{position:absolute;color:#ffd23f;opacity:.7;font-size:20px;animation:elxTw 3s ease-in-out infinite;z-index:1}\n@keyframes elxTw{0%,100%{opacity:.2;transform:scale(.7)}50%{opacity:.9;transform:scale(1.15)}}\n.elx-prob__wave{position:absolute;bottom:-1px;left:0;width:100%;line-height:0;z-index:2}\n@media(max-width:768px){.elx-prob h2{font-size:28px}.elx-cards{grid-template-columns:1fr}.elx-prob .lead{font-size:17px}.elx-prob .strong{font-size:18px}}\n</style>\n<section class=\"elx-prob\">\n  <div class=\"elx-prob__top\">\n    <svg viewBox=\"0 0 1440 90\" preserveAspectRatio=\"none\" style=\"width:100%;height:70px;display:block\"><path fill=\"#122a6b\" d=\"M0,45 C240,10 480,80 720,50 C960,20 1200,70 1440,40 L1440,0 L0,0 Z\"></path></svg>\n  </div>\n  <span class=\"elx-star\" style=\"top:12%;right:8%\">&#10022;</span>\n  <span class=\"elx-star\" style=\"top:22%;left:10%;animation-delay:1s\">&#10022;</span>\n  <span class=\"elx-star\" style=\"top:60%;right:5%;animation-delay:.6s\">&#10022;</span>\n  <span class=\"elx-star\" style=\"top:70%;left:6%;animation-delay:1.4s\">&#10022;</span>\n  <div class=\"elx-prob__in\">\n    <p class=\"eyebrow\">מוכר לך?</p>\n    <h2>כל קיץ אותו סיפור. יתושים, עקיצות, ילד שמגרד, ואתם מחפשים פתרון שסוף סוף יעבוד</h2>\n    <p class=\"lead\">מרחתם קרם, ריססתם תרסיס, ועדיין הילד חזר הביתה עם עקיצות. שמתם על הגוף שלו משהו שלא הייתם בטוחים לגביו, ובסוף גם זה לא עזר.</p>\n    <p class=\"strong\">רוב ההורים לא יודעים שיש פתרון שעובד, <b>בלי למרוח או לרסס כלום על העור של הילד.</b></p>\n    <div class=\"elx-cards\">\n      <div class=\"elx-cardp\">\n        <svg class=\"ic\" viewBox=\"0 0 64 64\" fill=\"none\"><circle cx=\"32\" cy=\"32\" r=\"26\" fill=\"#ffd23f\" stroke=\"#122a6b\" stroke-width=\"3\"/><circle cx=\"23\" cy=\"27\" r=\"3.5\" fill=\"#122a6b\"/><circle cx=\"41\" cy=\"27\" r=\"3.5\" fill=\"#122a6b\"/><path d=\"M22 44 C26 38 38 38 42 44\" stroke=\"#122a6b\" stroke-width=\"3.5\" fill=\"none\" stroke-linecap=\"round\"/><path d=\"M18 20 L28 24 M46 20 L36 24\" stroke=\"#122a6b\" stroke-width=\"3\" stroke-linecap=\"round\"/></svg>\n        <h3>אי נוחות להורים</h3>\n        <p>לשים על העור של הילד משהו שאתם לא בטוחים לגביו</p>\n      </div>\n      <div class=\"elx-cardp\">\n        <svg class=\"ic\" viewBox=\"0 0 64 64\" fill=\"none\"><ellipse cx=\"32\" cy=\"36\" rx=\"7\" ry=\"13\" fill=\"#7dd3fc\" stroke=\"#122a6b\" stroke-width=\"3\"/><circle cx=\"32\" cy=\"20\" r=\"7\" fill=\"#e7edff\" stroke=\"#122a6b\" stroke-width=\"3\"/><path d=\"M32 27 L32 49\" stroke=\"#122a6b\" stroke-width=\"2.5\"/><path d=\"M14 22 C20 24 26 26 30 30 M50 22 C44 24 38 26 34 30\" stroke=\"#122a6b\" stroke-width=\"2.5\" fill=\"none\" stroke-linecap=\"round\"/><path d=\"M20 44 L28 40 M44 44 L36 40\" stroke=\"#122a6b\" stroke-width=\"2.5\" stroke-linecap=\"round\"/></svg>\n        <h3>עקיצות למרות הכל</h3>\n        <p>הילד חזר הביתה מגורד וההגנה פשוט לא החזיקה</p>\n      </div>\n      <div class=\"elx-cardp\">\n        <svg class=\"ic\" viewBox=\"0 0 64 64\" fill=\"none\"><rect x=\"21\" y=\"24\" width=\"22\" height=\"30\" rx=\"6\" fill=\"#f4a8c0\" stroke=\"#122a6b\" stroke-width=\"3\"/><rect x=\"26\" y=\"14\" width=\"12\" height=\"10\" rx=\"2\" fill=\"#e7edff\" stroke=\"#122a6b\" stroke-width=\"3\"/><rect x=\"24\" y=\"32\" width=\"16\" height=\"10\" rx=\"2\" fill=\"#fff\" stroke=\"#122a6b\" stroke-width=\"2.5\"/></svg>\n        <h3>קרמים ותרסיסים</h3>\n        <p>נמרחים ישירות על העור, מתפוגגים מהר וצריך למרוח שוב ושוב</p>\n      </div>\n    </div>\n  </div>\n  <div class=\"elx-prob__wave\">\n    <svg viewBox=\"0 0 1440 110\" preserveAspectRatio=\"none\" style=\"width:100%;height:90px;display:block\"><path fill=\"#eaf0ff\" d=\"M0,55 C240,105 480,15 720,50 C960,85 1200,20 1440,60 L1440,110 L0,110 Z\"></path></svg>\n  </div>\n</section>\n<script>\n(function(){var els=document.querySelectorAll('.elx-cardp');if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('in')});return;}var o=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting)x.target.classList.add('in')})},{threshold:.2});els.forEach(function(e){o.observe(e)});})();\n</script>",
