        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "padding_top": 8,
        "padding_bottom": 28
      }
    },
    "custom_liquid_YehYnw": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  ELORA – סקשן טיעון (reframe) — בא אחרי סקשן הווידאו\n  * גרסה עם הכותרת הראשית למעלה (עברה לכאן מסקשן הווידאו)\n  ------------------------------------------------------------\n  חשוב לחיבור ה\"פאזל\":\n  • בהגדרות הבלוק הזה: Padding → Top = 0\n  • בהגדרות הבלוק הקודם (הווידאו): Padding → Bottom = 0\n  ============================================================\n{%- endcomment -%}\n<section class=\"elora-arg\" dir=\"rtl\">\n  {%- comment -%} שוליים מסולסלים – מוסטים בחצי צעד כדי להשתלב בסקשן הקודם {%- endcomment -%}\n  <span class=\"elora-arg__edge elora-arg__edge--top\" aria-hidden=\"true\"></span>\n  <div class=\"elora-arg__inner\">\n\n    {%- comment -%} ===== הכותרת הראשית (עברה מסקשן הווידאו) ===== {%- endcomment -%}\n    <h2 class=\"elora-arg__title\" data-reveal>\n      הדרך הכי יעילה להגן על הילד שלך מיתושים…\n      <br>\n      היא לא לשים <span class=\"elora-arg__hl\">שום דבר על העור שלו</span>.\n    </h2>\n\n    <p class=\"elora-arg__p\" data-reveal>\n      כן, זה נשמע קצת מוזר  כי זה נוגד את מה <span class=\"elora-arg__b\">שאנחנו מכירים</span>.\n    </p>\n    <p class=\"elora-arg__p\" data-reveal>\n      אבל רוב ההורים לא יודעים שיש פתרון שעובד\n      <span class=\"elora-arg__mark\">בלי למרוח או לרסס כלום</span>\n      על <span class=\"elora-arg__b\">העור של הילד</span>.\n    </p>\n    <p class=\"elora-arg__p\" data-reveal>\n      אומרים שהתרסיסים האלה בטוחים. אולי זה נכון.\n    </p>\n    <p class=\"elora-arg__headline\" data-reveal>\n      אבל כשמדובר <strong>בילד שלך</strong>\n      למה בכלל לקחת סיכון,<br> אם יש פתרון שעובד בלי לשים\n      <span class=\"elora-arg__hl\">שום דבר על העור שלו</span>?\n    </p>\n  </div>\n  <span class=\"elora-arg__edge elora-arg__edge--bottom\" aria-hidden=\"true\"></span>\n</section>\n<style>\n  .elora-arg {\n    --arg-accent: #2f5fd6;\n    --arg-text: #1c2430;\n    --arg-bg: #ffffff;          /* רקע לבן */\n    --arg-edge: #ffffff;        /* צבע הרקע של הדף / הסקשן הקודם */\n    position: relative;\n    font-family: inherit;\n    color: var(--arg-text);\n    background: var(--arg-bg);\n    padding: 54px 0 58px;\n    overflow: hidden;\n    isolation: isolate;\n  }\n  .elora-arg *,\n  .elora-arg *::before,\n  .elora-arg *::after { box-sizing: border-box; }\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .elora-arg__edge {\n    position: absolute;\n    left: 0;\n    width: 100%;\n    height: 22px;\n    z-index: 2;\n    background: var(--arg-edge);\n    pointer-events: none;\n  }\n  /* למעלה: מוסט ב-22px כדי להשתלב בשוליים התחתונים של סקשן הווידאו */\n  .elora-arg__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  /* למטה: אותה שפה מסולסלת להמשכיות עם מה שיבוא אחרי */\n  .elora-arg__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n  /* ===== תוכן ===== */\n  .elora-arg__inner {\n    position: relative;\n    z-index: 1;\n    max-width: 620px;\n    margin: 0 auto;\n    padding: 0 22px;\n    text-align: center;\n  }\n\n  /* ===== הכותרת הראשית ===== */\n  .elora-arg__title {\n    margin: 0 auto 30px;\n    max-width: 600px;\n    font-size: clamp(23px, 5.6vw, 34px);\n    line-height: 1.35;\n    font-weight: 800;\n    letter-spacing: -0.2px;\n    color: var(--arg-text);\n  }\n\n  .elora-arg__p {\n    font-size: clamp(18px, 4.4vw, 23px);\n    line-height: 1.75;\n    font-weight: 500;\n    margin: 0 0 18px;\n    color: #33404f;\n  }\n  .elora-arg__p:last-of-type { margin-bottom: 24px; }\n  /* הדגשה פשוטה (בולד) */\n  .elora-arg__b { font-weight: 800; color: inherit; }\n  /* הדגשת מרקר רכה */\n  .elora-arg__mark {\n    font-weight: 800;\n    color: var(--arg-accent);\n    background: linear-gradient(180deg, transparent 62%, rgba(47, 95, 214, .16) 62%);\n    padding: 0 3px;\n    border-radius: 3px;\n    white-space: nowrap;\n  }\n  /* ===== כותרת שאלת הסיכון (במקום הבועה) ===== */\n  .elora-arg__headline {\n    margin: 26px auto 0;\n    max-width: 560px;\n    font-size: clamp(21px, 5.2vw, 28px);\n    line-height: 1.5;\n    font-weight: 800;\n    color: var(--arg-text);\n  }\n  .elora-arg__headline strong { color: var(--arg-accent); }\n  /* קריאה חוזרת לכותרת של הסקשן הקודם – שני פסים */\n  .elora-arg__hl {\n    position: relative;\n    white-space: nowrap;\n    padding-bottom: 2px;\n  }\n  .elora-arg__hl::after {\n    content: \"\";\n    position: absolute;\n    right: 0; left: 0; bottom: -5px;\n    height: 7px;\n    background:\n      linear-gradient(var(--arg-accent), var(--arg-accent)) top/100% 2.5px no-repeat,\n      linear-gradient(var(--arg-accent), var(--arg-accent)) bottom/100% 2.5px no-repeat;\n    border-radius: 2px;\n    opacity: .95;\n  }\n  /* ===== אנימציית הופעה מדורגת ===== */\n  [data-reveal] {\n    opacity: 0;\n    transform: translateY(18px);\n    transition: opacity .6s ease, transform .6s ease;\n  }\n  [data-reveal].is-visible {\n    opacity: 1;\n    transform: none;\n  }\n  @media (prefers-reduced-motion: reduce) {\n    [data-reveal] { opacity: 1; transform: none; transition: none; }\n  }\n</style>\n<script>\n  (function () {\n    var section = document.currentScript && document.currentScript.previousElementSibling;\n    var root = document.querySelector('.elora-arg');\n    if (!root) return;\n    var items = Array.prototype.slice.call(root.querySelectorAll('[data-reveal]'));\n    if (!items.length) return;\n    if (!('IntersectionObserver' in window)) {\n      items.forEach(function (el) { el.classList.add('is-visible'); });\n      return;\n    }\n    var io = new IntersectionObserver(function (entries) {\n      entries.forEach(function (entry) {\n        if (entry.isIntersecting) {\n          var el = entry.target;\n          var i = items.indexOf(el);\n          el.style.transitionDelay = (i * 140) + 'ms';\n          el.classList.add('is-visible');\n          io.unobserve(el);\n        }\n      });\n    }, { threshold: 0.2 });\n    items.forEach(function (el) { io.observe(el); });\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 24
      }
    },
    "custom_liquid_FaJwnt": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  ELORA – \"איך זה עובד\" — חלל קסום לילדים (Sticky + Hyperspace)\n  ------------------------------------------------------------\n  • שדה כוכבים חי + ניצוצות פסטל, קפיצת היילספייס בין שלבים.\n  • רקטה חמודה חולפת, כוכב לכת פסטלי מרחף — vibe ילדותי.\n  • יתושים מצוירים עם כנפיים מתנפנפות; בשלב 3 נהדפים מהמגן.\n  • לחיבור הפאזל: Padding → Top = 0 בבלוק הזה,\n    Padding → Bottom = 0 בבלוק שמעליו.\n  • כיוונונים מהירים:\n      – מהירות גלילה:  height של .elora-how__scroller (300vh,\n        גדול יותר = איטי יותר)\n      – גובה הפאנל:    --panel-h\n  ★ התמונות = ממלא־מקום זמני. החליפו את הקישורים כאן למטה:\n  ============================================================\n{%- endcomment -%}\n\n{%- comment -%} ←←← תמונות (זמניות) — החליפו כאן ←←← {%- endcomment -%}\n{%- assign img_problem  = \"https://cdn.shopify.com/s/files/1/0825/1296/9956/files/story-stage1-problem.webp?v=1783319406\" -%}\n{%- assign img_failed   = \"https://cdn.shopify.com/s/files/1/0825/1296/9956/files/story-stage2-tried.webp?v=1783319404\" -%}\n{%- assign img_solution = \"https://cdn.shopify.com/s/files/1/0825/1296/9956/files/story-stage3-solution.webp?v=1783319839\" -%}\n\n{%- comment -%} יתוש מצויר (בשימוש חוזר) {%- endcomment -%}\n{%- capture mosq_svg -%}\n<svg viewBox=\"0 0 72 56\" fill=\"none\">\n  <g class=\"elora-how__wing elora-how__wing--b\"><ellipse cx=\"38\" cy=\"14\" rx=\"11\" ry=\"5.5\" fill=\"rgba(255,255,255,.5)\" stroke=\"rgba(255,255,255,.85)\" stroke-width=\"1.6\" transform=\"rotate(-4 38 14)\"/></g>\n  <g class=\"elora-how__wing elora-how__wing--a\"><ellipse cx=\"25\" cy=\"15\" rx=\"13\" ry=\"6.5\" fill=\"rgba(255,255,255,.62)\" stroke=\"rgba(255,255,255,.9)\" stroke-width=\"1.6\" transform=\"rotate(-14 25 15)\"/></g>\n  <ellipse cx=\"30\" cy=\"33\" rx=\"14\" ry=\"9.5\" fill=\"#ff9d9d\" stroke=\"#ff6b6b\" stroke-width=\"2.4\"/>\n  <path d=\"M22 27.5c1.5 3.5 1.5 7.5 0 11M29 25.8c1.6 4.4 1.6 9.6 0 14\" stroke=\"#ff6b6b\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <circle cx=\"49\" cy=\"25\" r=\"7.5\" fill=\"#ff9d9d\" stroke=\"#ff6b6b\" stroke-width=\"2.4\"/>\n  <circle cx=\"51.4\" cy=\"23.6\" r=\"2.5\" fill=\"#3b1f2b\"/>\n  <circle cx=\"52.3\" cy=\"22.7\" r=\".9\" fill=\"#fff\"/>\n  <path d=\"M55.5 29l11 6\" stroke=\"#ff6b6b\" stroke-width=\"2.6\" stroke-linecap=\"round\"/>\n  <path d=\"M20 41l-4 6M28 43l-2 7M36 42l2 6\" stroke=\"#ff6b6b\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n</svg>\n{%- endcapture -%}\n\n<section class=\"elora-how\" dir=\"rtl\">\n\n  <span class=\"elora-how__edge elora-how__edge--top\" aria-hidden=\"true\"></span>\n\n  <div class=\"elora-how__scroller\">\n    <div class=\"elora-how__sticky\">\n\n      <canvas class=\"elora-how__stars\" aria-hidden=\"true\"></canvas>\n\n      <div class=\"elora-how__bg\" aria-hidden=\"true\">\n        <div class=\"elora-how__bg-layer\" data-layer=\"0\"></div>\n        <div class=\"elora-how__bg-layer\" data-layer=\"1\"></div>\n        <div class=\"elora-how__bg-layer\" data-layer=\"2\"></div>\n      </div>\n\n      {%- comment -%} קישוטי חלל ילדותיים {%- endcomment -%}\n      <div class=\"elora-how__deco\" aria-hidden=\"true\">\n        <span class=\"elora-how__planet\">\n          <svg viewBox=\"0 0 80 60\" fill=\"none\">\n            <circle cx=\"40\" cy=\"30\" r=\"17\" fill=\"#ffd9a8\" stroke=\"#ffb864\" stroke-width=\"2.5\"/>\n            <path d=\"M27 26c3-2.5 8-4 13-4s10 1.5 13 4\" stroke=\"#ffb864\" stroke-width=\"2\" stroke-linecap=\"round\" opacity=\".55\"/>\n            <circle cx=\"34\" cy=\"28\" r=\"2\" fill=\"#3b2b1f\"/>\n            <circle cx=\"46\" cy=\"28\" r=\"2\" fill=\"#3b2b1f\"/>\n            <path d=\"M35 35c1.6 1.8 3.4 2.6 5 2.6s3.4-.8 5-2.6\" stroke=\"#3b2b1f\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n            <ellipse cx=\"40\" cy=\"33\" rx=\"30\" ry=\"8\" stroke=\"#b9a4ff\" stroke-width=\"3\" fill=\"none\" transform=\"rotate(-14 40 33)\"/>\n          </svg>\n        </span>\n        <span class=\"elora-how__rocket\">\n          <svg viewBox=\"0 0 60 60\" fill=\"none\">\n            <path d=\"M30 6c7 6 10 14 10 22l-10 8-10-8c0-8 3-16 10-22z\" fill=\"#eef3ff\" stroke=\"#9db7e8\" stroke-width=\"2.4\"/>\n            <circle cx=\"30\" cy=\"22\" r=\"5\" fill=\"#a5c8ff\" stroke=\"#5f8ad1\" stroke-width=\"2\"/>\n            <path d=\"M20 30l-7 9 9-2M40 30l7 9-9-2\" fill=\"#ffb0b0\" stroke=\"#ff7b7b\" stroke-width=\"2\" stroke-linejoin=\"round\"/>\n            <g class=\"elora-how__flame\">\n              <path d=\"M30 38c3 4 3 8 0 13-3-5-3-9 0-13z\" fill=\"#ffd166\" stroke=\"#ff9f43\" stroke-width=\"1.8\"/>\n            </g>\n          </svg>\n        </span>\n      </div>\n\n      <div class=\"elora-how__dots\" aria-hidden=\"true\">\n        <span class=\"elora-how__dot is-active\"></span>\n        <span class=\"elora-how__dot\"></span>\n        <span class=\"elora-how__dot\"></span>\n      </div>\n\n      <div class=\"elora-how__content\">\n        <div class=\"elora-how__kicker\"><i></i>אז הנה איך זה עובד</div>\n\n        <div class=\"elora-how__stages\">\n\n          {%- comment -%} ===== שלב 1 – הבעיה ===== {%- endcomment -%}\n          <article class=\"elora-how__stage\" data-stage=\"0\">\n            <span class=\"elora-how__tag elora-how__tag--red\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 8v5M12 16h.01\"/></svg>\n              הבעיה\n            </span>\n\n            <div class=\"elora-how__media elora-how__media--holo\">\n              <img src=\"{{ img_problem }}\" alt=\"ילד עם עקיצות יתושים\" loading=\"eager\">\n              <span class=\"elora-how__mosq elora-how__mosq--1\">{{ mosq_svg }}</span>\n              <span class=\"elora-how__mosq elora-how__mosq--2\">{{ mosq_svg }}</span>\n              <span class=\"elora-how__mosq elora-how__mosq--3\">{{ mosq_svg }}</span>\n            </div>\n\n            <p class=\"elora-how__text\">\n              כל קיץ אותו סיפור.\n              יתושים, עקיצות, ילד שמגרד.<br>\n              ואתם מחפשים פתרון <b>שסוף סוף יעבוד</b>.\n            </p>\n          </article>\n\n          {%- comment -%} ===== שלב 2 – מה שניסיתם ===== {%- endcomment -%}\n          <article class=\"elora-how__stage\" data-stage=\"1\">\n            <span class=\"elora-how__tag elora-how__tag--gray\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 12a8 8 0 1 1-3-6.2\"/><path d=\"M20 4v4h-4\"/></svg>\n              מה שכבר ניסיתם\n            </span>\n\n            <div class=\"elora-how__fails\">\n              <figure class=\"elora-how__fail\">\n                <div class=\"elora-how__fail-ic\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M8 9h8l-1 9.2a2 2 0 0 1-2 1.8h-2a2 2 0 0 1-2-1.8L8 9z\"/><path d=\"M9.5 9V6.5A2.5 2.5 0 0 1 12 4a2.5 2.5 0 0 1 2.5 2.5V9\"/><path d=\"M10 13h4\"/></svg>\n                  <span class=\"elora-how__fail-x\" aria-hidden=\"true\">✕</span>\n                </div>\n                <figcaption>קרם</figcaption>\n              </figure>\n\n              <figure class=\"elora-how__fail\">\n                <div class=\"elora-how__fail-ic\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"8\" y=\"9\" width=\"8\" height=\"11\" rx=\"2\"/><path d=\"M10 9V6h3\"/><path d=\"M13 6l3.5-1.5M13 4h3.5M13 8l3.5 1.5\"/></svg>\n                  <span class=\"elora-how__fail-x\" aria-hidden=\"true\">✕</span>\n                </div>\n                <figcaption>תרסיס</figcaption>\n              </figure>\n\n              <figure class=\"elora-how__fail\">\n                <div class=\"elora-how__fail-ic\">\n                  <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3s5.5 6 5.5 10a5.5 5.5 0 0 1-11 0C6.5 9 12 3 12 3z\"/></svg>\n                  <span class=\"elora-how__fail-x\" aria-hidden=\"true\">✕</span>\n                </div>\n                <figcaption>משהו על העור</figcaption>\n              </figure>\n            </div>\n\n            <p class=\"elora-how__text elora-how__text--sm\">\n              ועדיין הילד חזר הביתה עם עקיצות. <br>שמתם עליו משהו שלא הייתם בטוחים לגביו,\n              <b>ובסוף גם זה לא עזר</b>.\n            </p>\n\n            <div class=\"elora-how__media elora-how__media--failed\">\n              <img src=\"{{ img_failed }}\" alt=\"מריחת קרם על ילד\" loading=\"lazy\">\n            </div>\n          </article>\n\n          {%- comment -%} ===== שלב 3 – הפתרון ===== {%- endcomment -%}\n          <article class=\"elora-how__stage\" data-stage=\"2\">\n            <span class=\"elora-how__tag elora-how__tag--green\">\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12l5 5L20 6\"/></svg>\n              הפתרון\n            </span>\n\n            <div class=\"elora-how__media elora-how__media--shield\">\n              <img src=\"{{ img_solution }}\" alt=\"ילד מוגן מיתושים בחוץ\" loading=\"lazy\">\n              <span class=\"elora-how__shield-badge\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 3l7 3v5c0 4.4-3 8.2-7 9.5C8 19.2 5 15.4 5 11V6l7-3z\"/><path d=\"M9 12l2 2 4-4.5\"/></svg>\n              </span>\n              <span class=\"elora-how__deflect elora-how__deflect--r\" aria-hidden=\"true\">{{ mosq_svg }}<b></b></span>\n              <span class=\"elora-how__deflect elora-how__deflect--l\" aria-hidden=\"true\">{{ mosq_svg }}<b></b></span>\n            </div>\n\n            <p class=\"elora-how__lead\">יש פתרון אחר.</p>\n            <p class=\"elora-how__text--solution\">\n              מדבקה שמדביקים <b>על הבגד</b>. <br> <span class=\"elora-how__no\">לא על העור</span>.\n            </p>\n\n            <div class=\"elora-how__hours\">\n              <span class=\"elora-how__hours-clock\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 48 48\" fill=\"none\">\n                  <circle cx=\"24\" cy=\"24\" r=\"21\" stroke=\"rgba(111,232,154,.28)\" stroke-width=\"2\"/>\n                  <g stroke=\"rgba(111,232,154,.75)\" stroke-width=\"2.4\" stroke-linecap=\"round\">\n                    <path d=\"M24 3v4M45 24h-4M24 45v-4M3 24h4M38.8 9.2l-2.8 2.8M38.8 38.8l-2.8-2.8M9.2 38.8l2.8-2.8M9.2 9.2l2.8 2.8\"/>\n                  </g>\n                  <g class=\"elora-how__sweep\" stroke=\"#6fe89a\" stroke-width=\"2.6\" stroke-linecap=\"round\">\n                    <path d=\"M24 24V10\"/>\n                  </g>\n                  <circle cx=\"24\" cy=\"24\" r=\"2.6\" fill=\"#6fe89a\"/>\n                </svg>\n              </span>\n              <span class=\"elora-how__hours-txt\">\n                <span class=\"elora-how__hours-num\">עד 8 שעות</span>\n                <span class=\"elora-how__hours-sub\">הגנה רציפה מיתושים</span>\n              </span>\n            </div>\n          </article>\n\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <span class=\"elora-how__edge elora-how__edge--bottom\" aria-hidden=\"true\"></span>\n</section>\n\n<style>\n  .elora-how {\n    --how-blue: #7fb0ff;\n    --how-green: #6fe89a;\n    --how-red: #ff7b7b;\n    --how-text: #e9eefb;\n    --how-edge: #ffffff;              /* צבע הרקע של הדף מעל/מתחת */\n    --panel-h: min(100svh, 680px);    /* ← גובה הפאנל */\n    position: relative;\n    font-family: inherit;\n    color: var(--how-text);\n    background: #060a16;              /* חלל רך */\n    isolation: isolate;\n  }\n  .elora-how *,\n  .elora-how *::before,\n  .elora-how *::after { box-sizing: border-box; }\n\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .elora-how__edge {\n    position: absolute; left: 0; width: 100%; height: 22px; z-index: 6;\n    background: var(--how-edge); pointer-events: none;\n  }\n  .elora-how__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  .elora-how__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n\n  /* ===== מבנה גלילה ===== */\n  .elora-how__scroller { height: 300vh; }   /* ← מהירות: גדול יותר = איטי יותר */\n  .elora-how__sticky {\n    position: -webkit-sticky; position: sticky;\n    top: 0;\n    top: max(0px, calc((100svh - var(--panel-h)) / 2));\n    height: 100vh;\n    height: var(--panel-h);\n    overflow: hidden;\n    display: flex; align-items: center; justify-content: center;\n  }\n\n  .elora-how__stars { position: absolute; inset: 0; z-index: 0; display: block; }\n\n  .elora-how__bg { position: absolute; inset: 0; z-index: 1; pointer-events: none; }\n  .elora-how__bg-layer { position: absolute; inset: 0; opacity: 0; transition: opacity 200ms linear; will-change: opacity; }\n  .elora-how__bg-layer[data-layer=\"0\"] { opacity: 1; background: radial-gradient(115% 85% at 50% 36%, rgba(84, 130, 240, .28) 0%, rgba(84, 130, 240, 0) 70%); }\n  .elora-how__bg-layer[data-layer=\"1\"] { background: radial-gradient(115% 85% at 50% 36%, rgba(240, 110, 130, .2) 0%, rgba(240, 110, 130, 0) 70%); }\n  .elora-how__bg-layer[data-layer=\"2\"] { background: radial-gradient(115% 85% at 50% 36%, rgba(80, 225, 140, .24) 0%, rgba(80, 225, 140, 0) 72%); }\n\n  /* ===== קישוטים ילדותיים ===== */\n  .elora-how__deco { position: absolute; inset: 0; z-index: 1; pointer-events: none; }\n  .elora-how__planet {\n    position: absolute; top: 7%; right: 6%;\n    width: clamp(64px, 12vw, 96px);\n    animation: elora-bob 6s ease-in-out infinite;\n    filter: drop-shadow(0 0 14px rgba(255, 216, 168, .3));\n  }\n  .elora-how__planet svg { width: 100%; height: auto; display: block; }\n  @keyframes elora-bob { 0%,100%{transform:translateY(0) rotate(-4deg)} 50%{transform:translateY(-12px) rotate(4deg)} }\n\n  .elora-how__rocket {\n    position: absolute; bottom: -70px; left: -70px;\n    width: clamp(44px, 9vw, 62px);\n    opacity: 0;\n    animation: elora-rocket 15s ease-in-out infinite;\n    animation-delay: 2s;\n    filter: drop-shadow(0 0 12px rgba(165, 200, 255, .35));\n  }\n  .elora-how__rocket svg { width: 100%; height: auto; display: block; transform: rotate(38deg); }\n  .elora-how__flame { transform-box: fill-box; transform-origin: top center; animation: elora-flame .22s ease-in-out infinite alternate; }\n  @keyframes elora-flame { from { transform: scaleY(.75); } to { transform: scaleY(1.15); } }\n  @keyframes elora-rocket {\n    0%   { transform: translate(0, 0); opacity: 0; }\n    4%   { opacity: 1; }\n    30%  { transform: translate(calc(100vw + 140px), calc(-1 * var(--panel-h) - 140px)); opacity: 1; }\n    31%, 100% { transform: translate(0, 0); opacity: 0; }\n  }\n\n  .elora-how__content {\n    position: relative; z-index: 2; width: 100%; max-width: 680px;\n    margin: 0 auto; padding: 24px;\n    display: flex; flex-direction: column; align-items: center;\n    gap: clamp(12px, 2.2vh, 20px);\n  }\n\n  /* Kicker */\n  .elora-how__kicker {\n    display: inline-flex; align-items: center; gap: 9px;\n    padding: 7px 17px; border-radius: 999px;\n    background: rgba(16, 26, 52, .66);\n    border: 1px solid rgba(127, 176, 255, .4);\n    box-shadow: 0 0 18px rgba(127, 176, 255, .18);\n    color: #dce8ff;\n    font-size: clamp(12px, 3.2vw, 15px); font-weight: 700; letter-spacing: .05em; white-space: nowrap;\n  }\n  .elora-how__kicker i {\n    width: 7px; height: 7px; border-radius: 50%;\n    background: var(--how-blue);\n    box-shadow: 0 0 8px var(--how-blue);\n    animation: elora-blink 1.6s ease-in-out infinite;\n  }\n  @keyframes elora-blink { 0%,100%{opacity:1} 50%{opacity:.25} }\n\n  .elora-how__dots {\n    position: absolute; left: 16px; top: 50%; transform: translateY(-50%); z-index: 4;\n    display: flex; flex-direction: column; gap: 11px;\n  }\n  .elora-how__dot {\n    width: 9px; height: 9px; border-radius: 50%;\n    background: rgba(255, 255, 255, .22);\n    transition: background .3s ease, transform .3s ease, box-shadow .3s ease;\n  }\n  .elora-how__dot.is-active { background: var(--how-blue); box-shadow: 0 0 10px var(--how-blue); transform: scale(1.5); }\n\n  .elora-how__stages { display: grid; width: 100%; }\n  .elora-how__stage {\n    grid-column: 1; grid-row: 1;\n    display: flex; flex-direction: column; align-items: center; text-align: center;\n    gap: clamp(11px, 2vh, 17px);\n    opacity: 0; will-change: opacity, transform;\n  }\n\n  /* תגיות שלב */\n  .elora-how__tag {\n    display: inline-flex; align-items: center; gap: 7px;\n    padding: 6px 15px; border-radius: 999px;\n    font-size: clamp(12px, 3.2vw, 14px); font-weight: 800; letter-spacing: .04em;\n    background: rgba(255, 255, 255, .05);\n    animation: elora-wobble 5s ease-in-out infinite;\n  }\n  @keyframes elora-wobble { 0%,100%{transform:rotate(0)} 25%{transform:rotate(1.6deg)} 75%{transform:rotate(-1.6deg)} }\n  .elora-how__tag svg { width: 15px; height: 15px; }\n  .elora-how__tag--red   { color: var(--how-red);   border: 1px solid rgba(255, 123, 123, .45); box-shadow: 0 0 14px rgba(255, 123, 123, .2); }\n  .elora-how__tag--gray  { color: #b6c2da;          border: 1px solid rgba(182, 194, 218, .4);  box-shadow: 0 0 14px rgba(182, 194, 218, .14); }\n  .elora-how__tag--green { color: var(--how-green); border: 1px solid rgba(111, 232, 154, .45); box-shadow: 0 0 14px rgba(111, 232, 154, .2); }\n\n  /* ===== מדיה ===== */\n  .elora-how__media { position: relative; width: 100%; max-width: min(430px, 84vw); }\n  .elora-how__media img {\n    width: 100%; aspect-ratio: 16 / 10; object-fit: cover;\n    max-height: 32vh;\n    border-radius: 20px; display: block;\n  }\n  .elora-how__media--holo img {\n    border: 2px solid rgba(127, 176, 255, .55);\n    box-shadow: 0 0 30px rgba(127, 176, 255, .22), 0 18px 44px rgba(0, 0, 0, .5);\n  }\n  .elora-how__media--failed { max-width: min(390px, 80vw); }\n  .elora-how__media--failed img {\n    max-height: 24vh;\n    border: 2px solid rgba(255, 123, 123, .4);\n    box-shadow: 0 0 24px rgba(255, 123, 123, .16), 0 16px 38px rgba(0, 0, 0, .5);\n    filter: saturate(.8);\n  }\n\n  /* יתושים — כנפיים מתנפנפות */\n  .elora-how__wing { transform-box: fill-box; transform-origin: bottom center; }\n  .elora-how__wing--a { animation: elora-flap .16s ease-in-out infinite alternate; }\n  .elora-how__wing--b { animation: elora-flap .16s ease-in-out infinite alternate-reverse; }\n  @keyframes elora-flap { from { transform: rotate(-4deg) scaleY(1); } to { transform: rotate(10deg) scaleY(.62); } }\n\n  .elora-how__mosq { position: absolute; width: 52px; pointer-events: none; filter: drop-shadow(0 3px 8px rgba(0,0,0,.45)); }\n  .elora-how__mosq svg { width: 100%; height: auto; display: block; }\n  .elora-how__mosq--1 { top: -26px; right: -10px; animation: elora-fly1 7s ease-in-out infinite; }\n  .elora-how__mosq--2 { bottom: -18px; left: -14px; width: 42px; animation: elora-fly2 9s ease-in-out infinite; transform: scaleX(-1); }\n  .elora-how__mosq--2 svg { transform: scaleX(-1); }\n  .elora-how__mosq--3 { top: 30%; left: -30px; width: 34px; animation: elora-fly3 8s ease-in-out infinite; }\n  @keyframes elora-fly1 { 0%,100%{transform:translate(0,0) rotate(-6deg)} 30%{transform:translate(-28px,16px) rotate(6deg)} 65%{transform:translate(-10px,-12px) rotate(-3deg)} }\n  @keyframes elora-fly2 { 0%,100%{transform:translate(0,0) rotate(8deg)} 40%{transform:translate(22px,-18px) rotate(-5deg)} 75%{transform:translate(6px,10px) rotate(3deg)} }\n  @keyframes elora-fly3 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(14px,-20px) rotate(10deg)} }\n\n  /* ===== כיפת מגן (שלב 3) ===== */\n  .elora-how__media--shield img {\n    border: 2.5px solid rgba(111, 232, 154, .75);\n    box-shadow: 0 0 34px rgba(111, 232, 154, .3), 0 18px 44px rgba(0, 0, 0, .5);\n  }\n  .elora-how__media--shield::before,\n  .elora-how__media--shield::after {\n    content: \"\"; position: absolute; inset: 0;\n    border-radius: 20px;\n    border: 1.6px solid rgba(111, 232, 154, .55);\n    pointer-events: none;\n    animation: elora-ring 2.6s ease-out infinite;\n  }\n  .elora-how__media--shield::after { animation-delay: 1.3s; }\n  @keyframes elora-ring { 0% { transform: scale(1); opacity: .8; } 100% { transform: scale(1.14); opacity: 0; } }\n\n  .elora-how__shield-badge {\n    position: absolute; bottom: -16px; left: 50%; transform: translateX(-50%);\n    width: 46px; height: 46px; border-radius: 50%;\n    background: #0a1a10; color: var(--how-green);\n    border: 2px solid rgba(111, 232, 154, .8);\n    box-shadow: 0 0 18px rgba(111, 232, 154, .5);\n    display: flex; align-items: center; justify-content: center;\n    z-index: 2;\n    animation: elora-badge 3s ease-in-out infinite;\n  }\n  @keyframes elora-badge { 0%,100%{transform:translateX(-50%) scale(1)} 50%{transform:translateX(-50%) scale(1.1)} }\n  .elora-how__shield-badge svg { width: 24px; height: 24px; }\n\n  /* יתושים נהדפים מהמגן */\n  .elora-how__deflect { position: absolute; width: 46px; pointer-events: none; filter: drop-shadow(0 3px 8px rgba(0,0,0,.45)); }\n  .elora-how__deflect svg { width: 100%; height: auto; display: block; }\n  .elora-how__deflect b {\n    position: absolute; top: 50%; width: 16px; height: 16px; border-radius: 50%;\n    border: 2.5px solid rgba(111, 232, 154, .95);\n    box-shadow: 0 0 10px rgba(111, 232, 154, .8);\n    opacity: 0; pointer-events: none;\n  }\n  .elora-how__deflect--r { top: 14%; right: -46px; animation: elora-def-r 3.6s ease-in-out infinite; }\n  .elora-how__deflect--r svg { transform: scaleX(-1); }\n  .elora-how__deflect--r b { right: auto; left: -10px; animation: elora-spark 3.6s ease-out infinite; }\n  .elora-how__deflect--l { bottom: 20%; left: -40px; width: 38px; animation: elora-def-l 4.4s ease-in-out infinite; animation-delay: .8s; }\n  .elora-how__deflect--l b { left: auto; right: -10px; animation: elora-spark 4.4s ease-out infinite; animation-delay: .8s; }\n  @keyframes elora-def-r {\n    0%, 100% { transform: translate(0, 0) rotate(-10deg); }\n    42%      { transform: translate(-20px, 8px) rotate(-4deg); }\n    50%      { transform: translate(-24px, 10px) rotate(0deg); }\n    58%      { transform: translate(2px, -6px) rotate(24deg); }\n    70%      { transform: translate(8px, -10px) rotate(-12deg); }\n  }\n  @keyframes elora-def-l {\n    0%, 100% { transform: translate(0, 0) rotate(8deg); }\n    42%      { transform: translate(18px, -6px) rotate(3deg); }\n    50%      { transform: translate(22px, -8px) rotate(0deg); }\n    58%      { transform: translate(-2px, 6px) rotate(-22deg); }\n    70%      { transform: translate(-8px, 10px) rotate(10deg); }\n  }\n  @keyframes elora-spark {\n    0%, 46% { opacity: 0; transform: scale(.4); }\n    52%     { opacity: 1; transform: scale(1); }\n    66%, 100% { opacity: 0; transform: scale(1.6); }\n  }\n\n  /* ===== טקסטים ===== */\n  .elora-how__text {\n    margin: 0; max-width: 560px;\n    font-size: clamp(19px, 4.6vw, 26px); line-height: 1.5; font-weight: 500; color: var(--how-text);\n  }\n  .elora-how__text b { color: var(--how-blue); font-weight: 800; text-shadow: 0 0 16px rgba(127, 176, 255, .45); }\n  .elora-how__text--sm { margin: 0; max-width: 520px; font-size: clamp(15px, 3.8vw, 19px); line-height: 1.55; font-weight: 500; color: #c6d1e6; }\n  .elora-how__text--sm b { color: var(--how-red); font-weight: 800; text-shadow: 0 0 14px rgba(255, 123, 123, .4); }\n\n  .elora-how__lead {\n    margin: 0; font-size: clamp(24px, 6vw, 34px); font-weight: 900; line-height: 1.15;\n    color: #fff; text-shadow: 0 0 24px rgba(111, 232, 154, .3);\n  }\n  .elora-how__text--solution {\n    margin: 0; max-width: 520px;\n    font-size: clamp(17px, 4.3vw, 24px); line-height: 1.5; font-weight: 600; color: var(--how-text);\n  }\n  .elora-how__text--solution b { color: var(--how-green); font-weight: 900; text-shadow: 0 0 16px rgba(111, 232, 154, .5); }\n  .elora-how__no {\n    font-weight: 900; color: var(--how-blue);\n    text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 3px;\n    text-shadow: 0 0 16px rgba(127, 176, 255, .45);\n  }\n\n  /* ===== שלב 2 — כרטיסי כישלון (גדולים יותר) ===== */\n  .elora-how__fails { display: flex; gap: clamp(14px, 4vw, 26px); justify-content: center; }\n  .elora-how__fail { margin: 0; display: flex; flex-direction: column; align-items: center; gap: 10px; }\n  .elora-how__fail:nth-child(1) { animation: elora-bob-s 4.6s ease-in-out infinite; }\n  .elora-how__fail:nth-child(2) { animation: elora-bob-s 4.6s ease-in-out infinite; animation-delay: .7s; }\n  .elora-how__fail:nth-child(3) { animation: elora-bob-s 4.6s ease-in-out infinite; animation-delay: 1.4s; }\n  @keyframes elora-bob-s { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-7px)} }\n  .elora-how__fail-ic {\n    position: relative;\n    width: clamp(92px, 26vw, 122px); height: clamp(92px, 26vw, 122px);\n    border-radius: 26px;\n    background: rgba(255, 255, 255, .065);\n    border: 1.6px solid rgba(255, 255, 255, .18);\n    box-shadow: 0 0 22px rgba(255, 123, 123, .12), 0 12px 26px rgba(0, 0, 0, .45);\n    display: flex; align-items: center; justify-content: center; color: #c3cfe4;\n  }\n  .elora-how__fail-ic svg { width: 50%; height: 50%; }\n  .elora-how__fail-x {\n    position: absolute; top: -11px; left: -11px;\n    width: 36px; height: 36px; border-radius: 50%;\n    background: #ff4d4d; color: #fff;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 19px; font-weight: 900; line-height: 1;\n    box-shadow: 0 0 16px rgba(255, 77, 77, .8); border: 2.5px solid #2a0a0a;\n  }\n  .elora-how__fail figcaption {\n    font-size: clamp(14px, 3.7vw, 17px); font-weight: 700; color: #9aa8c0;\n    text-decoration: line-through; text-decoration-color: rgba(255, 100, 100, .8);\n  }\n\n  /* ===== שעון משימה ===== */\n  .elora-how__hours {\n    display: inline-flex; align-items: center; gap: 14px; margin-top: 2px;\n    padding: 12px 22px; border-radius: 18px;\n    background: rgba(8, 20, 14, .6);\n    -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px);\n    border: 1px solid rgba(111, 232, 154, .4);\n    box-shadow: 0 0 26px rgba(111, 232, 154, .18);\n  }\n  .elora-how__hours-clock { width: clamp(42px, 11vw, 54px); height: clamp(42px, 11vw, 54px); flex: none; }\n  .elora-how__hours-clock svg { width: 100%; height: 100%; display: block; }\n  .elora-how__sweep { transform-origin: 24px 24px; animation: elora-sweep 8s linear infinite; }\n  @keyframes elora-sweep { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }\n  .elora-how__hours-txt { display: flex; flex-direction: column; align-items: flex-start; }\n  .elora-how__hours-num {\n    font-size: clamp(28px, 7.6vw, 44px); font-weight: 900; line-height: 1.05;\n    color: var(--how-green); letter-spacing: -0.02em;\n    text-shadow: 0 0 20px rgba(111, 232, 154, .55);\n  }\n  .elora-how__hours-sub { font-size: clamp(12px, 3.2vw, 15px); font-weight: 700; color: #9fd4ae; }\n\n  /* מסכים נמוכים */\n  @media (max-height: 660px) {\n    .elora-how__media img { max-height: 26vh; }\n    .elora-how__media--failed img { max-height: 20vh; }\n    .elora-how__content { gap: 9px; padding: 18px 24px; }\n    .elora-how__stage { gap: 9px; }\n    .elora-how__fail-ic { width: clamp(78px, 22vw, 100px); height: clamp(78px, 22vw, 100px); }\n  }\n\n  /* ===== Fallback — ללא JS / תנועה מופחתת ===== */\n  .elora-how:not(.is-enhanced) .elora-how__scroller { height: auto; }\n  .elora-how:not(.is-enhanced) .elora-how__sticky { position: static; height: auto; overflow: visible; padding: 48px 0; }\n  .elora-how:not(.is-enhanced) .elora-how__stars { display: none; }\n  .elora-how:not(.is-enhanced) .elora-how__bg-layer[data-layer=\"0\"] { opacity: 1; }\n  .elora-how:not(.is-enhanced) .elora-how__dots { display: none; }\n  .elora-how:not(.is-enhanced) .elora-how__rocket { display: none; }\n  .elora-how:not(.is-enhanced) .elora-how__stages { display: block; }\n  .elora-how:not(.is-enhanced) .elora-how__stage { opacity: 1; margin-bottom: 46px; }\n  .elora-how:not(.is-enhanced) .elora-how__stage:last-child { margin-bottom: 0; }\n  .elora-how:not(.is-enhanced) .elora-how__media img { max-height: none; }\n  @media (prefers-reduced-motion: reduce) {\n    .elora-how__mosq, .elora-how__deflect, .elora-how__deflect b,\n    .elora-how__wing, .elora-how__sweep, .elora-how__kicker i,\n    .elora-how__planet, .elora-how__rocket, .elora-how__flame,\n    .elora-how__tag, .elora-how__fail, .elora-how__shield-badge,\n    .elora-how__media--shield::before, .elora-how__media--shield::after { animation: none; }\n  }\n</style>\n\n<script>\n  (function () {\n    var sections = document.querySelectorAll('.elora-how');\n    Array.prototype.forEach.call(sections, initHow);\n\n    function initHow(section) {\n      if (section.dataset.eloraInit) return;\n      section.dataset.eloraInit = '1';\n\n      var scroller = section.querySelector('.elora-how__scroller');\n      var sticky   = section.querySelector('.elora-how__sticky');\n      var canvas   = section.querySelector('.elora-how__stars');\n      var stages = [].slice.call(section.querySelectorAll('.elora-how__stage'));\n      var layers = [].slice.call(section.querySelectorAll('.elora-how__bg-layer'));\n      var dots   = [].slice.call(section.querySelectorAll('.elora-how__dot'));\n      var N = stages.length;\n      if (!N || !scroller || !sticky) return;\n\n      var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n      if (reduce) return;\n\n      section.classList.add('is-enhanced');\n\n      function clamp(v, a, b) { return Math.min(b, Math.max(a, v)); }\n\n      var warpTarget = 0;\n      var ticking = false;\n\n      function update() {\n        ticking = false;\n        var rect = scroller.getBoundingClientRect();\n        var stickyH = sticky.offsetHeight;\n        var topOff = parseFloat(window.getComputedStyle(sticky).top) || 0;\n        var dist = scroller.offsetHeight - stickyH;\n        if (dist <= 0) dist = 1;\n        var p = clamp((topOff - rect.top) / dist, 0, 1);\n        var scaled = p * N;\n\n        for (var i = 0; i < N; i++) {\n          var center = i + 0.5;\n          var d = Math.abs(scaled - center);\n\n          var o = clamp(1 - d / 0.5, 0, 1);\n          if (i === 0 && scaled < center) o = 1;\n          if (i === N - 1 && scaled > center) o = 1;\n          var ty = (scaled - center) * -30;\n          stages[i].style.opacity = o;\n          stages[i].style.transform = 'translateY(' + ty + 'px) scale(' + (0.96 + 0.04 * o) + ')';\n          stages[i].style.pointerEvents = o > 0.5 ? 'auto' : 'none';\n          stages[i].style.zIndex = o > 0.5 ? 2 : 1;\n\n          var lo = clamp(1 - d / 0.95, 0, 1);\n          if (i === 0 && scaled < center) lo = 1;\n          if (i === N - 1 && scaled > center) lo = 1;\n          layers[i].style.opacity = lo;\n        }\n\n        var w = 0;\n        for (var b = 1; b < N; b++) {\n          var dd = scaled - b;\n          w = Math.max(w, Math.exp(-(dd * dd) / 0.022));\n        }\n        warpTarget = (p <= 0 || p >= 1) ? 0 : w;\n\n        var active = clamp(Math.floor(scaled), 0, N - 1);\n        for (var k = 0; k < dots.length; k++) dots[k].classList.toggle('is-active', k === active);\n      }\n\n      function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }\n      window.addEventListener('scroll', onScroll, { passive: true });\n      window.addEventListener('resize', function () { onScroll(); sizeCanvas(); });\n      update();\n\n      /* ===== שדה כוכבים + ניצוצות פסטל + היילספייס ===== */\n      if (!canvas || !canvas.getContext) return;\n      var ctx = canvas.getContext('2d');\n      var stars = [], W = 0, H = 0, cx = 0, cy = 0, maxR = 1;\n      var warp = 0, running = false, inView = false;\n      var palette = ['215,228,255', '255,224,160', '255,190,220', '180,240,200'];\n\n      function sizeCanvas() {\n        var dpr = Math.min(window.devicePixelRatio || 1, 2);\n        W = sticky.clientWidth; H = sticky.clientHeight;\n        canvas.width = W * dpr; canvas.height = H * dpr;\n        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n        cx = W / 2; cy = H / 2;\n        maxR = Math.sqrt(cx * cx + cy * cy);\n        var count = clamp(Math.round(W * H / 8500), 60, 170);\n        stars = [];\n        for (var i = 0; i < count; i++) stars.push(newStar(true));\n      }\n\n      function newStar(anywhere) {\n        var sparkle = Math.random() < 0.16;\n        return {\n          a: Math.random() * Math.PI * 2,\n          r: anywhere ? Math.random() : 0.04 + Math.random() * 0.12,\n          sp: 0.0004 + Math.random() * 0.0012,\n          sz: sparkle ? 1.1 + Math.random() * 1.3 : 0.5 + Math.random() * 1.5,\n          tw: Math.random() * Math.PI * 2,\n          c: sparkle ? palette[1 + Math.floor(Math.random() * 3)] : palette[0],\n          k: sparkle\n        };\n      }\n\n      function frame() {\n        if (!running) return;\n        warp += (warpTarget - warp) * 0.09;\n        ctx.clearRect(0, 0, W, H);\n\n        for (var i = 0; i < stars.length; i++) {\n          var s = stars[i];\n          var speed = s.sp * (1 + warp * 30);\n          s.r += speed;\n          s.tw += 0.045;\n          if (s.r > 1.05) { stars[i] = newStar(false); continue; }\n\n          var x = cx + Math.cos(s.a) * s.r * maxR;\n          var y = cy + Math.sin(s.a) * s.r * maxR;\n          var alpha = (0.3 + 0.7 * Math.abs(Math.sin(s.tw))) * Math.min(1, s.r * 5 + 0.15);\n\n          if (warp > 0.06) {\n            var r0 = Math.max(0.01, s.r - speed * 9 - warp * 0.055 * s.r);\n            var x0 = cx + Math.cos(s.a) * r0 * maxR;\n            var y0 = cy + Math.sin(s.a) * r0 * maxR;\n            ctx.strokeStyle = 'rgba(' + s.c + ',' + (alpha * (0.5 + warp * 0.5)) + ')';\n            ctx.lineWidth = s.sz;\n            ctx.beginPath(); ctx.moveTo(x0, y0); ctx.lineTo(x, y); ctx.stroke();\n          } else if (s.k) {\n            /* ניצוץ פסטל בצורת + */\n            var L = s.sz * 3.2;\n            ctx.strokeStyle = 'rgba(' + s.c + ',' + alpha + ')';\n            ctx.lineWidth = 1.2;\n            ctx.beginPath();\n            ctx.moveTo(x - L, y); ctx.lineTo(x + L, y);\n            ctx.moveTo(x, y - L); ctx.lineTo(x, y + L);\n            ctx.stroke();\n          } else {\n            ctx.fillStyle = 'rgba(' + s.c + ',' + alpha + ')';\n            ctx.beginPath(); ctx.arc(x, y, s.sz, 0, 6.2832); ctx.fill();\n          }\n        }\n        requestAnimationFrame(frame);\n      }\n\n      function setRunning(v) {\n        v = v && inView && !document.hidden;\n        if (v === running) return;\n        running = v;\n        if (running) requestAnimationFrame(frame);\n      }\n\n      sizeCanvas();\n\n      if ('IntersectionObserver' in window) {\n        var io = new IntersectionObserver(function (entries) {\n          inView = entries[0].isIntersecting;\n          setRunning(true);\n        }, { rootMargin: '120px' });\n        io.observe(section);\n      } else {\n        inView = true; setRunning(true);\n      }\n      document.addEventListener('visibilitychange', function () { setRunning(true); });\n    }\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_J84HCN": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  ELORA – \"בועת הקסם\" + נחיתה הביתה — בא אחרי סקשן החלל\n  ------------------------------------------------------------\n  • רקע שנמס מחושך־חלל (למעלה) לשקיעה חמה ולאור ביתי (למטה).\n  • במרכז: הילד בתוך בועת ריח זוהרת, חלקיקי ריח מקיפים,\n    יתושים חמודים מבולבלים עם \"?\" — לא מוצאים אותו.\n  • למטה: גבעות, בית עם חלון מאיר וגחליליות — הסגירה הרגשית.\n  • לחיבור הפאזל: Padding → Top = 0 בבלוק הזה,\n    Padding → Bottom = 0 בבלוק שמעליו (החלל).\n  ★ התמונה = ממלא־מקום זמני. החליפו את הקישור כאן:\n  ============================================================\n{%- endcomment -%}\n\n{%- comment -%} ←←← תמונת הילד בבועה (זמנית) — החליפו כאן ←←← {%- endcomment -%}\n{%- assign img_child = \"https://cdn.shopify.com/s/files/1/0825/1296/9956/files/hf_20260705_182141_3cac5240-0af3-4307-a858-213eef69d783_1.webp?v=1783319376\" -%}\n\n{%- comment -%} יתוש מצויר (זהה לסקשן הקודם) {%- endcomment -%}\n{%- capture mosq_svg -%}\n<svg viewBox=\"0 0 72 56\" fill=\"none\">\n  <g class=\"elora-bub__wing elora-bub__wing--b\"><ellipse cx=\"38\" cy=\"14\" rx=\"11\" ry=\"5.5\" fill=\"rgba(255,255,255,.5)\" stroke=\"rgba(255,255,255,.85)\" stroke-width=\"1.6\" transform=\"rotate(-4 38 14)\"/></g>\n  <g class=\"elora-bub__wing elora-bub__wing--a\"><ellipse cx=\"25\" cy=\"15\" rx=\"13\" ry=\"6.5\" fill=\"rgba(255,255,255,.62)\" stroke=\"rgba(255,255,255,.9)\" stroke-width=\"1.6\" transform=\"rotate(-14 25 15)\"/></g>\n  <ellipse cx=\"30\" cy=\"33\" rx=\"14\" ry=\"9.5\" fill=\"#ff9d9d\" stroke=\"#ff6b6b\" stroke-width=\"2.4\"/>\n  <path d=\"M22 27.5c1.5 3.5 1.5 7.5 0 11M29 25.8c1.6 4.4 1.6 9.6 0 14\" stroke=\"#ff6b6b\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n  <circle cx=\"49\" cy=\"25\" r=\"7.5\" fill=\"#ff9d9d\" stroke=\"#ff6b6b\" stroke-width=\"2.4\"/>\n  <circle cx=\"51.4\" cy=\"23.6\" r=\"2.5\" fill=\"#3b1f2b\"/>\n  <circle cx=\"52.3\" cy=\"22.7\" r=\".9\" fill=\"#fff\"/>\n  <path d=\"M55.5 29l11 6\" stroke=\"#ff6b6b\" stroke-width=\"2.6\" stroke-linecap=\"round\"/>\n  <path d=\"M20 41l-4 6M28 43l-2 7M36 42l2 6\" stroke=\"#ff6b6b\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n</svg>\n{%- endcapture -%}\n\n<section class=\"elora-bub\" dir=\"rtl\">\n\n  <span class=\"elora-bub__edge elora-bub__edge--top\" aria-hidden=\"true\"></span>\n\n  {%- comment -%} כוכבים סטטיים באזור הכהה {%- endcomment -%}\n  <div class=\"elora-bub__sky\" aria-hidden=\"true\">\n    <i style=\"top:6%; right:12%\"></i><i style=\"top:11%; right:30%; animation-delay:.7s\"></i>\n    <i style=\"top:5%; right:56%; animation-delay:1.3s\"></i><i style=\"top:13%; right:74%; animation-delay:.3s\"></i>\n    <i style=\"top:8%; right:88%; animation-delay:1.7s\"></i><i style=\"top:17%; right:46%; animation-delay:1s\"></i>\n    <i style=\"top:20%; right:8%;  animation-delay:1.5s\"></i><i style=\"top:22%; right:66%; animation-delay:.5s\"></i>\n  </div>\n\n  <div class=\"elora-bub__inner\">\n\n    <span class=\"elora-bub__kicker\" data-reveal><i></i>הקסם שמאחורי המדבקה</span>\n\n    <h2 class=\"elora-bub__headline\" data-reveal>\n      המדבקה מכילה <b>ציטרונלה</b>, ועוד שמנים צמחיים כמו <b>אקליפטוס</b> <b>ולימון גראס</b>.<br> שמנים צמחיים טבעיים\n      היוצרים <b>בועת ריח והגנה</b> סביב הילד.\n    </h2>\n\n    {%- comment -%} ===== הבועה ===== {%- endcomment -%}\n    <div class=\"elora-bub__stage\" data-reveal>\n\n      <div class=\"elora-bub__bubble\">\n        <span class=\"elora-bub__iris\" aria-hidden=\"true\"></span>\n        <img src=\"{{ img_child }}\" alt=\"ילד מוגן בתוך בועת הריח\" loading=\"lazy\">\n        <span class=\"elora-bub__shine\" aria-hidden=\"true\"></span>\n\n        {%- comment -%} חלקיקי ריח מקיפים {%- endcomment -%}\n        <span class=\"elora-bub__orbit elora-bub__orbit--1\" aria-hidden=\"true\"><b></b></span>\n        <span class=\"elora-bub__orbit elora-bub__orbit--2\" aria-hidden=\"true\"><b></b></span>\n        <span class=\"elora-bub__orbit elora-bub__orbit--3\" aria-hidden=\"true\"><b></b></span>\n      </div>\n\n      <span class=\"elora-bub__chip\" data-reveal>\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M4 20c8 1 15-5 16-15-10 1-16 7-16 15z\"/><path d=\"M4 20c3-6 7-10 12-12\"/></svg>\n        שמן צמחי 100% טבעי\n      </span>\n\n      {%- comment -%} יתושים מבולבלים {%- endcomment -%}\n      <span class=\"elora-bub__lost elora-bub__lost--r\" aria-hidden=\"true\">\n        {{ mosq_svg }}<em>?</em>\n      </span>\n      <span class=\"elora-bub__lost elora-bub__lost--l\" aria-hidden=\"true\">\n        {{ mosq_svg }}<em>?</em>\n      </span>\n    </div>\n\n    <p class=\"elora-bub__explain\" data-reveal>\n      יתושים מנווטים לפי ריח ובועת הריח פשוט <b>מסתירה אותו מהם</b>.<br>\n      <span class=\"elora-bub__skin\">ככה עור הילד לא נוגע בשום דבר.</span>\n    </p>\n\n    {%- comment -%} ===== 3 צעדים קטנים ===== {%- endcomment -%}\n    <div class=\"elora-bub__steps\" data-reveal>\n      <span class=\"elora-bub__step\">\n        <b>1</b>\n        מדביקים על הבגד\n      </span>\n      <span class=\"elora-bub__step\">\n        <b>2</b>\n        נוצרת בועת ריח\n      </span>\n      <span class=\"elora-bub__step\">\n        <b>3</b>\n        היתושים לא מוצאים אותו\n      </span>\n    </div>\n\n    {%- comment -%} ===== הנחיתה הביתה ===== {%- endcomment -%}\n    <div class=\"elora-bub__home\" data-reveal>\n      <p class=\"elora-bub__lead\">\n        הילד חוזר הביתה <b>בלי עקיצות</b>.<br>\n        אתם חוזרים הביתה <b>רגועים</b>.\n      </p>\n      <p class=\"elora-bub__sub\">\n        כי ידעתם שנתתם לו הגנה מלאה\n        <span class=\"elora-bub__hl\">בלי לשים משהו על העור שלו</span>.\n      </p>\n    </div>\n  </div>\n\n  {%- comment -%} גבעות + בית + גחליליות {%- endcomment -%}\n  <div class=\"elora-bub__scene\" aria-hidden=\"true\">\n    <span class=\"elora-bub__fly\" style=\"right:16%; bottom:64px\"></span>\n    <span class=\"elora-bub__fly\" style=\"right:38%; bottom:96px; animation-delay:1.1s\"></span>\n    <span class=\"elora-bub__fly\" style=\"right:70%; bottom:72px; animation-delay:.5s\"></span>\n    <span class=\"elora-bub__fly\" style=\"right:85%; bottom:110px; animation-delay:1.6s\"></span>\n    <svg viewBox=\"0 0 1440 200\" preserveAspectRatio=\"none\">\n      <path d=\"M0,120 C240,70 480,150 720,110 C960,70 1200,140 1440,100 L1440,200 L0,200 Z\" fill=\"#9fce85\"/>\n      <path d=\"M0,160 C280,120 560,180 840,150 C1080,128 1280,170 1440,150 L1440,200 L0,200 Z\" fill=\"#7db863\"/>\n      <g transform=\"translate(660,58)\">\n        <ellipse cx=\"60\" cy=\"66\" rx=\"64\" ry=\"30\" fill=\"#ffd166\" opacity=\".14\"/>\n        <ellipse cx=\"60\" cy=\"66\" rx=\"40\" ry=\"20\" fill=\"#ffd166\" opacity=\".16\"/>\n        <rect x=\"22\" y=\"46\" width=\"76\" height=\"56\" rx=\"7\" fill=\"#f3e0bd\" stroke=\"#caa36e\" stroke-width=\"3\"/>\n        <path d=\"M12 50 L60 12 L108 50 Z\" fill=\"#e2795f\" stroke=\"#c65b44\" stroke-width=\"3\" stroke-linejoin=\"round\"/>\n        <rect x=\"46\" y=\"60\" width=\"28\" height=\"26\" rx=\"4\" fill=\"#ffd166\" stroke=\"#caa36e\" stroke-width=\"3\"/>\n        <path d=\"M60 60v26M46 73h28\" stroke=\"#caa36e\" stroke-width=\"2.6\"/>\n        <rect x=\"84\" y=\"20\" width=\"10\" height=\"18\" rx=\"2\" fill=\"#c65b44\"/>\n      </g>\n    </svg>\n  </div>\n\n  <span class=\"elora-bub__edge elora-bub__edge--bottom\" aria-hidden=\"true\"></span>\n</section>\n\n<style>\n  .elora-bub {\n    --bub-blue: #7fb0ff;\n    --bub-mint: #6fe89a;\n    --bub-accent: #2f5fd6;\n    --bub-edge: #ffffff;\n    position: relative;\n    font-family: inherit;\n    color: #e9eefb;\n    background: linear-gradient(180deg,\n      #060a16 0%, #10182f 16%, #2b2350 32%,\n      #6e4064 46%, #c97e63 57%, #ffd9ac 68%,\n      #fff0dc 80%, #fdeed8 100%);\n    overflow: hidden;\n    isolation: isolate;\n  }\n  .elora-bub *,\n  .elora-bub *::before,\n  .elora-bub *::after { box-sizing: border-box; }\n\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .elora-bub__edge {\n    position: absolute; left: 0; width: 100%; height: 22px; z-index: 6;\n    background: var(--bub-edge); pointer-events: none;\n  }\n  .elora-bub__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  .elora-bub__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n\n  /* כוכבים באזור הכהה */\n  .elora-bub__sky { position: absolute; inset: 0; z-index: 0; pointer-events: none; }\n  .elora-bub__sky i {\n    position: absolute; width: 4px; height: 4px; border-radius: 50%;\n    background: #dfe9ff; box-shadow: 0 0 8px rgba(200, 220, 255, .8);\n    animation: elora-tw 2.4s ease-in-out infinite;\n  }\n  @keyframes elora-tw { 0%,100%{opacity:.9; transform:scale(1)} 50%{opacity:.25; transform:scale(.7)} }\n\n  .elora-bub__inner {\n    position: relative; z-index: 2;\n    max-width: 640px; margin: 0 auto;\n    padding: 52px 22px 0;\n    display: flex; flex-direction: column; align-items: center;\n    text-align: center;\n    gap: clamp(16px, 3vw, 24px);\n  }\n\n  .elora-bub__kicker {\n    display: inline-flex; align-items: center; gap: 9px;\n    padding: 7px 17px; border-radius: 999px;\n    background: rgba(16, 26, 52, .66);\n    border: 1px solid rgba(127, 176, 255, .4);\n    box-shadow: 0 0 18px rgba(127, 176, 255, .18);\n    color: #dce8ff;\n    font-size: clamp(12px, 3.2vw, 15px); font-weight: 700; letter-spacing: .05em; white-space: nowrap;\n  }\n  .elora-bub__kicker i {\n    width: 7px; height: 7px; border-radius: 50%;\n    background: var(--bub-mint); box-shadow: 0 0 8px var(--bub-mint);\n    animation: elora-blink2 1.6s ease-in-out infinite;\n  }\n  @keyframes elora-blink2 { 0%,100%{opacity:1} 50%{opacity:.25} }\n\n  .elora-bub__headline {\n    margin: 0; max-width: 560px;\n    font-size: clamp(20px, 5vw, 29px); line-height: 1.45; font-weight: 800; color: #fff;\n  }\n  .elora-bub__headline b { color: var(--bub-mint); text-shadow: 0 0 18px rgba(111, 232, 154, .5); }\n\n  /* ===== הבמה של הבועה ===== */\n  .elora-bub__stage { position: relative; margin-top: 6px; }\n\n  .elora-bub__bubble {\n    position: relative;\n    width: min(310px, 72vw); height: min(310px, 72vw);\n    border-radius: 50%;\n    animation: elora-float 5.5s ease-in-out infinite;\n  }\n  @keyframes elora-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }\n\n  .elora-bub__bubble img {\n    position: absolute; inset: 10px;\n    width: calc(100% - 20px); height: calc(100% - 20px);\n    border-radius: 50%; object-fit: cover; display: block;\n  }\n\n  /* טבעת קשת־בענן מסתובבת */\n  .elora-bub__iris {\n    position: absolute; inset: 0; border-radius: 50%;\n    background: conic-gradient(from 20deg,\n      rgba(127,176,255,.85), rgba(255,190,220,.85),\n      rgba(180,240,200,.85), rgba(185,164,255,.85),\n      rgba(255,224,160,.8), rgba(127,176,255,.85));\n    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 9px), #000 calc(100% - 8px));\n            mask: radial-gradient(farthest-side, transparent calc(100% - 9px), #000 calc(100% - 8px));\n    animation: elora-iris 11s linear infinite;\n    filter: drop-shadow(0 0 18px rgba(160, 200, 255, .45));\n  }\n  @keyframes elora-iris { to { transform: rotate(360deg); } }\n\n  /* ברק בועת סבון */\n  .elora-bub__shine {\n    position: absolute; top: 8%; right: 14%;\n    width: 26%; height: 13%;\n    border-radius: 50%;\n    background: linear-gradient(180deg, rgba(255,255,255,.85), rgba(255,255,255,0));\n    transform: rotate(38deg);\n    pointer-events: none;\n  }\n\n  /* חלקיקי ריח במסלול */\n  .elora-bub__orbit {\n    position: absolute; inset: -14px; border-radius: 50%;\n    animation: elora-orbit 9s linear infinite;\n    pointer-events: none;\n  }\n  .elora-bub__orbit--2 { inset: -26px; animation-duration: 13s; animation-direction: reverse; }\n  .elora-bub__orbit--3 { inset: -6px; animation-duration: 7s; }\n  @keyframes elora-orbit { to { transform: rotate(360deg); } }\n  .elora-bub__orbit b {\n    position: absolute; top: -3px; left: 50%;\n    width: 9px; height: 9px; border-radius: 50%;\n    background: var(--bub-mint);\n    box-shadow: 0 0 12px rgba(111, 232, 154, .9);\n  }\n  .elora-bub__orbit--2 b { width: 7px; height: 7px; background: #ffd9ec; box-shadow: 0 0 10px rgba(255, 190, 220, .9); }\n  .elora-bub__orbit--3 b { width: 6px; height: 6px; background: #cfe2ff; box-shadow: 0 0 10px rgba(160, 200, 255, .9); }\n\n  /* תגית ציטרונלה */\n  .elora-bub__chip {\n    position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%);\n    display: inline-flex; align-items: center; gap: 7px;\n    padding: 8px 16px; border-radius: 999px;\n    background: rgba(10, 26, 16, .78);\n    border: 1px solid rgba(111, 232, 154, .55);\n    box-shadow: 0 0 16px rgba(111, 232, 154, .3);\n    color: var(--bub-mint);\n    font-size: clamp(12px, 3.3vw, 15px); font-weight: 800; white-space: nowrap;\n    z-index: 3;\n  }\n  .elora-bub__chip svg { width: 16px; height: 16px; }\n\n  /* יתושים מבולבלים */\n  .elora-bub__wing { transform-box: fill-box; transform-origin: bottom center; }\n  .elora-bub__wing--a { animation: elora-flap2 .16s ease-in-out infinite alternate; }\n  .elora-bub__wing--b { animation: elora-flap2 .16s ease-in-out infinite alternate-reverse; }\n  @keyframes elora-flap2 { from { transform: rotate(-4deg) scaleY(1); } to { transform: rotate(10deg) scaleY(.62); } }\n\n  .elora-bub__lost { position: absolute; width: 52px; pointer-events: none; filter: drop-shadow(0 3px 8px rgba(0,0,0,.4)); }\n  .elora-bub__lost svg { width: 100%; height: auto; display: block; }\n  .elora-bub__lost em {\n    position: absolute; top: -20px; right: 4px;\n    font-style: normal; font-weight: 900;\n    font-size: 21px; color: #ffd166;\n    text-shadow: 0 0 10px rgba(255, 209, 102, .7);\n    animation: elora-q 1.8s ease-in-out infinite;\n  }\n  @keyframes elora-q { 0%,100%{transform:translateY(0) rotate(-8deg); opacity:.95} 50%{transform:translateY(-6px) rotate(8deg); opacity:.6} }\n  .elora-bub__lost--r { top: 6%; right: -58px; animation: elora-lost-r 7s ease-in-out infinite; }\n  .elora-bub__lost--r svg { transform: scaleX(-1); }\n  .elora-bub__lost--l { bottom: 16%; left: -54px; width: 42px; animation: elora-lost-l 8.5s ease-in-out infinite; }\n  @keyframes elora-lost-r {\n    0%,100% { transform: translate(0,0) rotate(-6deg); }\n    25%     { transform: translate(-14px,12px) rotate(8deg); }\n    50%     { transform: translate(10px,22px) rotate(-10deg) scale(.96); }\n    75%     { transform: translate(-6px,6px) rotate(5deg); }\n  }\n  @keyframes elora-lost-l {\n    0%,100% { transform: translate(0,0) rotate(7deg); }\n    30%     { transform: translate(16px,-10px) rotate(-8deg); }\n    60%     { transform: translate(-8px,-20px) rotate(10deg) scale(.95); }\n  }\n\n  /* ===== הסבר ===== */\n  .elora-bub__explain {\n    margin: 10px 0 0; max-width: 540px;\n    font-size: clamp(17px, 4.2vw, 22px); line-height: 1.6; font-weight: 500; color: #f2e9ff;\n  }\n  .elora-bub__explain b { color: var(--bub-blue); font-weight: 800; text-shadow: 0 0 16px rgba(127, 176, 255, .45); }\n  .elora-bub__skin { font-weight: 800; color: #fff; }\n\n  /* ===== 3 צעדים ===== */\n  .elora-bub__steps {\n    display: flex; flex-wrap: wrap; justify-content: center;\n    gap: clamp(8px, 2.4vw, 14px);\n  }\n  .elora-bub__step {\n    display: inline-flex; align-items: center; gap: 8px;\n    padding: 8px 14px; border-radius: 999px;\n    background: rgba(255, 250, 240, .82);\n    border: 1px solid rgba(120, 90, 60, .18);\n    box-shadow: 0 6px 16px rgba(90, 60, 30, .14);\n    color: #4a3a2c;\n    font-size: clamp(12.5px, 3.3vw, 15px); font-weight: 700; white-space: nowrap;\n  }\n  .elora-bub__step b {\n    width: 22px; height: 22px; border-radius: 50%; flex: none;\n    display: inline-flex; align-items: center; justify-content: center;\n    background: var(--bub-accent); color: #fff;\n    font-size: 12.5px; font-weight: 900;\n  }\n\n  /* ===== נחיתה הביתה ===== */\n  .elora-bub__home { margin-top: clamp(8px, 2.4vw, 18px); }\n  .elora-bub__lead {\n    margin: 0 0 12px;\n    font-size: clamp(23px, 5.6vw, 32px); line-height: 1.4; font-weight: 900; color: #3d2f24;\n  }\n  .elora-bub__lead b { color: #1f7a3d; }\n  .elora-bub__sub {\n    margin: 0; max-width: 500px;\n    font-size: clamp(16px, 4vw, 20px); line-height: 1.65; font-weight: 600; color: #5a4735;\n  }\n  .elora-bub__hl {\n    position: relative; white-space: nowrap; padding-bottom: 2px;\n    font-weight: 800; color: var(--bub-accent);\n  }\n  .elora-bub__hl::after {\n    content: \"\"; position: absolute; right: 0; left: 0; bottom: -5px; height: 7px;\n    background:\n      linear-gradient(var(--bub-accent), var(--bub-accent)) top/100% 2.5px no-repeat,\n      linear-gradient(var(--bub-accent), var(--bub-accent)) bottom/100% 2.5px no-repeat;\n    border-radius: 2px; opacity: .95;\n  }\n\n  /* ===== הסצנה: גבעות + בית + גחליליות ===== */\n  .elora-bub__scene { position: relative; z-index: 1; margin-top: -6px; }\n  .elora-bub__scene svg { display: block; width: 100%; height: clamp(120px, 22vw, 190px); }\n  .elora-bub__fly {\n    position: absolute; z-index: 2;\n    width: 6px; height: 6px; border-radius: 50%;\n    background: #ffe08a; box-shadow: 0 0 10px rgba(255, 224, 138, .95);\n    animation: elora-fly-tw 2.6s ease-in-out infinite;\n  }\n  @keyframes elora-fly-tw {\n    0%,100% { opacity: .95; transform: translate(0,0); }\n    50%     { opacity: .2;  transform: translate(4px,-7px); }\n  }\n\n  /* ===== Reveal ===== */\n  [data-reveal] { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }\n  [data-reveal].is-visible { opacity: 1; transform: none; }\n  .elora-bub__chip[data-reveal] { transform: translateX(-50%) translateY(20px); }\n  .elora-bub__chip[data-reveal].is-visible { transform: translateX(-50%); }\n\n  @media (prefers-reduced-motion: reduce) {\n    [data-reveal] { opacity: 1; transform: none; transition: none; }\n    .elora-bub__chip[data-reveal] { transform: translateX(-50%); }\n    .elora-bub__bubble, .elora-bub__iris, .elora-bub__orbit,\n    .elora-bub__lost, .elora-bub__lost em, .elora-bub__wing,\n    .elora-bub__sky i, .elora-bub__fly, .elora-bub__kicker i { animation: none; }\n  }\n</style>\n\n<script>\n  (function () {\n    var roots = document.querySelectorAll('.elora-bub');\n    Array.prototype.forEach.call(roots, function (root) {\n      if (root.dataset.eloraInit) return;\n      root.dataset.eloraInit = '1';\n\n      var items = [].slice.call(root.querySelectorAll('[data-reveal]'));\n      if (!items.length) return;\n\n      if (!('IntersectionObserver' in window) ||\n          (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {\n        items.forEach(function (el) { el.classList.add('is-visible'); });\n        return;\n      }\n\n      var io = new IntersectionObserver(function (entries) {\n        entries.forEach(function (entry) {\n          if (entry.isIntersecting) {\n            var el = entry.target;\n            var i = items.indexOf(el);\n            el.style.transitionDelay = (Math.max(0, i) * 130) + 'ms';\n            el.classList.add('is-visible');\n            io.unobserve(el);\n          }\n        });\n      }, { threshold: 0.18 });\n\n      items.forEach(function (el) { io.observe(el); });\n    });\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 20
      }
    },
    "custom_liquid_aDLQMc": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  ELORA – \"תעודת הזהות של המדבקה\" — המוצר במרכז + 4 בלוקים\n  ------------------------------------------------------------\n  • המוצר באמצע (מסגרת מדבקה עם פינה מקופלת), 4 כרטיסים\n    מסביבו מחוברים אליו בקווים מנוקדים \"זורמים\".\n  • מיקומים לפי הקופי: 1 שמאל־למעלה, 2 ימין־למעלה,\n    3 שמאל־למטה, 4 ימין־למטה. בנייד: המוצר למעלה\n    והכרטיסים נערמים לפי הסדר 1→4.\n  • לחיבור הפאזל: Padding → Top = 0 בבלוק הזה,\n    Padding → Bottom = 0 בבלוק שמעליו.\n  ★ תמונת המוצר = ממלא־מקום זמני. החליפו כאן:\n  ============================================================\n{%- endcomment -%}\n\n{%- comment -%} ←←← תמונת המדבקה/המוצר (זמנית) — החליפו כאן ←←← {%- endcomment -%}\n{%- assign img_product = \"https://cdn.shopify.com/s/files/1/0825/1296/9956/files/idcard-C-cartoon.webp?v=1783331166\" -%}\n\n<section class=\"elora-pid\" dir=\"rtl\">\n\n  <span class=\"elora-pid__edge elora-pid__edge--top\" aria-hidden=\"true\"></span>\n\n  {%- comment -%} עננים רכים {%- endcomment -%}\n  <span class=\"elora-pid__cloud elora-pid__cloud--1\" aria-hidden=\"true\"></span>\n  <span class=\"elora-pid__cloud elora-pid__cloud--2\" aria-hidden=\"true\"></span>\n\n  <div class=\"elora-pid__inner\">\n\n    <span class=\"elora-pid__kicker\" data-reveal><i></i>תעודת הזהות של המדבקה</span>\n    <h2 class=\"elora-pid__headline\" data-reveal>כל מה שחשוב לדעת  במבט אחד</h2>\n\n    <div class=\"elora-pid__grid\">\n\n      {%- comment -%} קווים מנוקדים (מחשב בלבד) {%- endcomment -%}\n      <svg class=\"elora-pid__links\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n        <path d=\"M25,31 Q35,39 44,46\" class=\"elora-pid__link elora-pid__link--blue\"/>\n        <path d=\"M75,31 Q65,39 56,46\" class=\"elora-pid__link elora-pid__link--green\"/>\n        <path d=\"M25,69 Q35,61 44,54\" class=\"elora-pid__link elora-pid__link--purple\"/>\n        <path d=\"M75,69 Q65,61 56,54\" class=\"elora-pid__link elora-pid__link--orange\"/>\n      </svg>\n\n      {%- comment -%} ===== המוצר במרכז ===== {%- endcomment -%}\n      <div class=\"elora-pid__product\" data-reveal>\n        <div class=\"elora-pid__sticker\">\n          <img src=\"{{ img_product }}\" alt=\"מדבקת ELORA נגד יתושים\" loading=\"lazy\">\n          <span class=\"elora-pid__peel\" aria-hidden=\"true\"></span>\n        </div>\n        <span class=\"elora-pid__spark elora-pid__spark--1\" aria-hidden=\"true\">✦</span>\n        <span class=\"elora-pid__spark elora-pid__spark--2\" aria-hidden=\"true\">✦</span>\n      </div>\n\n      {%- comment -%} ===== 1 — הדבר הכי חשוב (שמאל למעלה) ===== {%- endcomment -%}\n      <article class=\"elora-pid__card elora-pid__card--tl elora-pid__card--hero\" data-reveal>\n        <span class=\"elora-pid__num elora-pid__num--blue\">1</span>\n        <span class=\"elora-pid__star\">★ הכי חשוב</span>\n        <span class=\"elora-pid__icon elora-pid__icon--blue\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 4L4 7l2 4 2-1v9h8v-9l2 1 2-4-5-3a3.5 3.5 0 0 1-6 0z\"/><rect x=\"10.4\" y=\"11\" width=\"5\" height=\"5\" rx=\"1.2\" fill=\"rgba(47,95,214,.15)\"/></svg>\n        </span>\n        <h3>מדביקים על הבגד  לא על הילד</h3>\n        <p>עור הילד לא בא במגע <b>עם שום דבר</b>.</p>\n      </article>\n\n      {%- comment -%} ===== 2 — מרכיבים (ימין למעלה) ===== {%- endcomment -%}\n      <article class=\"elora-pid__card elora-pid__card--tr\" data-reveal>\n        <span class=\"elora-pid__num elora-pid__num--green\">2</span>\n        <span class=\"elora-pid__icon elora-pid__icon--green\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 19c7 1 13-4 14-13-9 1-14 6-14 13z\"/><path d=\"M5 19c2.5-5 6-8.5 10-10.5\"/></svg>\n        </span>\n        <h3>מה יש בפנים?</h3>\n       <ul>\n          <li>שמן ציטרונלה טבעי</li>\n          <li>שמן אקליפטוס טבעי</li>\n          <li>שמן לימון גראס טבעי</li>\n          <li>סרט דבק בדרגה רפואית <b>מגיל 0</b></li>\n        </ul>\n      </article>\n\n      {%- comment -%} ===== 3 — איך זה עובד (שמאל למטה) ===== {%- endcomment -%}\n      <article class=\"elora-pid__card elora-pid__card--bl\" data-reveal>\n        <span class=\"elora-pid__num elora-pid__num--purple\">3</span>\n        <span class=\"elora-pid__icon elora-pid__icon--purple\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><path d=\"M12 4.5a7.5 7.5 0 0 1 7.5 7.5M12 2a10 10 0 0 1 10 10\" opacity=\".55\"/><path d=\"M12 19.5A7.5 7.5 0 0 1 4.5 12M12 22A10 10 0 0 1 2 12\" opacity=\".55\"/></svg>\n        </span>\n        <h3>איך זה עובד?</h3>\n        <p>יתושים מנווטים לפי ריח.<br> הציטרונלה יוצרת <b>בועת הגנה</b> שמסתירה את הילד מהם <b>בלי לגעת בו</b>.</p>\n      </article>\n\n      {%- comment -%} ===== 4 — כמות ותזמון (ימין למטה) ===== {%- endcomment -%}\n      <article class=\"elora-pid__card elora-pid__card--br\" data-reveal>\n        <span class=\"elora-pid__num elora-pid__num--orange\">4</span>\n        <span class=\"elora-pid__icon elora-pid__icon--orange\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.9\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"8.5\"/><path d=\"M12 7.5V12l3 2\"/></svg>\n        </span>\n        <h3>כמה מדבקות?</h3>\n        <div class=\"elora-pid__dose\">\n          <div class=\"elora-pid__row\">\n            <span class=\"elora-pid__age\">גיל 0–2</span>\n            <span class=\"elora-pid__mini\"><b></b></span>\n            <span class=\"elora-pid__note\">אחת על הגב</span>\n          </div>\n          <div class=\"elora-pid__row\">\n            <span class=\"elora-pid__age\">גיל 3–5</span>\n            <span class=\"elora-pid__mini\"><b></b><b></b></span>\n            <span class=\"elora-pid__note\">2 מדבקות</span>\n          </div>\n          <div class=\"elora-pid__row\">\n            <span class=\"elora-pid__age\">גיל 6+</span>\n            <span class=\"elora-pid__mini\"><b></b><b></b><b></b><b></b></span>\n            <span class=\"elora-pid__note\">עד 4</span>\n          </div>\n        </div>\n        <p class=\"elora-pid__clock\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"12\" cy=\"12\" r=\"8.5\"/><path d=\"M12 7.5V12l3 2\"/></svg>\n          מחליפים כל <b>8 שעות</b>\n        </p>\n      </article>\n\n    </div>\n  </div>\n\n  <span class=\"elora-pid__edge elora-pid__edge--bottom\" aria-hidden=\"true\"></span>\n</section>\n\n<style>\n  .elora-pid {\n    --pid-blue: #2f5fd6;\n    --pid-green: #2fa84f;\n    --pid-purple: #8a6fd8;\n    --pid-orange: #f2933c;\n    --pid-text: #22304a;\n    --pid-edge: #ffffff;\n    position: relative;\n    font-family: inherit;\n    color: var(--pid-text);\n    background: linear-gradient(180deg, #fff6e9 0%, #eef6ff 34%, #f6fbff 100%);\n    overflow: hidden;\n    isolation: isolate;\n  }\n  .elora-pid *,\n  .elora-pid *::before,\n  .elora-pid *::after { box-sizing: border-box; }\n\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .elora-pid__edge {\n    position: absolute; left: 0; width: 100%; height: 22px; z-index: 6;\n    background: var(--pid-edge); pointer-events: none;\n  }\n  .elora-pid__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  .elora-pid__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n\n  /* עננים */\n  .elora-pid__cloud {\n    position: absolute; z-index: 0;\n    background: #ffffff; border-radius: 60px; opacity: .8;\n    filter: drop-shadow(0 6px 12px rgba(140, 170, 200, .12));\n  }\n  .elora-pid__cloud::before, .elora-pid__cloud::after {\n    content: \"\"; position: absolute; background: #fff; border-radius: 50%;\n  }\n  .elora-pid__cloud--1 { top: 44px; right: 8%; width: 84px; height: 24px; }\n  .elora-pid__cloud--1::before { width: 36px; height: 36px; top: -16px; right: 12px; }\n  .elora-pid__cloud--1::after  { width: 26px; height: 26px; top: -10px; right: 42px; }\n  .elora-pid__cloud--2 { top: 90px; left: 6%; width: 64px; height: 19px; opacity: .65; }\n  .elora-pid__cloud--2::before { width: 28px; height: 28px; top: -12px; left: 10px; }\n  .elora-pid__cloud--2::after  { width: 20px; height: 20px; top: -8px; left: 34px; }\n\n  .elora-pid__inner {\n    position: relative; z-index: 2;\n    max-width: 880px; margin: 0 auto;\n    padding: 54px 20px 56px;\n    display: flex; flex-direction: column; align-items: center;\n    text-align: center;\n  }\n\n  .elora-pid__kicker {\n    display: inline-flex; align-items: center; gap: 8px;\n    padding: 7px 17px; border-radius: 999px;\n    background: #ffffff;\n    border: 1px solid rgba(47, 95, 214, .22);\n    box-shadow: 0 4px 14px rgba(47, 95, 214, .1);\n    color: var(--pid-blue);\n    font-size: clamp(12px, 3.2vw, 15px); font-weight: 800; letter-spacing: .04em; white-space: nowrap;\n  }\n  .elora-pid__kicker i {\n    width: 7px; height: 7px; border-radius: 50%;\n    background: var(--pid-blue); box-shadow: 0 0 6px rgba(47, 95, 214, .6);\n  }\n\n  .elora-pid__headline {\n    margin: 14px 0 30px;\n    font-size: clamp(21px, 5.2vw, 30px); line-height: 1.35; font-weight: 900;\n  }\n\n  /* ===== הגריד ===== */\n  .elora-pid__grid {\n    position: relative;\n    display: grid;\n    width: 100%;\n    grid-template-columns: 1fr minmax(190px, 240px) 1fr;\n    grid-template-areas:\n      \"tr prod tl\"\n      \"br prod bl\";   /* RTL: העמודה הראשונה = ימין */\n    gap: clamp(16px, 3vw, 26px);\n    align-items: center;\n  }\n\n  /* קווים מנוקדים */\n  .elora-pid__links { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }\n  .elora-pid__link {\n    fill: none; stroke-width: 2.4;\n    vector-effect: non-scaling-stroke;\n    stroke-linecap: round;\n    stroke-dasharray: 0.1 4;\n    animation: elora-march 1.3s linear infinite;\n    opacity: .6;\n  }\n  @keyframes elora-march { to { stroke-dashoffset: -4.1; } }\n  .elora-pid__link--blue   { stroke: var(--pid-blue); }\n  .elora-pid__link--green  { stroke: var(--pid-green); }\n  .elora-pid__link--purple { stroke: var(--pid-purple); }\n  .elora-pid__link--orange { stroke: var(--pid-orange); }\n\n  /* ===== המוצר ===== */\n  .elora-pid__product { grid-area: prod; position: relative; z-index: 2; justify-self: center; }\n  .elora-pid__sticker {\n    position: relative;\n    width: min(230px, 58vw);\n    padding: 10px;\n    background: #ffffff;\n    border-radius: 24px;\n    box-shadow: 0 18px 40px rgba(50, 80, 140, .18), 0 0 0 1px rgba(47, 95, 214, .07);\n    transform: rotate(-2.5deg);\n    animation: elora-float-p 5.5s ease-in-out infinite;\n  }\n  @keyframes elora-float-p { 0%,100%{transform:rotate(-2.5deg) translateY(0)} 50%{transform:rotate(-2.5deg) translateY(-9px)} }\n  .elora-pid__sticker img {\n    width: 100%; aspect-ratio: 1 / 1; object-fit: cover;\n    border-radius: 16px; display: block;\n  }\n  /* פינה מקופלת */\n  .elora-pid__peel {\n    position: absolute; bottom: -1px; left: -1px;\n    width: 34px; height: 34px;\n    background: linear-gradient(45deg, #ffffff 48%, #dfe8f5 52%, #c9d6ea 100%);\n    border-radius: 0 22px 0 22px;\n    box-shadow: -3px -3px 8px rgba(50, 80, 140, .14);\n  }\n  .elora-pid__spark {\n    position: absolute; color: #ffc94d; font-style: normal;\n    text-shadow: 0 0 10px rgba(255, 201, 77, .7);\n    animation: elora-spark-tw 2.4s ease-in-out infinite;\n  }\n  .elora-pid__spark--1 { top: -16px; right: -8px; font-size: 20px; }\n  .elora-pid__spark--2 { bottom: -6px; right: 22px; font-size: 13px; animation-delay: 1.1s; }\n  @keyframes elora-spark-tw { 0%,100%{opacity:1; transform:scale(1) rotate(0)} 50%{opacity:.35; transform:scale(.75) rotate(20deg)} }\n\n  /* ===== כרטיסים ===== */\n  .elora-pid__card {\n    position: relative; z-index: 2;\n    background: #ffffff;\n    border: 1px solid rgba(60, 90, 140, .1);\n    border-radius: 20px;\n    box-shadow: 0 12px 28px rgba(50, 80, 140, .1);\n    padding: 20px 18px 18px;\n    text-align: right;\n  }\n  .elora-pid__card--tl { grid-area: tl; transform: rotate(-1.2deg); }\n  .elora-pid__card--tr { grid-area: tr; transform: rotate(1.2deg); }\n  .elora-pid__card--bl { grid-area: bl; transform: rotate(1deg); }\n  .elora-pid__card--br { grid-area: br; transform: rotate(-1.2deg); }\n\n  .elora-pid__card--hero {\n    border: 2px solid rgba(47, 95, 214, .35);\n    box-shadow: 0 14px 32px rgba(47, 95, 214, .16);\n  }\n  .elora-pid__star {\n    position: absolute; top: -11px; right: 16px;\n    padding: 3px 11px; border-radius: 999px;\n    background: var(--pid-blue); color: #fff;\n    font-size: 11.5px; font-weight: 800; letter-spacing: .02em;\n    box-shadow: 0 4px 10px rgba(47, 95, 214, .35);\n  }\n\n  .elora-pid__num {\n    position: absolute; top: -13px; left: 14px;\n    width: 27px; height: 27px; border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    color: #fff; font-size: 14px; font-weight: 900;\n    border: 2.5px solid #fff;\n    box-shadow: 0 4px 10px rgba(50, 80, 140, .22);\n  }\n  .elora-pid__num--blue   { background: var(--pid-blue); }\n  .elora-pid__num--green  { background: var(--pid-green); }\n  .elora-pid__num--purple { background: var(--pid-purple); }\n  .elora-pid__num--orange { background: var(--pid-orange); }\n\n  .elora-pid__icon {\n    display: inline-flex; align-items: center; justify-content: center;\n    width: 42px; height: 42px; border-radius: 13px; margin-bottom: 10px;\n  }\n  .elora-pid__icon svg { width: 24px; height: 24px; }\n  .elora-pid__icon--blue   { background: rgba(47, 95, 214, .1);  color: var(--pid-blue); }\n  .elora-pid__icon--green  { background: rgba(47, 168, 79, .12); color: var(--pid-green); }\n  .elora-pid__icon--purple { background: rgba(138, 111, 216, .13); color: var(--pid-purple); }\n  .elora-pid__icon--orange { background: rgba(242, 147, 60, .14); color: var(--pid-orange); }\n\n  .elora-pid__card h3 {\n    margin: 0 0 7px;\n    font-size: clamp(15.5px, 4vw, 18px); line-height: 1.35; font-weight: 800;\n    color: var(--pid-text);\n  }\n  .elora-pid__card p { margin: 0; font-size: clamp(13.5px, 3.6vw, 15.5px); line-height: 1.6; color: #4c5c78; font-weight: 500; }\n  .elora-pid__card p b { color: var(--pid-blue); font-weight: 800; }\n  .elora-pid__card--bl p b { color: var(--pid-purple); }\n\n  .elora-pid__card ul { margin: 0; padding: 0; list-style: none; }\n  .elora-pid__card ul li {\n    position: relative; padding-right: 22px; margin-bottom: 5px;\n    font-size: clamp(13.5px, 3.6vw, 15.5px); line-height: 1.55; color: #4c5c78; font-weight: 600;\n  }\n  .elora-pid__card ul li::before {\n    content: \"✓\"; position: absolute; right: 0; top: 0;\n    color: var(--pid-green); font-weight: 900;\n  }\n  .elora-pid__card ul li b { color: var(--pid-green); font-weight: 800; }\n\n  /* מינון */\n  .elora-pid__dose { display: flex; flex-direction: column; gap: 7px; margin-bottom: 10px; }\n  .elora-pid__row {\n    display: flex; align-items: center; gap: 8px;\n    background: #f6f9ff; border: 1px solid rgba(60, 90, 140, .08);\n    border-radius: 11px; padding: 6px 10px;\n  }\n  .elora-pid__age { font-size: clamp(12.5px, 3.3vw, 14px); font-weight: 800; color: var(--pid-text); white-space: nowrap; min-width: 54px; }\n  .elora-pid__mini { display: inline-flex; gap: 3px; }\n  .elora-pid__mini b {\n    width: 13px; height: 13px; border-radius: 4px;\n    background: linear-gradient(160deg, #7fb0ff, #2f5fd6);\n    border: 2px solid #fff;\n    box-shadow: 0 2px 5px rgba(47, 95, 214, .3);\n  }\n  .elora-pid__note { font-size: clamp(11.5px, 3vw, 13px); color: #6b7a95; font-weight: 600; margin-inline-start: auto; white-space: nowrap; }\n\n  .elora-pid__clock {\n    display: inline-flex; align-items: center; gap: 7px;\n    margin: 0; padding: 7px 13px;\n    background: rgba(47, 168, 79, .1);\n    border: 1px solid rgba(47, 168, 79, .3);\n    border-radius: 999px;\n    color: #1f7a3d; font-size: clamp(12.5px, 3.3vw, 14.5px); font-weight: 800;\n  }\n  .elora-pid__clock svg { width: 16px; height: 16px; flex: none; }\n  .elora-pid__clock b { font-weight: 900; }\n\n  /* ===== נייד ===== */\n  @media (max-width: 760px) {\n    .elora-pid__grid {\n      grid-template-columns: 1fr;\n      grid-template-areas: \"prod\" \"tl\" \"tr\" \"bl\" \"br\";\n      gap: 22px;\n    }\n    .elora-pid__links { display: none; }\n    .elora-pid__card,\n    .elora-pid__card--tl, .elora-pid__card--tr,\n    .elora-pid__card--bl, .elora-pid__card--br { transform: none; }\n    .elora-pid__product { margin-bottom: 4px; }\n  }\n\n  /* ===== Reveal ===== */\n  [data-reveal] { opacity: 0; translate: 0 20px; transition: opacity .55s ease, translate .55s ease; }\n  [data-reveal].is-visible { opacity: 1; translate: 0 0; }\n\n  @media (prefers-reduced-motion: reduce) {\n    [data-reveal] { opacity: 1; translate: none; transition: none; }\n    .elora-pid__sticker, .elora-pid__spark, .elora-pid__link { animation: none; }\n  }\n</style>\n\n<script>\n  (function () {\n    var roots = document.querySelectorAll('.elora-pid');\n    Array.prototype.forEach.call(roots, function (root) {\n      if (root.dataset.eloraInit) return;\n      root.dataset.eloraInit = '1';\n\n      var items = [].slice.call(root.querySelectorAll('[data-reveal]'));\n      if (!items.length) return;\n\n      if (!('IntersectionObserver' in window) ||\n          (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {\n        items.forEach(function (el) { el.classList.add('is-visible'); });\n        return;\n      }\n\n      var io = new IntersectionObserver(function (entries) {\n        entries.forEach(function (entry) {\n          if (entry.isIntersecting) {\n            var el = entry.target;\n            var i = items.indexOf(el);\n            el.style.transitionDelay = (Math.max(0, i) * 110) + 'ms';\n            el.classList.add('is-visible');\n            io.unobserve(el);\n          }\n        });\n      }, { threshold: 0.15 });\n\n      items.forEach(function (el) { io.observe(el); });\n    });\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 16
      }
    },
    "custom_liquid_cjXRLU": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  LOREN – סקשן אחריות \"14 ימי ניסיון\" (v2 — צבעים + motion)\n  ------------------------------------------------------------\n  מיקום מומלץ: סקשן Custom Liquid נמוך בדף.\n  • לחיבור הפאזל: Padding → Top = 0 בבלוק הזה,\n    Padding → Bottom = 0 בבלוק שמעליו.\n  Motion כלול: מונה 14, פעימת מגן, הופעה מדורגת,\n  ציור ה-✓, כניסת pills בקפיצה. הכל מכבד prefers-reduced-motion.\n  ============================================================\n{%- endcomment -%}\n\n<section class=\"loren-grnt\" dir=\"rtl\" id=\"lorenGrnt\">\n  <span class=\"loren-grnt__edge loren-grnt__edge--top\" aria-hidden=\"true\"></span>\n  <span class=\"loren-grnt__edge loren-grnt__edge--bottom\" aria-hidden=\"true\"></span>\n\n  <div class=\"loren-grnt__inner\">\n\n    <div class=\"loren-grnt__badge\" data-gr-reveal aria-hidden=\"true\">\n      <span class=\"loren-grnt__pulse\"></span>\n      <span class=\"loren-grnt__pulse loren-grnt__pulse--2\"></span>\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <path d=\"M12 2.5l7.5 3.2v5.1c0 5-3.2 8.6-7.5 10.7-4.3-2.1-7.5-5.7-7.5-10.7V5.7z\"/>\n        <path class=\"loren-grnt__check\" d=\"M8.6 12.2l2.3 2.3 4.5-4.7\"/>\n      </svg>\n      <span class=\"loren-grnt__badge-days\" id=\"lorenGrntDays\">0</span>\n    </div>\n\n    <p class=\"loren-grnt__kicker\" data-gr-reveal>בלי סיכון. באחריות שלנו.</p>\n\n    <h2 class=\"loren-grnt__title\" data-gr-reveal>\n      14 ימי ניסיון  <span class=\"loren-grnt__hl\">ואם זה לא עובד, מקבלים החזר כספי.</span>\n    </h2>\n\n    <p class=\"loren-grnt__text\" data-gr-reveal>\n      אנחנו יודעים שזה נשמע כמעט טוב מדי, ולכן ההתחייבות עלינו:\n      נסו את המדבקות על הילד <b>14 יום</b>.<br>\n      אם לא הרגשתם הבדל, או שהמדבקות פשוט לא עשו את העבודה\n      מחזירים לנו את המדבקות שנשארו ומקבלים <b>החזר כספי</b>.<br> בלי טפסים מסובכים ובלי שאלות מיותרות.\n    </p>\n\n    <ul class=\"loren-grnt__points\" data-gr-reveal>\n      <li class=\"loren-grnt__pill\">\n        <span class=\"loren-grnt__pt-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12l5 5L20 7\"/></svg>\n        </span>\n        מנסים בשטח, בגינה או  בטיול.\n      </li>\n      <li class=\"loren-grnt__pill\">\n        <span class=\"loren-grnt__pt-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12l5 5L20 7\"/></svg>\n        </span>\n        לא מרוצים? מחזירים את מה שנשאר\n      </li>\n      <li class=\"loren-grnt__pill\">\n        <span class=\"loren-grnt__pt-ic\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12l5 5L20 7\"/></svg>\n        </span>\n        מקבלים החזר כספי\n      </li>\n    </ul>\n\n    <p class=\"loren-grnt__foot\" data-gr-reveal>\n      כל הסיכון עלינו. כי אנחנו יודעים מה יקרה אחרי הלילה הראשון בחוץ.\n    </p>\n\n  </div>\n</section>\n\n<style>\n  .loren-grnt {\n    --gr-accent: #2f5fd6;      /* כחול המותג */\n    --gr-green: #2fa84f;       /* ירוק ל-✓ ולנקודות חיוביות */\n    --gr-text: #22303e;\n    --gr-edge: #ffffff;\n    position: relative;\n    font-family: inherit;\n    color: var(--gr-text);\n    /* ממשיך מהתכלת של סוף \"תעודת הזהות\" ומתערבב בהדרגה לקרם/אפרסק */\n    background: linear-gradient(180deg, #e3f2fd 0%, #ecf2ec 30%, #f7eedd 62%, #fdf3e7 100%);\n    padding: 56px 0 60px;\n    overflow: hidden;\n    isolation: isolate;\n  }\n  .loren-grnt *,\n  .loren-grnt *::before,\n  .loren-grnt *::after { box-sizing: border-box; }\n\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .loren-grnt__edge {\n    position: absolute; left: 0; width: 100%; height: 22px; z-index: 2;\n    background: var(--gr-edge); pointer-events: none;\n  }\n  .loren-grnt__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  .loren-grnt__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n\n  .loren-grnt__inner {\n    position: relative; z-index: 1;\n    max-width: 600px;\n    margin: 0 auto;\n    padding: 0 22px;\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 14px;\n  }\n\n  /* ===== מגן עם 14 + פעימת הגנה ===== */\n  .loren-grnt__badge {\n    position: relative;\n    width: 88px; height: 88px;\n    color: var(--gr-accent);\n    margin-bottom: 4px;\n  }\n  .loren-grnt__badge svg { position: relative; z-index: 2; width: 100%; height: 100%; display: block; }\n\n  /* טבעות פעימה */\n  .loren-grnt__pulse {\n    position: absolute;\n    inset: 8px;\n    border-radius: 50%;\n    border: 2px solid rgba(47, 95, 214, .35);\n    opacity: 0;\n    z-index: 1;\n    pointer-events: none;\n  }\n  .is-inview .loren-grnt__pulse { animation: loren-gr-pulse 3.2s ease-out infinite; }\n  .is-inview .loren-grnt__pulse--2 { animation-delay: 1.6s; }\n  @keyframes loren-gr-pulse {\n    0%   { transform: scale(.75); opacity: 0; }\n    18%  { opacity: .8; }\n    100% { transform: scale(1.65); opacity: 0; }\n  }\n\n  /* ה-✓ מצייר את עצמו */\n  .loren-grnt__check {\n    stroke-dasharray: 12;\n    stroke-dashoffset: 12;\n    stroke: var(--gr-green);\n    stroke-width: 2.2;\n  }\n  .is-inview .loren-grnt__check { animation: loren-gr-draw .7s ease-out .9s forwards; }\n  @keyframes loren-gr-draw { to { stroke-dashoffset: 0; } }\n\n  .loren-grnt__badge-days {\n    position: absolute;\n    top: -6px; right: -12px;\n    z-index: 3;\n    min-width: 36px; height: 36px;\n    padding: 0 7px;\n    border-radius: 999px;\n    background: var(--gr-accent);\n    color: #fff;\n    font-size: 17px; font-weight: 900;\n    display: flex; align-items: center; justify-content: center;\n    box-shadow: 0 6px 14px rgba(47, 95, 214, .35);\n    border: 2px solid #fff;\n    font-variant-numeric: tabular-nums;\n  }\n\n  .loren-grnt__kicker {\n    margin: 0;\n    font-size: clamp(13px, 3.4vw, 15px);\n    font-weight: 800;\n    letter-spacing: .05em;\n    color: var(--gr-accent);\n  }\n\n  .loren-grnt__title {\n    margin: 0;\n    max-width: 540px;\n    font-size: clamp(22px, 5.4vw, 31px);\n    line-height: 1.35;\n    font-weight: 800;\n    letter-spacing: -0.2px;\n  }\n  .loren-grnt__hl { color: var(--gr-accent); }\n\n  .loren-grnt__text {\n    margin: 0;\n    max-width: 520px;\n    font-size: clamp(16px, 4vw, 19px);\n    line-height: 1.75;\n    font-weight: 500;\n    color: #45525f;\n  }\n  .loren-grnt__text b { font-weight: 800; color: var(--gr-text); }\n\n  /* ===== pills ===== */\n  .loren-grnt__points {\n    list-style: none;\n    margin: 6px 0 0;\n    padding: 0;\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 8px;\n  }\n  .loren-grnt__pill {\n    display: inline-flex;\n    align-items: center;\n    gap: 7px;\n    padding: 9px 15px;\n    background: #ffffff;\n    border: 1px solid rgba(47, 95, 214, .16);\n    border-radius: 999px;\n    font-size: clamp(12.5px, 3.4vw, 14.5px);\n    font-weight: 700;\n    color: var(--gr-text);\n    box-shadow: 0 5px 14px rgba(120, 90, 40, .1);\n    white-space: nowrap;\n  }\n  .loren-grnt__pt-ic {\n    flex: none;\n    width: 15px; height: 15px;\n    color: var(--gr-green);\n  }\n  .loren-grnt__pt-ic svg { width: 100%; height: 100%; display: block; }\n\n  /* כניסת pills בקפיצה */\n  .is-inview .loren-grnt__pill { animation: loren-gr-pop .55s cubic-bezier(.34,1.56,.64,1) both; }\n  .is-inview .loren-grnt__pill:nth-child(1) { animation-delay: .55s; }\n  .is-inview .loren-grnt__pill:nth-child(2) { animation-delay: .7s; }\n  .is-inview .loren-grnt__pill:nth-child(3) { animation-delay: .85s; }\n  @keyframes loren-gr-pop {\n    0%   { transform: scale(.6) translateY(10px); opacity: 0; }\n    100% { transform: scale(1) translateY(0); opacity: 1; }\n  }\n  /* לפני שהסקשן נגלה — שיהיו שקופים כדי שהקפיצה תיראה */\n  .loren-grnt:not(.is-inview) .loren-grnt__pill { opacity: 0; }\n\n  .loren-grnt__foot {\n    margin: 8px 0 0;\n    font-size: clamp(14px, 3.7vw, 16.5px);\n    font-weight: 700;\n    color: #7a6a52;\n  }\n\n  /* ===== הופעה מדורגת ===== */\n  [data-gr-reveal] {\n    opacity: 0;\n    transform: translateY(16px);\n    transition: opacity .6s ease, transform .6s ease;\n  }\n  .is-inview [data-gr-reveal] { opacity: 1; transform: none; }\n\n  /* ===== reduced motion — הכל סטטי וגלוי ===== */\n  @media (prefers-reduced-motion: reduce) {\n    [data-gr-reveal],\n    .loren-grnt:not(.is-inview) .loren-grnt__pill { opacity: 1; transform: none; transition: none; }\n    .is-inview .loren-grnt__pulse,\n    .is-inview .loren-grnt__pulse--2,\n    .is-inview .loren-grnt__pill,\n    .is-inview .loren-grnt__check { animation: none; }\n    .loren-grnt__check { stroke-dashoffset: 0; }\n  }\n</style>\n\n<script>\n  (function () {\n    var root = document.getElementById('lorenGrnt');\n    if (!root) return;\n    var daysEl = document.getElementById('lorenGrntDays');\n    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n\n    function setStagger() {\n      var items = root.querySelectorAll('[data-gr-reveal]');\n      for (var i = 0; i < items.length; i++) {\n        items[i].style.transitionDelay = (i * 130) + 'ms';\n      }\n    }\n\n    /* מונה 0 → 14 */\n    function countUp() {\n      if (!daysEl) return;\n      if (reduce) { daysEl.textContent = '14'; return; }\n      var start = null, DUR = 1000, TARGET = 14;\n      function tick(ts) {\n        if (!start) start = ts;\n        var p = Math.min((ts - start) / DUR, 1);\n        /* easing עדין */\n        var eased = 1 - Math.pow(1 - p, 3);\n        daysEl.textContent = Math.round(eased * TARGET);\n        if (p < 1) requestAnimationFrame(tick);\n      }\n      requestAnimationFrame(tick);\n    }\n\n    function activate() {\n      if (root.classList.contains('is-inview')) return;\n      setStagger();\n      root.classList.add('is-inview');\n      setTimeout(countUp, 250);\n    }\n\n    if (reduce || !('IntersectionObserver' in window)) {\n      activate();\n      return;\n    }\n\n    var io = new IntersectionObserver(function (entries) {\n      entries.forEach(function (e) {\n        if (e.isIntersecting) { activate(); io.disconnect(); }\n      });\n    }, { threshold: 0.35 });\n    io.observe(root);\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 16
      }
    },
    "custom_liquid_bgnHAT": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  ============================================================\n  LOREN – סקשן FAQ (אקורדיון)\n  ------------------------------------------------------------\n  • רק שאלה אחת פתוחה בכל רגע — פתיחה סוגרת את הקודמת.\n  • אנימציית פתיחה/סגירה חלקה, RTL, מותאם נייד.\n  • לחיבור הפאזל: Padding → Top = 0 בבלוק הזה,\n    Padding → Bottom = 0 בבלוק שמעליו.\n  • לעריכת שאלות: כל שאלה היא בלוק <details> — פשוט לשכפל/למחוק.\n  ============================================================\n{%- endcomment -%}\n\n<section class=\"loren-faq\" dir=\"rtl\" id=\"lorenFaq\">\n  <span class=\"loren-faq__edge loren-faq__edge--top\" aria-hidden=\"true\"></span>\n  <span class=\"loren-faq__edge loren-faq__edge--bottom\" aria-hidden=\"true\"></span>\n\n  <div class=\"loren-faq__inner\">\n\n    <p class=\"loren-faq__kicker\">רגע לפני שמזמינים</p>\n    <h2 class=\"loren-faq__title\">שאלות שכל אמא שואלת</h2>\n\n    <div class=\"loren-faq__list\">\n\n      <details class=\"loren-faq__item\">\n        <summary class=\"loren-faq__q\">\n          <span>זה באמת עובד?</span>\n          <span class=\"loren-faq__ic\" aria-hidden=\"true\"></span>\n        </summary>\n        <div class=\"loren-faq__a\"><div class=\"loren-faq__a-in\">\n          כן — וזו לא קסם, זו פשוט הדרך שבה יתושים עובדים. יתושים מאתרים אותנו לפי ריח.\n          השמנים הטבעיים במדבקה (ציטרונלה, אקליפטוס ולימון גראס) יוצרים בועת ריח סביב הילד\n          שפשוט מסתירה אותו מהיתושים. ואם אצלכם זה לא יעבוד — יש לכם 14 ימי ניסיון והחזר כספי.\n        </div></div>\n      </details>\n\n      <details class=\"loren-faq__item\">\n        <summary class=\"loren-faq__q\">\n          <span>זה בטוח לתינוקות?</span>\n          <span class=\"loren-faq__ic\" aria-hidden=\"true\"></span>\n        </summary>\n        <div class=\"loren-faq__a\"><div class=\"loren-faq__a-in\">\n          כן, מגיל 0. וזה בדיוק היתרון הגדול: המדבקה נדבקת <b>על הבגד — לא על העור</b>.\n          שום דבר לא נמרח, לא מרוסס ולא נוגע בגוף של הילד. בלי DEET ובלי כימיקלים,\n          רק שמנים צמחיים טבעיים.\n        </div></div>\n      </details>\n\n      <details class=\"loren-faq__item\">\n        <summary class=\"loren-faq__q\">\n          <span>איפה מדביקים וכמה מדבקות צריך?</span>\n          <span class=\"loren-faq__ic\" aria-hidden=\"true\"></span>\n        </summary>\n        <div class=\"loren-faq__a\"><div class=\"loren-faq__a-in\">\n          מדביקים על הבגד — הכי נוח על הגב, הכתף או השרוול.\n          <b>גיל 0–2:</b> מדבקה אחת על הגב · <b>גיל 3–5:</b> 2 מדבקות · <b>גיל 6+:</b> עד 4 מדבקות.\n          ילד גדול יותר = בועת ריח גדולה יותר.\n        </div></div>\n      </details>\n\n      <details class=\"loren-faq__item\">\n        <summary class=\"loren-faq__q\">\n          <span>כמה זמן מדבקה אחת מחזיקה?</span>\n          <span class=\"loren-faq__ic\" aria-hidden=\"true\"></span>\n        </summary>\n        <div class=\"loren-faq__a\"><div class=\"loren-faq__a-in\">\n          עד <b>8 שעות של הגנה רציפה</b> — מספיק ליום שלם בגן, טיול אחר הצהריים וגם ערב בחוץ.\n          אחרי 8 שעות פשוט מחליפים למדבקה חדשה.\n        </div></div>\n      </details>\n\n      <details class=\"loren-faq__item\">\n        <summary class=\"loren-faq__q\">\n          <span>מה קורה אם הילד מזיע או נרטב?</span>\n          <span class=\"loren-faq__ic\" aria-hidden=\"true\"></span>\n        </summary>\n        <div class=\"loren-faq__a\"><div class=\"loren-faq__a-in\">\n          כלום — המדבקה <b>עמידה במים ובזיעה</b>. גינה, מתקנים, התזות מים בקיץ...\n          המדבקה נשארת במקום וממשיכה לעבוד.\n        </div></div>\n      </details>\n\n      <details class=\"loren-faq__item\">\n        <summary class=\"loren-faq__q\">\n          <span>יש לזה ריח חזק?</span>\n          <span class=\"loren-faq__ic\" aria-hidden=\"true\"></span>\n        </summary>\n        <div class=\"loren-faq__a\"><div class=\"loren-faq__a-in\">\n          יש ריח צמחי עדין ונעים של לימונית — רוב ההורים דווקא אוהבים אותו.\n          הוא מורגש בעיקר ליתושים, לא לכם: לא משהו חריף שממלא את החדר.\n        </div></div>\n      </details>\n\n      <details class=\"loren-faq__item\">\n        <summary class=\"loren-faq__q\">\n          <span>ומה אם זה לא יעבוד לנו?</span>\n          <span class=\"loren-faq__ic\" aria-hidden=\"true\"></span>\n        </summary>\n        <div class=\"loren-faq__a\"><div class=\"loren-faq__a-in\">\n          אז זה עלינו. יש לכם <b>14 ימי ניסיון</b> — אם לא הרגשתם הבדל,\n          מחזירים את המדבקות שנשארו ומקבלים החזר כספי. בלי שאלות מיותרות.\n        </div></div>\n      </details>\n\n    </div>\n  </div>\n</section>\n\n<style>\n  .loren-faq {\n    --faq-accent: #2f5fd6;\n    --faq-text: #22303e;\n    --faq-sub: #45525f;\n    --faq-edge: #ffffff;\n    position: relative;\n    font-family: inherit;\n    color: var(--faq-text);\n    /* ממשיך מהאפרסק/קרם של סוף סקשן ההתחייבות ומתערבב בהדרגה לתכלת */\n    background: linear-gradient(180deg, #fdf3e7 0%, #f7eedd 30%, #ecf2ec 62%, #e3f2fd 100%);\n    padding: 56px 0 62px;\n    overflow: hidden;\n    isolation: isolate;\n  }\n  .loren-faq *,\n  .loren-faq *::before,\n  .loren-faq *::after { box-sizing: border-box; }\n\n  /* ===== שוליים מסולסלים (פאזל) ===== */\n  .loren-faq__edge {\n    position: absolute; left: 0; width: 100%; height: 22px; z-index: 2;\n    background: var(--faq-edge); pointer-events: none;\n  }\n  .loren-faq__edge--top {\n    top: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 22px, transparent 96%, #000 100%) 22px 0 / 44px 100% repeat-x;\n  }\n  .loren-faq__edge--bottom {\n    bottom: 0;\n    -webkit-mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n            mask: radial-gradient(circle 15px at 22px 0px, transparent 96%, #000 100%) 0 0 / 44px 100% repeat-x;\n  }\n\n  .loren-faq__inner {\n    position: relative; z-index: 1;\n    max-width: 640px;\n    margin: 0 auto;\n    padding: 0 20px;\n  }\n\n  .loren-faq__kicker {\n    margin: 0 0 6px;\n    text-align: center;\n    font-size: clamp(13px, 3.4vw, 15px);\n    font-weight: 800;\n    letter-spacing: .05em;\n    color: var(--faq-accent);\n  }\n  .loren-faq__title {\n    margin: 0 0 26px;\n    text-align: center;\n    font-size: clamp(22px, 5.4vw, 31px);\n    font-weight: 800;\n    letter-spacing: -0.2px;\n  }\n\n  .loren-faq__list {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n\n  /* ===== פריט ===== */\n  .loren-faq__item {\n    background: #ffffff;\n    border: 1px solid rgba(47, 95, 214, .1);\n    border-radius: 16px;\n    box-shadow: 0 4px 14px rgba(40, 60, 90, .05);\n    overflow: hidden;\n    transition: box-shadow .25s ease, border-color .25s ease;\n  }\n  .loren-faq__item[open] {\n    border-color: rgba(47, 95, 214, .28);\n    box-shadow: 0 10px 26px rgba(40, 60, 90, .1);\n  }\n\n  .loren-faq__q {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    padding: 16px 18px;\n    cursor: pointer;\n    list-style: none;\n    font-size: clamp(15.5px, 4.1vw, 18px);\n    font-weight: 700;\n    line-height: 1.4;\n    color: var(--faq-text);\n    -webkit-tap-highlight-color: transparent;\n    user-select: none;\n  }\n  .loren-faq__q::-webkit-details-marker { display: none; }\n  .loren-faq__q:hover { color: var(--faq-accent); }\n\n  /* אייקון +/− */\n  .loren-faq__ic {\n    flex: none;\n    position: relative;\n    width: 26px; height: 26px;\n    border-radius: 50%;\n    background: rgba(47, 95, 214, .09);\n    transition: background .25s ease, transform .3s ease;\n  }\n  .loren-faq__ic::before,\n  .loren-faq__ic::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    margin: auto;\n    background: var(--faq-accent);\n    border-radius: 2px;\n    transition: transform .3s ease, opacity .3s ease;\n  }\n  .loren-faq__ic::before { width: 12px; height: 2px; }\n  .loren-faq__ic::after  { width: 2px;  height: 12px; }\n  .loren-faq__item[open] .loren-faq__ic {\n    background: var(--faq-accent);\n    transform: rotate(180deg);\n  }\n  .loren-faq__item[open] .loren-faq__ic::before { background: #fff; }\n  .loren-faq__item[open] .loren-faq__ic::after  { opacity: 0; transform: rotate(90deg); }\n\n  /* ===== תשובה — אנימציית גובה חלקה ===== */\n  .loren-faq__a {\n    display: grid;\n    grid-template-rows: 0fr;\n    transition: grid-template-rows .38s cubic-bezier(.4,0,.2,1);\n  }\n  .loren-faq__item[open] .loren-faq__a { grid-template-rows: 1fr; }\n  .loren-faq__a-in {\n    overflow: hidden;\n    padding: 0 18px;\n    font-size: clamp(14.5px, 3.8vw, 16.5px);\n    line-height: 1.75;\n    font-weight: 500;\n    color: var(--faq-sub);\n  }\n  .loren-faq__item[open] .loren-faq__a-in { padding-bottom: 18px; }\n  .loren-faq__a-in b { font-weight: 800; color: var(--faq-text); }\n\n  @media (prefers-reduced-motion: reduce) {\n    .loren-faq__a, .loren-faq__ic, .loren-faq__ic::before, .loren-faq__ic::after, .loren-faq__item { transition: none; }\n  }\n</style>\n\n<script>\n  (function () {\n    var root = document.getElementById('lorenFaq');\n    if (!root) return;\n    var items = Array.prototype.slice.call(root.querySelectorAll('.loren-faq__item'));\n\n    items.forEach(function (item) {\n      var summary = item.querySelector('.loren-faq__q');\n      if (!summary) return;\n\n      summary.addEventListener('click', function (e) {\n        e.preventDefault(); /* אנחנו מנהלים את הפתיחה בעצמנו לאנימציה נכונה */\n\n        var isOpen = item.hasAttribute('open');\n\n        /* סגור את כל האחרים */\n        items.forEach(function (other) {\n          if (other !== item && other.hasAttribute('open')) closeItem(other);\n        });\n\n        if (isOpen) closeItem(item);\n        else openItem(item);\n      });\n    });\n\n    function openItem(item) {\n      item.setAttribute('open', '');\n    }\n\n    function closeItem(item) {\n      /* מסירים את open רק אחרי שאנימציית הסגירה מתחילה להיראות חלק:\n         מכיוון שהאנימציה עובדת עם grid-template-rows על [open],\n         נשתמש בטריק: מוסיפים מחלקה שסוגרת ויזואלית, ואז מסירים open בסוף. */\n      var a = item.querySelector('.loren-faq__a');\n      if (!a) { item.removeAttribute('open'); return; }\n\n      /* הפעל סגירה ויזואלית */\n      a.style.gridTemplateRows = '0fr';\n      var inEl = item.querySelector('.loren-faq__a-in');\n      if (inEl) inEl.style.paddingBottom = '0';\n\n      var done = false;\n      function finish() {\n        if (done) return;\n        done = true;\n        item.removeAttribute('open');\n        a.style.gridTemplateRows = '';\n        if (inEl) inEl.style.paddingBottom = '';\n        a.removeEventListener('transitionend', finish);\n      }\n      a.addEventListener('transitionend', finish);\n      setTimeout(finish, 450); /* fallback */\n    }\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 52
      }
    }
