        "custom_liquid": "<style>\n.elora-hero{position:relative;overflow:hidden;background:linear-gradient(160deg,#eaf6ef 0%,#f6fbf5 45%,#fff 100%);padding:64px 20px 72px;text-align:center;direction:rtl;font-family:'Assistant','Heebo',sans-serif}\n.elora-hero *{box-sizing:border-box}\n.elora-hero__badge{display:inline-flex;align-items:center;gap:8px;background:#fff;border:1px solid #d5ecdd;color:#2e7d52;font-weight:700;font-size:14px;padding:8px 16px;border-radius:100px;box-shadow:0 4px 18px rgba(46,125,82,.10);margin-bottom:26px}\n.elora-hero__badge span{display:inline-block;width:8px;height:8px;border-radius:50%;background:#39b06a;box-shadow:0 0 0 4px rgba(57,176,106,.18)}\n.elora-hero h1{font-size:clamp(30px,6vw,52px);line-height:1.18;font-weight:800;color:#173d29;max-width:900px;margin:0 auto 8px}\n.elora-hero h1 .hl{color:#2e9e5b;position:relative;white-space:nowrap}\n.elora-hero h1 .hl:after{content:\"\";position:absolute;left:0;right:0;bottom:2px;height:10px;background:rgba(57,176,106,.22);border-radius:6px;z-index:-1}\n.elora-hero__sub{font-size:clamp(17px,2.4vw,21px);color:#4a6b58;max-width:620px;margin:22px auto 0;line-height:1.6}\n.elora-hero__cta{margin-top:34px}\n.elora-hero__cta a{display:inline-block;background:#173d29;color:#fff;font-weight:800;font-size:18px;padding:16px 44px;border-radius:100px;text-decoration:none;box-shadow:0 12px 30px rgba(23,61,41,.25);transition:transform .2s,box-shadow .2s}\n.elora-hero__cta a:hover{transform:translateY(-3px);box-shadow:0 18px 40px rgba(23,61,41,.32)}\n.elora-hero__trust{margin-top:20px;font-size:14px;color:#6b8577;font-weight:600}\n.elora-hero__blob{position:absolute;border-radius:50%;filter:blur(60px);opacity:.5;z-index:0}\n.elora-hero__blob.b1{width:320px;height:320px;background:#bfe8cd;top:-90px;right:-80px}\n.elora-hero__blob.b2{width:260px;height:260px;background:#d9f0e0;bottom:-90px;left:-70px}\n.elora-hero__inner{position:relative;z-index:1}\n</style>\n<section class=\"elora-hero\">\n  <div class=\"elora-hero__blob b1\"></div>\n  <div class=\"elora-hero__blob b2\"></div>\n  <div class=\"elora-hero__inner\">\n    <div class=\"elora-hero__badge\"><span></span>ציטרונלה טבעית 100% &nbsp;|&nbsp; מגיל 0</div>\n    <h1>הדרך הכי יעילה להגן על הילד שלך מיתושים<br>היא <span class=\"hl\">לא לשים שום דבר</span> על העור שלו</h1>\n    <p class=\"elora-hero__sub\">מדבקות אלורה נדבקות על הבגד ויוצרות בועת הגנה טבעית סביב הילד — בלי כימיקלים, בלי ריסוס, בלי מגע עם העור.</p>\n    <div class=\"elora-hero__cta\"><a href=\"#buy\">אני רוצה להגן על הילד שלי »</a></div>\n    <div class=\"elora-hero__trust\">★★★★★ מעל 200 הורים כבר עברו למדבקות אלורה</div>\n  </div>\n</section>",
