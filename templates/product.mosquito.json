      "settings": {
        "custom_liquid": "<style>\n.elx-hero{position:relative;overflow:hidden;background:linear-gradient(165deg,#eaf0ff 0%,#dbe6ff 55%,#cdddff 100%);padding:70px 20px 110px;text-align:center;direction:rtl;font-family:'Assistant','Heebo',sans-serif}\n.elx-hero *{box-sizing:border-box}\n.elx-hero__in{position:relative;z-index:3;max-width:900px;margin:0 auto}\n.elx-hero__badge{display:inline-flex;align-items:center;gap:9px;background:#fff;border:1px solid #c7d6ff;color:#1f4fc9;font-weight:800;font-size:14px;padding:9px 18px;border-radius:100px;box-shadow:0 6px 20px rgba(31,79,201,.14);margin-bottom:26px}\n.elx-hero__badge i{width:9px;height:9px;border-radius:50%;background:#28c76f;box-shadow:0 0 0 4px rgba(40,199,111,.2);animation:elxpulse 1.8s infinite}\n@keyframes elxpulse{0%,100%{box-shadow:0 0 0 4px rgba(40,199,111,.2)}50%{box-shadow:0 0 0 8px rgba(40,199,111,0)}}\n.elx-hero h1{font-size:clamp(31px,6.2vw,56px);line-height:1.16;font-weight:800;color:#122a6b;margin:0 auto;max-width:820px}\n.elx-hero h1 .hl{color:#1f4fc9;position:relative;white-space:nowrap;display:inline-block}\n.elx-hero h1 .hl svg{position:absolute;left:0;right:0;bottom:-8px;width:100%;height:12px}\n.elx-hero__sub{font-size:clamp(17px,2.4vw,21px);color:#3a4a7a;max-width:600px;margin:26px auto 0;line-height:1.65}\n.elx-float{position:absolute;z-index:1;user-select:none;pointer-events:none}\n.elx-float.f1{top:8%;right:6%;font-size:46px;animation:elxfloat 6s ease-in-out infinite}\n.elx-float.f2{top:16%;left:7%;font-size:40px;animation:elxfloat 5s ease-in-out infinite .6s}\n.elx-float.f3{bottom:26%;right:11%;font-size:34px;animation:elxfloat 7s ease-in-out infinite .3s}\n.elx-float.f4{bottom:30%;left:9%;font-size:30px;animation:elxfloat 5.5s ease-in-out infinite 1s}\n.elx-cloud{position:absolute;background:#fff;border-radius:100px;opacity:.85;z-index:1}\n.elx-cloud.c1{width:120px;height:34px;top:12%;left:14%;animation:elxdrift 9s ease-in-out infinite}\n.elx-cloud.c1:before{content:\"\";position:absolute;width:52px;height:52px;background:#fff;border-radius:50%;top:-22px;right:22px}\n.elx-cloud.c2{width:90px;height:26px;top:30%;right:16%;animation:elxdrift 11s ease-in-out infinite 1s}\n.elx-cloud.c2:before{content:\"\";position:absolute;width:40px;height:40px;background:#fff;border-radius:50%;top:-16px;right:16px}\n@keyframes elxfloat{0%,100%{transform:translateY(0) rotate(-4deg)}50%{transform:translateY(-16px) rotate(4deg)}}\n@keyframes elxdrift{0%,100%{transform:translateX(0)}50%{transform:translateX(18px)}}\n.elx-hero__wave{position:absolute;left:0;right:0;bottom:-1px;width:100%;z-index:2;line-height:0}\n.elx-hero .elx-reveal{opacity:0;transform:translateY(24px);animation:elxup .9s ease forwards}\n.elx-hero .d1{animation-delay:.05s}.elx-hero .d2{animation-delay:.2s}.elx-hero .d3{animation-delay:.35s}\n@keyframes elxup{to{opacity:1;transform:none}}\n</style>\n<section class=\"elx-hero\">\n  <span class=\"elx-float f1\">🦟</span>\n  <span class=\"elx-float f2\">☀️</span>\n  <span class=\"elx-float f3\">🧸</span>\n  <span class=\"elx-float f4\">🌿</span>\n  <span class=\"elx-cloud c1\"></span>\n  <span class=\"elx-cloud c2\"></span>\n  <div class=\"elx-hero__in\">\n    <div class=\"elx-hero__badge elx-reveal d1\"><i></i>ציטרונלה טבעית 100% &nbsp;|&nbsp; מתאים מגיל 0</div>\n    <h1 class=\"elx-reveal d2\">הדרך הכי יעילה להגן על הילד שלך מיתושים<br>היא <span class=\"hl\">לא לשים שום דבר<svg viewBox=\"0 0 200 12\" preserveAspectRatio=\"none\"><path d=\"M2 8 Q50 2 100 6 T198 5\" stroke=\"#ffd23f\" stroke-width=\"6\" fill=\"none\" stroke-linecap=\"round\"/></svg></span> על העור שלו</h1>\n    <p class=\"elx-hero__sub elx-reveal d3\">מדבקות אלורה נדבקות על הבגד ויוצרות בועת הגנה טבעית סביב הילד, בלי כימיקלים, בלי ריסוס ובלי מגע עם העור.</p>\n  </div>\n  <div class=\"elx-hero__wave\"><svg viewBox=\"0 0 1440 120\" preserveAspectRatio=\"none\" style=\"width:100%;height:90px;display:block\"><path fill=\"#122a6b\" d=\"M0,64 C240,120 480,10 720,48 C960,86 1200,20 1440,60 L1440,120 L0,120 Z\"></path></svg></div>\n</section>",
