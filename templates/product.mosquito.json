    "custom_liquid_p4J6rj": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-how{position:relative;background:#eaf0ff;padding:110px 20px 130px;direction:rtl;font-family:'Assistant','Heebo',sans-serif;overflow:hidden}\n.elx-how *{box-sizing:border-box}\n.elx-how__top{position:absolute;top:-1px;left:0;width:100%;line-height:0;z-index:2}\n.elx-how__head{text-align:center;max-width:720px;margin:0 auto 54px;position:relative;z-index:3}\n.elx-how .eyebrow{color:#1f4fc9;font-weight:800;font-size:17px;margin:0 0 12px}\n.elx-how h2{font-size:42px;font-weight:900;color:#122a6b;margin:0 0 18px}\n.elx-how .sub{font-size:19px;line-height:1.6;color:#3a4f85;margin:0}\n.elx-steps{max-width:820px;margin:0 auto;position:relative;z-index:3;display:flex;flex-direction:column;gap:24px}\n.elx-step{display:flex;align-items:center;gap:24px;background:#fff;border-radius:24px;padding:26px 30px;box-shadow:0 12px 30px rgba(31,79,201,.08);opacity:0;transform:translateY(34px);transition:opacity .6s ease,transform .6s ease}\n.elx-step.in{opacity:1;transform:none}\n.elx-step:nth-child(2){transition-delay:.1s}.elx-step:nth-child(3){transition-delay:.2s}.elx-step:nth-child(4){transition-delay:.3s}\n.elx-step__num{flex:0 0 auto;width:78px;height:78px;border-radius:20px;background:linear-gradient(145deg,#1f4fc9,#3b6fe8);color:#fff;font-size:34px;font-weight:900;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 18px rgba(31,79,201,.35);position:relative}\n.elx-step__ic{position:absolute;top:-14px;left:-14px;width:40px;height:40px;background:#fff;border-radius:12px;padding:5px;box-shadow:0 4px 10px rgba(31,79,201,.2);animation:elxBob 3.4s ease-in-out infinite}\n.elx-step:nth-child(2) .elx-step__ic{animation-delay:.4s}.elx-step:nth-child(3) .elx-step__ic{animation-delay:.8s}.elx-step:nth-child(4) .elx-step__ic{animation-delay:1.2s}\n@keyframes elxBob{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}\n.elx-step__txt{text-align:right;flex:1}\n.elx-step__txt h3{font-size:23px;font-weight:800;color:#122a6b;margin:0 0 6px}\n.elx-step__txt p{font-size:16px;line-height:1.55;color:#4a5c8a;margin:0}\n.elx-step__txt b{color:#1f4fc9}\n.elx-how__char{position:absolute;bottom:120px;left:-10px;width:130px;z-index:2;pointer-events:none;filter:drop-shadow(0 12px 18px rgba(31,79,201,.2));animation:elxSway2 5s ease-in-out infinite}\n@keyframes elxSway2{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-14px) rotate(3deg)}}\n.elx-how__wave{position:absolute;bottom:-1px;left:0;width:100%;line-height:0;z-index:2}\n@media(max-width:768px){.elx-how h2{font-size:30px}.elx-step{padding:20px;gap:16px}.elx-step__num{width:60px;height:60px;font-size:26px}.elx-how__char{width:80px;left:-14px;bottom:60px}}\n</style>\n<section class=\"elx-how\">\n  <div class=\"elx-how__top\">\n    <svg viewBox=\"0 0 1440 90\" preserveAspectRatio=\"none\" style=\"width:100%;height:70px;display:block\"><path fill=\"#eaf0ff\" d=\"M0,40 C240,85 480,5 720,35 C960,65 1200,10 1440,45 L1440,0 L0,0 Z\"></path></svg>\n  </div>\n  <img class=\"elx-how__char\" src=\"https://cdn.shopify.com/s/files/1/0825/1296/9956/files/pueplw.png?v=1782663782\" alt=\"\">\n  <div class=\"elx-how__head\">\n    <p class=\"eyebrow\">הפתרון של אלורה</p>\n    <h2>אז הנה, ככה זה עובד</h2>\n    <p class=\"sub\">מדבקה שנדבקת על הבגד ולא על העור, ויוצרת בועת הגנה טבעית שמסתירה את הילד מהיתושים, בלי לגעת בו.</p>\n  </div>\n  <div class=\"elx-steps\">\n    <div class=\"elx-step\">\n      <div class=\"elx-step__num\">1<div class=\"elx-step__ic\"><svg viewBox=\"0 0 40 40\" fill=\"none\"><path d=\"M14 6 L20 10 L26 6 L34 12 L30 18 L28 16 L28 34 L12 34 L12 16 L10 18 L6 12 Z\" fill=\"#7dd3fc\" stroke=\"#122a6b\" stroke-width=\"2.2\" stroke-linejoin=\"round\"/></svg></div></div>\n      <div class=\"elx-step__txt\"><h3>מדביקים על הבגד, לא על הילד</h3><p>עור הילד לא בא במגע עם שום דבר. פשוט מדביקים את המדבקה על החולצה או המכנס ויוצאים.</p></div>\n    </div>\n    <div class=\"elx-step\">\n      <div class=\"elx-step__num\">2<div class=\"elx-step__ic\"><svg viewBox=\"0 0 40 40\" fill=\"none\"><path d=\"M20 34 C20 22 24 12 34 8 C34 20 30 30 20 34 Z\" fill=\"#86efac\" stroke=\"#122a6b\" stroke-width=\"2.2\" stroke-linejoin=\"round\"/><path d=\"M20 34 C20 24 16 16 8 13 C8 23 11 31 20 34 Z\" fill=\"#4ade80\" stroke=\"#122a6b\" stroke-width=\"2.2\" stroke-linejoin=\"round\"/></svg></div></div>\n      <div class=\"elx-step__txt\"><h3>ציטרונלה טבעית בלבד</h3><p>סרט דבק בדרגה רפואית, <b>מתאים מגיל 0</b>. בלי כימיקלים ובלי חומרים שאתם לא מכירים.</p></div>\n    </div>\n    <div class=\"elx-step\">\n      <div class=\"elx-step__num\">3<div class=\"elx-step__ic\"><svg viewBox=\"0 0 40 40\" fill=\"none\"><path d=\"M20 5 L32 10 V20 C32 28 26 33 20 35 C14 33 8 28 8 20 V10 Z\" fill=\"#a5b4fc\" stroke=\"#122a6b\" stroke-width=\"2.2\" stroke-linejoin=\"round\"/><path d=\"M15 20 L19 24 L26 15\" stroke=\"#122a6b\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></div>\n      <div class=\"elx-step__txt\"><h3>בועת הגנה שמסתירה את הילד</h3><p>יתושים מנווטים לפי ריח. הציטרונלה על הבגד יוצרת בועת הגנה <b>שמסתירה את הילד מהם, בלי לגעת בו.</b></p></div>\n    </div>\n    <div class=\"elx-step\">\n      <div class=\"elx-step__num\">4<div class=\"elx-step__ic\"><svg viewBox=\"0 0 40 40\" fill=\"none\"><circle cx=\"20\" cy=\"21\" r=\"13\" fill=\"#fde68a\" stroke=\"#122a6b\" stroke-width=\"2.2\"/><path d=\"M20 14 V21 L25 24\" stroke=\"#122a6b\" stroke-width=\"2.4\" fill=\"none\" stroke-linecap=\"round\"/><path d=\"M14 6 L10 9 M26 6 L30 9\" stroke=\"#122a6b\" stroke-width=\"2.2\" stroke-linecap=\"round\"/></svg></div></div>\n      <div class=\"elx-step__txt\"><h3>כמות ותזמון פשוטים</h3><p>גיל 0 עד 2: מדבקה אחת על הגב · גיל 3 עד 5: שתי מדבקות · גיל 6 ומעלה: עד 4 מדבקות. <b>מחליפים כל 8 שעות.</b></p></div>\n    </div>\n  </div>\n  <div class=\"elx-how__wave\">\n    <svg viewBox=\"0 0 1440 110\" preserveAspectRatio=\"none\" style=\"width:100%;height:90px;display:block\"><path fill=\"#ffffff\" d=\"M0,50 C240,100 480,10 720,45 C960,80 1200,15 1440,55 L1440,110 L0,110 Z\"></path></svg>\n  </div>\n</section>\n<script>\n(function(){var els=document.querySelectorAll('.elx-step');if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('in')});return;}var o=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting)x.target.classList.add('in')})},{threshold:.15});els.forEach(function(e){o.observe(e)});})();\n</script>",
