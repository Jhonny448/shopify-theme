    "custom_liquid_b69CaY": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-cmp{position:relative;background:#ffffff;padding:120px 20px 130px;direction:rtl;font-family:'Assistant','Heebo',sans-serif;overflow:hidden}\n.elx-cmp *{box-sizing:border-box}\n.elx-cmp__top{position:absolute;top:-1px;left:0;width:100%;line-height:0;z-index:2}\n.elx-cmp__head{text-align:center;max-width:720px;margin:0 auto 46px;position:relative;z-index:3}\n.elx-cmp__head h2{font-size:clamp(28px,5vw,42px);font-weight:900;color:#122a6b;margin:0 0 14px}\n.elx-cmp__head p{font-size:19px;color:#3a4f85;margin:0}\n.elx-cmp__grid{display:grid;grid-template-columns:1fr 1fr;gap:26px;max-width:960px;margin:0 auto;position:relative;z-index:3}\n.elx-col{border-radius:26px;padding:38px 28px 32px;opacity:0;transform:translateY(34px);transition:opacity .7s ease,transform .7s ease}\n.elx-col.in{opacity:1;transform:none}\n.elx-col.win{background:linear-gradient(160deg,#1f4fc9,#173da6);box-shadow:0 22px 45px rgba(31,79,201,.32);position:relative;color:#fff}\n.elx-col.lose{background:#f4f6fb;border:1px solid #e3e8f2;color:#8a94a8;transition-delay:.15s}\n.elx-tag{position:absolute;top:-18px;right:50%;transform:translateX(50%);background:#ffd23f;color:#122a6b;font-weight:900;font-size:15px;padding:8px 20px;border-radius:50px;box-shadow:0 6px 16px rgba(255,210,63,.5);white-space:nowrap}\n.elx-col h3{font-size:26px;font-weight:900;text-align:center;margin:6px 0 24px}\n.elx-col.win h3{color:#fff}\n.elx-col.lose h3{color:#6b7590}\n.elx-row{display:flex;align-items:center;gap:12px;padding:11px 0;font-size:17px;font-weight:600;border-top:1px solid rgba(255,255,255,.14)}\n.elx-col.lose .elx-row{border-top:1px solid #e3e8f2}\n.elx-row:first-of-type{border-top:none}\n.elx-mk{flex:0 0 auto;width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center}\n.elx-mk svg{width:15px;height:15px}\n.elx-col.win .elx-mk{background:#22c55e}\n.elx-col.lose .elx-mk{background:#d7ddea}\n.elx-char2{position:absolute;bottom:-6px;right:-6px;width:118px;z-index:4;pointer-events:none;filter:drop-shadow(0 10px 16px rgba(31,79,201,.3));animation:elxSway3 5s ease-in-out infinite}\n@keyframes elxSway3{0%,100%{transform:translateY(0) rotate(3deg)}50%{transform:translateY(-12px) rotate(-3deg)}}\n.elx-cmp__wave{position:absolute;bottom:-1px;left:0;width:100%;line-height:0;z-index:2}\n@media(max-width:768px){.elx-cmp__grid{grid-template-columns:1fr}.elx-col.lose{order:2}.elx-char2{width:78px}}\n</style>\n<section class=\"elx-cmp\">\n  <div class=\"elx-cmp__top\">\n    <svg viewBox=\"0 0 1440 90\" preserveAspectRatio=\"none\" style=\"width:100%;height:70px;display:block\"><path fill=\"#ffffff\" d=\"M0,45 C240,90 480,10 720,40 C960,70 1200,15 1440,50 L1440,0 L0,0 Z\"></path></svg>\n  </div>\n  <div class=\"elx-cmp__head\">\n    <h2>למה הורים עוברים לאלורה</h2>\n    <p>ההבדל בין להגן על הילד, לבין להגן על העור שלו.</p>\n  </div>\n  <div class=\"elx-cmp__grid\">\n    <div class=\"elx-col win\">\n      <span class=\"elx-tag\">&#9733; הבחירה של ההורים</span>\n      <img class=\"elx-char2\" src=\"https://cdn.shopify.com/s/files/1/0825/1296/9956/files/pink.png?v=1782663689\" alt=\"\">\n      <h3>מדבקות אלורה</h3>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 13 L10 18 L19 6\" stroke=\"#fff\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>נדבקות על הבגד, לא נוגעות בעור</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 13 L10 18 L19 6\" stroke=\"#fff\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>ציטרונלה טבעית 100%, ללא כימיקלים</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 13 L10 18 L19 6\" stroke=\"#fff\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>הגנה יציבה עד 8 שעות רצופות</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 13 L10 18 L19 6\" stroke=\"#fff\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>בלי מגע דביק, בלי ריח חריף</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M5 13 L10 18 L19 6\" stroke=\"#fff\" stroke-width=\"3.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>מתאימות מגיל 0, גם לתינוקות</div>\n    </div>\n    <div class=\"elx-col lose\">\n      <h3>קרמים ותרסיסים רגילים</h3>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M7 7 L17 17 M17 7 L7 17\" stroke=\"#98a1b5\" stroke-width=\"3.2\" stroke-linecap=\"round\"/></svg></span>נמרחים ישירות על עור הילד</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M7 7 L17 17 M17 7 L7 17\" stroke=\"#98a1b5\" stroke-width=\"3.2\" stroke-linecap=\"round\"/></svg></span>מכילים כימיקלים שקשה לזהות</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M7 7 L17 17 M17 7 L7 17\" stroke=\"#98a1b5\" stroke-width=\"3.2\" stroke-linecap=\"round\"/></svg></span>מתפוגגים מהר וצריך למרוח שוב</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M7 7 L17 17 M17 7 L7 17\" stroke=\"#98a1b5\" stroke-width=\"3.2\" stroke-linecap=\"round\"/></svg></span>ריח חזק ותחושה דביקה על העור</div>\n      <div class=\"elx-row\"><span class=\"elx-mk\"><svg viewBox=\"0 0 24 24\" fill=\"none\"><path d=\"M7 7 L17 17 M17 7 L7 17\" stroke=\"#98a1b5\" stroke-width=\"3.2\" stroke-linecap=\"round\"/></svg></span>לא תמיד מתאימים לתינוקות</div>\n    </div>\n  </div>\n  <div class=\"elx-cmp__wave\">\n    <svg viewBox=\"0 0 1440 110\" preserveAspectRatio=\"none\" style=\"width:100%;height:90px;display:block\"><path fill=\"#1f4fc9\" d=\"M0,50 C240,100 480,10 720,45 C960,80 1200,15 1440,55 L1440,110 L0,110 Z\"></path></svg>\n  </div>\n</section>\n<script>\n(function(){var els=document.querySelectorAll('.elx-col');if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('in')});return;}var o=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting)x.target.classList.add('in')})},{threshold:.2});els.forEach(function(e){o.observe(e)});})();\n</script>",
