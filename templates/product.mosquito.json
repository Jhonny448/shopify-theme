        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_Cp64PX": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n.elx-faq{position:relative;background:#f4f7ff;padding:120px 20px 130px;direction:rtl;font-family:'Assistant','Heebo',sans-serif;overflow:hidden}\n.elx-faq *{box-sizing:border-box}\n.elx-faq__top{position:absolute;top:-1px;left:0;width:100%;line-height:0;z-index:2}\n.elx-faq__deco{position:absolute;border-radius:50%;background:rgba(31,79,201,.06);z-index:1}\n.elx-faq__deco.d1{width:180px;height:180px;top:120px;right:-60px}\n.elx-faq__deco.d2{width:120px;height:120px;bottom:160px;left:-40px}\n.elx-faq__head{text-align:center;max-width:640px;margin:0 auto 44px;position:relative;z-index:3}\n.elx-faq__head h2{font-size:clamp(28px,5vw,42px);font-weight:900;color:#122a6b;margin:0 0 14px}\n.elx-faq__head p{font-size:19px;color:#4a5c8a;margin:0}\n.elx-faq__list{max-width:820px;margin:0 auto;position:relative;z-index:3;display:flex;flex-direction:column;gap:16px}\n.elx-q{background:#fff;border-radius:18px;box-shadow:0 8px 22px rgba(31,79,201,.07);overflow:hidden;opacity:0;transform:translateY(24px);transition:opacity .5s ease,transform .5s ease}\n.elx-q.in{opacity:1;transform:none}\n.elx-q:nth-child(2){transition-delay:.07s}.elx-q:nth-child(3){transition-delay:.14s}.elx-q:nth-child(4){transition-delay:.21s}.elx-q:nth-child(5){transition-delay:.28s}\n.elx-q summary{list-style:none;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:14px;padding:24px 26px;font-size:20px;font-weight:800;color:#122a6b}\n.elx-q summary::-webkit-details-marker{display:none}\n.elx-q__ic{flex:0 0 auto;width:34px;height:34px;border-radius:50%;background:#1f4fc9;position:relative;transition:transform .3s ease}\n.elx-q__ic:before,.elx-q__ic:after{content:'';position:absolute;background:#fff;border-radius:2px;top:50%;left:50%;transform:translate(-50%,-50%)}\n.elx-q__ic:before{width:15px;height:3px}\n.elx-q__ic:after{width:3px;height:15px;transition:transform .3s ease}\n.elx-q[open] .elx-q__ic{transform:rotate(180deg)}\n.elx-q[open] .elx-q__ic:after{transform:translate(-50%,-50%) scaleY(0)}\n.elx-q__a{padding:0 26px 26px;font-size:17px;line-height:1.7;color:#4a5c8a}\n.elx-faq__wave{position:absolute;bottom:-1px;left:0;width:100%;line-height:0;z-index:2}\n@media(max-width:768px){.elx-faq__head h2{font-size:28px}.elx-q summary{font-size:17px;padding:18px 20px}}\n</style>\n<section class=\"elx-faq\">\n  <div class=\"elx-faq__top\">\n    <svg viewBox=\"0 0 1440 90\" preserveAspectRatio=\"none\" style=\"width:100%;height:70px;display:block\"><path fill=\"#f4f7ff\" d=\"M0,40 C240,85 480,5 720,35 C960,65 1200,10 1440,45 L1440,0 L0,0 Z\"></path></svg>\n  </div>\n  <span class=\"elx-faq__deco d1\"></span>\n  <span class=\"elx-faq__deco d2\"></span>\n  <div class=\"elx-faq__head\">\n    <h2>שאלות שהורים שואלים</h2>\n    <p>כל מה שרציתם לדעת לפני שאתם מגנים על הילד בצורה חכמה.</p>\n  </div>\n  <div class=\"elx-faq__list\">\n    <details class=\"elx-q\" open>\n      <summary>האם זה בטוח לתינוקות?<span class=\"elx-q__ic\"></span></summary>\n      <div class=\"elx-q__a\">כן. המדבקות מבוססות על ציטרונלה טבעית בלבד עם סרט דבק בדרגה רפואית, ומתאימות מגיל 0. הן נדבקות על הבגד ולא נוגעות בעור של הילד כלל.</div>\n    </details>\n    <details class=\"elx-q\">\n      <summary>כמה זמן ההגנה מחזיקה?<span class=\"elx-q__ic\"></span></summary>\n      <div class=\"elx-q__a\">כל מדבקה מגנה עד 8 שעות רצופות. פשוט מדביקים בבוקר לפני היציאה, ומחליפים לאחר 8 שעות במידת הצורך.</div>\n    </details>\n    <details class=\"elx-q\">\n      <summary>כמה מדבקות צריך לשים?<span class=\"elx-q__ic\"></span></summary>\n      <div class=\"elx-q__a\">תלוי בגיל: גיל 0 עד 2 מדבקה אחת על הגב. גיל 3 עד 5 שתי מדבקות. גיל 6 ומעלה עד 4 מדבקות. מפזרים על הבגדים לכיסוי מיטבי.</div>\n    </details>\n    <details class=\"elx-q\">\n      <summary>איך זה עובד בכלל בלי לגעת בעור?<span class=\"elx-q__ic\"></span></summary>\n      <div class=\"elx-q__a\">יתושים מנווטים לפי ריח. הציטרונלה שעל הבגד יוצרת בועת הגנה ריחנית שמסתירה את הילד מהיתושים, כך שהם פשוט לא מזהים אותו, בלי שום מגע עם העור.</div>\n    </details>\n    <details class=\"elx-q\">\n      <summary>האם המדבקה משאירה סימנים על הבגד?<span class=\"elx-q__ic\"></span></summary>\n      <div class=\"elx-q__a\">לא. המדבקות מתקלפות בקלות ולא משאירות שאריות דבק על הבגד. הן עמידות לאורך היום אך פשוטות להסרה בסוף.</div>\n    </details>\n  </div>\n  <div class=\"elx-faq__wave\">\n    <svg viewBox=\"0 0 1440 110\" preserveAspectRatio=\"none\" style=\"width:100%;height:90px;display:block\"><path fill=\"#1f4fc9\" d=\"M0,50 C240,100 480,10 720,45 C960,80 1200,15 1440,55 L1440,110 L0,110 Z\"></path></svg>\n  </div>\n</section>\n<script>\n(function(){var els=document.querySelectorAll('.elx-q');if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('in')});return;}var o=new IntersectionObserver(function(en){en.forEach(function(x){if(x.isIntersecting)x.target.classList.add('in')})},{threshold:.15});els.forEach(function(e){o.observe(e)});})();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
