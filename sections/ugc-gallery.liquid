{{ 'natpat-kit.css' | asset_url | stylesheet_tag }}
{{ 'ugc-gallery.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  #ugc-{{ section.id }} { --cols: {{ section.settings.columns_desktop }}; }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div id="ugc-{{ section.id }}" class="np-section ugc color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
      <div class="np-head">
        {%- if section.settings.eyebrow != blank -%}<span class="np-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="np-head__title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}<p class="np-head__subtext">{{ section.settings.subtext }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="ugc__grid" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign has_link = false
          if block.settings.link != blank
            assign has_link = true
          endif
        -%}
        <{% if has_link %}a href="{{ block.settings.link }}"{% else %}div{% endif %} class="ugc__item" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '200,300,400,600,800', class: 'ugc__img', alt: block.settings.alt | default: '' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'ugc__img placeholder-svg' }}
          {%- endif -%}
        </{% if has_link %}a{% else %}div{% endif %}>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "גלריית משפחות (NatPat)",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "#המשפחה_שלנו" },
    { "type": "inline_richtext", "id": "title", "label": "Heading", "default": "משפחות אמיתיות, רגעים אמיתיים" },
    {
      "type": "select", "id": "heading_size", "label": "Heading size",
      "options": [ { "value": "h2", "label": "Medium" }, { "value": "h1", "label": "Large" } ],
      "default": "h1"
    },
    { "type": "text", "id": "subtext", "label": "Subtext" },
    { "type": "range", "id": "columns_desktop", "min": 3, "max": 6, "step": 1, "label": "Columns on desktop", "default": 4 },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "תמונה",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "גלריית משפחות (NatPat)",
      "blocks": [
        { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" },
        { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
