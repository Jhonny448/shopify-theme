{{ 'natpat-kit.css' | asset_url | stylesheet_tag }}
{{ 'product-story.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} {
    --np-green: {{ section.settings.accent | default: '#2e44d4' }};
    --np-green-dark: {{ section.settings.accent | default: '#2e44d4' | color_darken: 12 }};
    --np-green-soft: {{ section.settings.accent | default: '#2e44d4' | color_lighten: 45 }};
    --story-align: {{ section.settings.text_align }};
    --story-max: {{ section.settings.content_width }}rem;
  }
{%- endstyle -%}

<div class="np-section story color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="story__inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="np-eyebrow story__eyebrow{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.headline != blank -%}
        <h2 class="story__headline {{ section.settings.heading_size }} inline-richtext{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"{% if settings.animations_reveal_on_scroll %} style="--animation-order: 1;"{% endif %}>{{ section.settings.headline }}</h2>
      {%- endif -%}

      <div class="story__body">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'paragraph' -%}
              <div class="story__para rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"{% if settings.animations_reveal_on_scroll %} style="--animation-order: {{ forloop.index | plus: 1 }};"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
            {%- when 'highlight' -%}
              <p class="story__highlight{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"{% if settings.animations_reveal_on_scroll %} style="--animation-order: {{ forloop.index | plus: 1 }};"{% endif %} {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <div class="story__cta{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <a class="button story__btn"{% if section.settings.button_link != blank %} href="{{ section.settings.button_link }}"{% endif %}>
            {{- section.settings.button_label | escape -}}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "סיפור מוצר (NatPat)",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "למה הורים עוברים למדבקות" },
    { "type": "inline_richtext", "id": "headline", "label": "Headline", "default": "הדרך הכי יעילה להגן על הילד שלך מיתושים… <br>היא <mark>לא לשים שום דבר על העור שלו.</mark>" },
    {
      "type": "select", "id": "heading_size", "label": "Headline size",
      "options": [ { "value": "h2", "label": "Medium" }, { "value": "h1", "label": "Large" }, { "value": "h0", "label": "Extra large" } ],
      "default": "h1"
    },
    {
      "type": "select", "id": "text_align", "label": "Text alignment",
      "options": [ { "value": "center", "label": "Center" }, { "value": "start", "label": "Start (right in RTL)" } ],
      "default": "center"
    },
    { "type": "range", "id": "content_width", "min": 50, "max": 90, "step": 2, "unit": "rem", "label": "Content width", "default": 68 },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#2e44d4" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "פסקה",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>כתבו כאן פסקה מהסיפור.</p>" }
      ]
    },
    {
      "type": "highlight",
      "name": "משפט מודגש",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "משפט מפתח מודגש" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "סיפור מוצר (NatPat)",
      "blocks": [
        { "type": "paragraph", "settings": { "text": "<p>כן, זה נשמע קצת מוזר — כי זה נוגד את מה שאנחנו מכירים. אבל רוב ההורים לא יודעים שיש פתרון שעובד בלי למרוח או לרסס כלום על העור של הילד.</p>" } },
        { "type": "paragraph", "settings": { "text": "<p>אומרים שהתרסיסים בטוחים. אולי זה נכון. אבל כשמדובר בילד שלך — למה בכלל לקחת סיכון, אם יש פתרון שעובד בלי לשים שום דבר על העור שלו?</p>" } },
        { "type": "paragraph", "settings": { "text": "<p>כל קיץ אותו סיפור. יתושים, עקיצות, ילד שמגרד — ואתם מחפשים פתרון שסוף סוף יעבוד. מרחתם קרם, ריססתם תרסיס — ועדיין הילד חזר הביתה עם עקיצות.</p>" } },
        { "type": "highlight", "settings": { "text": "יש פתרון אחר. מדבקה שמדביקים על הבגד — לא על העור — ומרחיקה יתושים עד 8 שעות." } },
        { "type": "paragraph", "settings": { "text": "<p>המדבקה מכילה ציטרונלה — שמן צמחי טבעי שיוצר בועת ריח סביב הילד. יתושים מנווטים לפי ריח, ובועת הריח פשוט מסתירה אותו מהם. ככה עור הילד לא נוגע בשום דבר.</p>" } },
        { "type": "paragraph", "settings": { "text": "<p>הילד חוזר הביתה בלי עקיצות. אתם חוזרים הביתה רגועים — כי ידעתם שנתתם לו הגנה מלאה, בלי לשים שום דבר על העור שלו.</p>" } }
      ]
    }
  ]
}
{% endschema %}
