{{ 'natpat-kit.css' | asset_url | stylesheet_tag }}
{{ 'comparison.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="np-section compare color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
      <div class="np-head">
        {%- if section.settings.eyebrow != blank -%}<span class="np-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="np-head__title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="compare__table" role="table">
      <div class="compare__row compare__row--head" role="row">
        <span class="compare__feature" role="columnheader"></span>
        <span class="compare__col compare__col--us" role="columnheader">{{ section.settings.us_label }}</span>
        <span class="compare__col compare__col--them" role="columnheader">{{ section.settings.them_label }}</span>
      </div>
      {%- for block in section.blocks -%}
        <div class="compare__row" role="row" {{ block.shopify_attributes }}>
          <span class="compare__feature" role="cell">{{ block.settings.feature }}</span>
          <span class="compare__col compare__col--us" role="cell">{{ block.settings.us_value | default: '✓' }}</span>
          <span class="compare__col compare__col--them" role="cell">{{ block.settings.them_value | default: '✗' }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "השוואה (NatPat)",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ההבדל ברור" },
    { "type": "inline_richtext", "id": "title", "label": "Heading", "default": "למה לבחור בנו?" },
    {
      "type": "select", "id": "heading_size", "label": "Heading size",
      "options": [ { "value": "h2", "label": "Medium" }, { "value": "h1", "label": "Large" } ],
      "default": "h1"
    },
    { "type": "text", "id": "us_label", "label": "Our column label", "default": "המדבקות שלנו" },
    { "type": "text", "id": "them_label", "label": "Others column label", "default": "פתרונות אחרים" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "שורת השוואה",
      "settings": [
        { "type": "text", "id": "feature", "label": "Feature", "default": "100% טבעי" },
        { "type": "text", "id": "us_value", "label": "Our value (✓ or text)", "default": "✓" },
        { "type": "text", "id": "them_value", "label": "Others value (✗ or text)", "default": "✗" }
      ]
    }
  ],
  "presets": [
    {
      "name": "השוואה (NatPat)",
      "blocks": [
        { "type": "row", "settings": { "feature": "100% טבעי, ללא DEET" } },
        { "type": "row", "settings": { "feature": "בטוח לילדים מגיל 0" } },
        { "type": "row", "settings": { "feature": "בלי ריסוס על העור" } },
        { "type": "row", "settings": { "feature": "ריח נעים" } },
        { "type": "row", "settings": { "feature": "אחריות 365 יום" } }
      ]
    }
  ]
}
{% endschema %}
