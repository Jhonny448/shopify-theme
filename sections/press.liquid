{{ 'natpat-kit.css' | asset_url | stylesheet_tag }}
{{ 'press.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  #press-{{ section.id }} { --cols: {{ section.blocks.size | at_most: 4 }}; }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} {
    --np-green: {{ section.settings.accent | default: '#2e44d4' }};
    --np-green-dark: {{ section.settings.accent | default: '#2e44d4' | color_darken: 12 }};
    --np-green-soft: {{ section.settings.accent | default: '#2e44d4' | color_lighten: 45 }};
  }
{%- endstyle -%}

<div id="press-{{ section.id }}" class="np-section press color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.title != blank -%}
      <div class="np-head">
        <h2 class="np-head__title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}

    <div class="np-carousel np-carousel--snap press__grid" role="list">
      {%- for block in section.blocks -%}
        <figure class="np-card press__card" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.settings.quote != blank -%}
            <blockquote class="press__quote">{{ block.settings.quote }}</blockquote>
          {%- endif -%}
          <figcaption class="press__logo">
            {%- if block.settings.logo != blank -%}
              {{ block.settings.logo | image_url: width: 360 | image_tag: loading: 'lazy', widths: '120,240,360', class: 'press__logo-img', alt: block.settings.name | default: '' }}
            {%- else -%}
              <span class="press__logo-name">{{ block.settings.name }}</span>
            {%- endif -%}
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "כפי שפורסם ב (NatPat)",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "inline_richtext", "id": "title", "label": "Heading", "default": "כפי שפורסם ב…" },
    {
      "type": "select", "id": "heading_size", "label": "Heading size",
      "options": [ { "value": "h2", "label": "Medium" }, { "value": "h1", "label": "Large" } ],
      "default": "h2"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#2e44d4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "פרסום",
      "settings": [
        { "type": "richtext", "id": "quote", "label": "Quote", "default": "<p>“פתרון טבעי וגאוני להרחקת יתושים מהילדים.”</p>" },
        { "type": "image_picker", "id": "logo", "label": "Publication logo" },
        { "type": "text", "id": "name", "label": "Publication name (if no logo)", "default": "Mako" }
      ]
    }
  ],
  "presets": [
    {
      "name": "כפי שפורסם ב (NatPat)",
      "blocks": [
        { "type": "logo", "settings": { "quote": "<p>“פתרון טבעי וגאוני להרחקת יתושים מהילדים.”</p>", "name": "Mako" } },
        { "type": "logo", "settings": { "quote": "<p>“הריח מדהים והמדבקות פשוט עובדות.”</p>", "name": "Ynet" } },
        { "type": "logo", "settings": { "quote": "<p>“ההורים מדברים על זה — וזה מוצדק.”</p>", "name": "Walla" } },
        { "type": "logo", "settings": { "quote": "<p>“אלטרנטיבה טבעית בלי כימיקלים מיותרים.”</p>", "name": "TheMarker" } }
      ]
    }
  ]
}
{% endschema %}
