{{ 'natpat-kit.css' | asset_url | stylesheet_tag }}
{{ 'guarantee.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} {
    --np-green: {{ section.settings.accent | default: '#2e44d4' }};
    --np-green-dark: {{ section.settings.accent | default: '#2e44d4' | color_darken: 12 }};
    --np-green-soft: {{ section.settings.accent | default: '#2e44d4' | color_lighten: 45 }};
  }
{%- endstyle -%}

<div class="np-section guarantee">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="guarantee__panel color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.image != blank -%}
        <div class="guarantee__media">
          {{ section.settings.image | image_url: width: 480 | image_tag: loading: 'lazy', widths: '160,240,360,480', class: 'guarantee__img', alt: section.settings.heading | strip_html | escape }}
        </div>
      {%- else -%}
        <div class="guarantee__media guarantee__media--emoji" aria-hidden="true">{{ section.settings.emoji | default: '🛡️' }}</div>
      {%- endif -%}
      <div class="guarantee__content">
        {%- if section.settings.eyebrow != blank -%}<span class="np-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="guarantee__heading inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}<div class="guarantee__text rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a class="button button--primary guarantee__btn"{% if section.settings.button_link != blank %} href="{{ section.settings.button_link }}"{% endif %}>
            {{- section.settings.button_label | escape -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "באנר אחריות (NatPat)",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image / icon (optional)" },
    { "type": "text", "id": "emoji", "label": "Emoji (if no image)", "default": "🛡️" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "קונים בראש שקט" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "אחריות 365 יום — החזר כספי מלא" },
    {
      "type": "select", "id": "heading_size", "label": "Heading size",
      "options": [ { "value": "h2", "label": "Medium" }, { "value": "h1", "label": "Large" }, { "value": "h0", "label": "Extra large" } ],
      "default": "h1"
    },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>אם לא אהבתם — נחזיר לכם את הכסף, בלי שאלות. פחות מ-0.5% מהלקוחות מבקשים החזר.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "קנו עכשיו בראש שקט" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-2" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#2e44d4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "presets": [ { "name": "באנר אחריות (NatPat)" } ]
}
{% endschema %}
