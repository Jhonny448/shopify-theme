{{ 'natpat-kit.css' | asset_url | stylesheet_tag }}
{{ 'how-it-works.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} {
    --np-green: {{ section.settings.accent | default: '#2e44d4' }};
    --np-green-dark: {{ section.settings.accent | default: '#2e44d4' | color_darken: 12 }};
    --np-green-soft: {{ section.settings.accent | default: '#2e44d4' | color_lighten: 45 }};
  }
{%- endstyle -%}

<div class="np-section hiw color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- if section.settings.title != blank or section.settings.eyebrow != blank -%}
      <div class="np-head">
        {%- if section.settings.eyebrow != blank -%}<span class="np-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="np-head__title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}<p class="np-head__subtext">{{ section.settings.subtext }}</p>{%- endif -%}
      </div>
    {%- endif -%}

    <ol class="hiw__grid{% if section.settings.show_connector %} hiw__grid--connected{% endif %}">
      {%- for block in section.blocks -%}
        <li class="hiw__step" {{ block.shopify_attributes }}>
          <div class="hiw__icon">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', widths: '80,120,200', class: 'hiw__img', alt: '' }}
            {%- else -%}
              <span class="hiw__emoji" aria-hidden="true">{{ block.settings.emoji | default: '✨' }}</span>
            {%- endif -%}
            <span class="hiw__num">{{ forloop.index }}</span>
          </div>
          <h3 class="hiw__title">{{ block.settings.title }}</h3>
          {%- if block.settings.text != blank -%}<div class="hiw__text rte">{{ block.settings.text }}</div>{%- endif -%}
        </li>
      {%- endfor -%}
    </ol>
  </div>
</div>

{% schema %}
{
  "name": "איך זה עובד (NatPat)",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "פשוט וקל" },
    { "type": "inline_richtext", "id": "title", "label": "Heading", "default": "איך זה עובד?" },
    {
      "type": "select", "id": "heading_size", "label": "Heading size",
      "options": [ { "value": "h2", "label": "Medium" }, { "value": "h1", "label": "Large" } ],
      "default": "h1"
    },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "שלושה צעדים פשוטים להגנה טבעית" },
    { "type": "checkbox", "id": "show_connector", "label": "Show connector line", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "accent", "label": "Accent color", "default": "#2e44d4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding bottom", "default": 48 }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "צעד",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (optional)" },
        { "type": "text", "id": "emoji", "label": "Emoji (if no image)", "default": "✨" },
        { "type": "text", "id": "title", "label": "Title", "default": "קלפו את המדבקה" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>הוציאו מדבקה מהאריזה — בלי ידיים מלוכלכות.</p>" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "איך זה עובד (NatPat)",
      "blocks": [
        { "type": "step", "settings": { "emoji": "🩹", "title": "1. קלפו", "text": "<p>הוציאו מדבקה מהאריזה — קל ונקי.</p>" } },
        { "type": "step", "settings": { "emoji": "👕", "title": "2. הדביקו", "text": "<p>הצמידו לבגד או לאביזר של הילד/ה.</p>" } },
        { "type": "step", "settings": { "emoji": "🛡️", "title": "3. מוגנים", "text": "<p>הגנה טבעית לאורך כל היום. פשוט ככה.</p>" } }
      ]
    }
  ]
}
{% endschema %}
